---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTag from '../components/ui/SectionTag.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';
import {
  getSiteSettings,
  getHomePage,
  getServices,
  getFeaturedCaseStudy,
  getPosts,
} from '../lib/sanity';

// Fetch data at build time
let settings: any = null;
let homePage: any = null;
let services: any[] = [];
let featuredCase: any = null;
let posts: any[] = [];

try {
  [settings, homePage, services, featuredCase, posts] = await Promise.all([
    getSiteSettings(),
    getHomePage(),
    getServices(),
    getFeaturedCaseStudy(),
    getPosts(3),
  ]);
} catch (_) {
  // Sanity not connected yet — use placeholder data
}

// Placeholder services if Sanity is empty
const displayServices = services.length > 0 ? services : [
  { _id: '1', title: 'Web Design & Development', description: 'High-converting websites built for service businesses. Strategy-first, not template-first.', slug: { current: 'web-design' } },
  { _id: '2', title: 'Paid Ads', description: 'Google Ads, LSA, and Meta campaigns built around your cost-per-lead goals. Not vanity metrics.', slug: { current: 'paid-ads' } },
  { _id: '3', title: 'SEO', description: 'Local and technical SEO that compounds over time and reduces your reliance on paid ads.', slug: { current: 'seo' } },
  { _id: '4', title: 'Content Creation', description: 'Video and photo content that builds authority and keeps your brand visible between campaigns.', slug: { current: 'content-creation' } },
  { _id: '5', title: 'Strategy Consulting', description: 'Not sure where to start? We\'ll audit your full digital presence and build a prioritized plan.', slug: { current: 'strategy' } },
  { _id: '6', title: 'AI Integration', description: 'Practical AI implementation that reduces cost, saves time, and gives your business a real edge.', slug: { current: 'ai-integration' } },
];

// Placeholder posts if Sanity is empty
const displayPosts = posts.length > 0 ? posts : [
  { _id: '1', title: 'Why Most Service Businesses Fail Online (And What Actually Works)', excerpt: 'The common mistakes we see across every industry, and the framework we use to fix them.', publishedAt: '2026-02-12', slug: { current: 'why-service-businesses-fail-online' } },
  { _id: '2', title: 'Local SEO in 2026: What\'s Changed and What Still Works', excerpt: 'The tactics that have faded and the fundamentals that keep driving rankings for service businesses.', publishedAt: '2026-01-14', slug: { current: 'local-seo-2026' } },
  { _id: '3', title: 'What Makes a Service Business Website Actually Convert', excerpt: 'Speed, structure, and trust signals: the three things that separate websites that generate leads from ones that don\'t.', publishedAt: '2025-12-18', slug: { current: 'service-business-website-conversion' } },
];

// Proof bar stats — from homePage, fallback to hardcoded
const proofStats = (homePage?.proofStats?.length > 0 ? homePage.proofStats : [
  { value: '$100M+', label: 'Ad Spend Managed' },
  { value: '8x',     label: 'Avg Blended ROAS' },
  { value: '5+ Yrs', label: 'Avg Client Tenure' },
  { value: '9+',     label: 'Industries Served' },
]).map((s: any, i: number) => ({ ...s, idx: String(i + 1).padStart(2, '0') }));

// Singleton content with fallbacks
const heroHeadline = homePage?.hero?.headline ?? null;
const heroSubhead  = homePage?.hero?.subhead  ?? null;
const servicesSectionTitle = homePage?.servicesSection?.title ?? 'Services built for measurable growth';
const servicesSectionIntro = homePage?.servicesSection?.intro ?? 'Six ways we help service businesses compete and grow online. Every engagement starts with your goals, not a default package.';
const whoTitle     = homePage?.whoWeServe?.headline ?? 'Built for service businesses ready to grow.';
const whoBody      = homePage?.whoWeServe?.body ?? "You run a great operation. Your digital presence should reflect that and drive real leads. Whether you're a local landscaping company or a regional security provider, we build what your business needs to compete and win online.";
const whoCtaLabel  = homePage?.whoWeServe?.ctaLabel ?? 'See If We\'re a Fit';
const industries   = homePage?.whoWeServe?.industries?.length > 0
  ? homePage.whoWeServe.industries
  : ['Concrete & Hardscape', 'Construction', 'Excavation', 'Home & Business Security', 'HVAC', 'Landscaping', 'Plumbing', 'Roofing', 'Windows & Doors'];
const aboutTitle   = homePage?.aboutTeaser?.title ?? 'Enterprise experience.\nBoutique delivery.';
const aboutBody    = homePage?.aboutTeaser?.body ?? "Railshop is a digital growth partner co-founded by a corporate marketing leader and a product management leader in software. We spent years at the senior level inside national brands, building and scaling the kinds of digital programs most agencies only claim to understand. We started Railshop to bring that experience directly to growing service businesses, without the overhead.";
const aboutCards   = homePage?.aboutTeaser?.cards?.length > 0 ? homePage.aboutTeaser.cards : [
  { eyebrow: '01', heading: 'Senior-Only Team',              body: 'Every engagement is led by us directly. Senior work start to finish, not handed down the line.' },
  { eyebrow: '02', heading: 'The Right People, Every Time',  body: 'When a project needs a specialist, we know exactly who to call and why.' },
  { eyebrow: '03', heading: 'Built to Partner',              body: "We're built for long-term partnerships where each program builds on the last." },
];
const blogTitle    = homePage?.blogTeaser?.title ?? 'Straight talk on digital marketing.';
const blogIntro    = homePage?.blogTeaser?.intro ?? "Written by practitioners running live campaigns. What's working, what's changed, and what to ignore.";
const ctaTitle     = homePage?.ctaBanner?.title ?? 'Ready to grow your<br />service business online?';
const ctaSubtitle  = homePage?.ctaBanner?.subtitle ?? 'We take on a limited number of new clients. Book a call to see if we\'re the right fit.';

// Featured case study content
const caseQuote = featuredCase?.homepagePullQuote ?? 'From local HVAC company to regional market leader.';
const caseBody  = featuredCase?.homepageBody ?? "A family-owned HVAC business ready to scale but stuck on word-of-mouth and slow seasons. We built their full digital program and grew with them for five years. The result: 4x revenue growth and an 8x blended return on ad spend.";
const caseStats = featuredCase?.stats?.length > 0 ? featuredCase.stats : [
  { value: '8x',  label: 'Blended ROAS' },
  { value: '4x',  label: 'Revenue Growth' },
  { value: '5yr', label: 'Partnership' },
];
const caseStatColors = ['cs-green', 'cs-blue', 'cs-gold'];

const homeSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      'name': homePage?.seo?.metaTitle ?? 'Railshop | Digital Marketing for Home & Consumer Service Businesses',
      'description': homePage?.seo?.metaDescription ?? 'Railshop is a boutique digital growth agency for home and consumer service businesses.',
      'url': 'https://railshop.co',
      'isPartOf': { '@id': 'https://railshop.co/#website' },
    },
    {
      '@type': 'ItemList',
      'name': 'Railshop Services',
      'itemListElement': displayServices.map((svc: any, i: number) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'name': svc.title,
        'url': `https://railshop.co/services/${svc.slug.current}`,
      })),
    },
  ],
};

const serviceIcons = [
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10l4.553-2.07A1 1 0 0121 8.868v6.264a1 1 0 01-1.447.899L15 14"/><rect x="2" y="7" width="13" height="10" rx="2"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 017 7c0 2.62-1.4 4.91-3.5 6.19V17a1 1 0 01-1 1h-5a1 1 0 01-1-1v-1.81A7.003 7.003 0 015 9a7 7 0 017-7z"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.5 3.5L17 8l-3.5 1.5L12 13l-1.5-3.5L7 8l3.5-1.5L12 3z"/><path d="M5 17l1 2.5L8.5 20 7 17.5 5 17z"/></svg>`,
];
---

<BaseLayout
  title={homePage?.seo?.metaTitle ?? 'Railshop | Digital Marketing for Home & Consumer Service Businesses'}
  description={homePage?.seo?.metaDescription ?? 'Railshop is a boutique digital growth agency for home and consumer service businesses. We build websites, run paid ads, and drive SEO. Delivered by senior practitioners with national brand experience.'}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(homeSchema)} />
  </Fragment>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <!-- Orbital arc SVG -->
      <svg class="hero-arc-svg" viewBox="0 0 1400 700" fill="none" preserveAspectRatio="xMidYMid slice">
        <path class="arc-main" d="M -80 660 Q 380 -60 860 280 Q 1060 430 1480 180" stroke-width="1" fill="none"/>
        <path class="arc-secondary" d="M -80 700 Q 360 -20 830 310 Q 1030 470 1480 220" stroke-width="1" fill="none"/>
        <!-- Starfield -->
        <circle class="arc-star" cx="920"  cy="48"  r="1.5"/>
        <circle class="arc-star" cx="1180" cy="82"  r="1"/>
        <circle class="arc-star" cx="1310" cy="155" r="1.5"/>
        <circle class="arc-star" cx="1060" cy="210" r="1"/>
        <circle class="arc-star" cx="830"  cy="130" r="2"/>
        <circle class="arc-star" cx="760"  cy="310" r="1"/>
        <circle class="arc-star" cx="990"  cy="390" r="1.5"/>
        <circle class="arc-star" cx="1240" cy="340" r="1"/>
        <circle class="arc-star" cx="1380" cy="420" r="2"/>
        <circle class="arc-star" cx="1120" cy="490" r="1"/>
        <circle class="arc-star" cx="870"  cy="560" r="1.5"/>
        <circle class="arc-star" cx="1290" cy="580" r="1"/>
        <circle class="arc-star" cx="680"  cy="80"  r="1"/>
        <circle class="arc-star" cx="580"  cy="190" r="1.5"/>
        <circle class="arc-star" cx="1050" cy="640" r="1"/>
        <circle class="arc-star" cx="1400" cy="260" r="1.5"/>
        <circle class="arc-star" cx="940"  cy="290" r="1"/>
        <circle class="arc-star" cx="1160" cy="430" r="2"/>
        <circle class="arc-star" cx="780"  cy="430" r="1"/>
        <circle class="arc-star" cx="1320" cy="68"  r="1"/>
        <!-- 4-pointed star accents -->
        <path class="arc-star-4pt" d="M 1100 120 L 1101.8 124.2 L 1106 126 L 1101.8 127.8 L 1100 132 L 1098.2 127.8 L 1094 126 L 1098.2 124.2 Z"/>
        <path class="arc-star-4pt" d="M 1350 310 L 1351.5 313.5 L 1355 315 L 1351.5 316.5 L 1350 320 L 1348.5 316.5 L 1345 315 L 1348.5 313.5 Z"/>
        <path class="arc-star-4pt" d="M 860 480 L 861.8 484.2 L 866 486 L 861.8 487.8 L 860 492 L 858.2 487.8 L 854 486 L 858.2 484.2 Z"/>
      </svg>
      <!-- Faint glow behind headline -->
      <div class="hero-glow"></div>
    </div>

    <!-- Corner annotations -->
    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: ONLINE</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">40.29°N · 79.55°W</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">MISSION_ID: RS-0001</span>
    </div>

    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow">
          <SectionTag label="Launch with Confidence" />
        </div>

        {heroHeadline ? (
          <h1 class="hero-headline" set:html={heroHeadline.replace(/\n/g, '<br />')} />
        ) : (
          <h1 class="hero-headline">
            We help service<br />
            businesses grow<br />
            <em class="hero-accent">revenue online.</em>
          </h1>
        )}

        <p class="hero-sub">
          {heroSubhead ?? 'Railshop is a boutique growth partner for home and consumer service brands. We build what your business needs and nothing it doesn\'t.'}
        </p>

        <div class="hero-ctas">
          <Button href="/contact#book-a-call" variant="primary">
            Book a Call
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </Button>
          <Button href="/work" variant="secondary">
            See Our Work
          </Button>
        </div>
      </div>

      <!-- Space illustration -->
      <div class="hero-illustration" aria-hidden="true">
        <svg class="hero-svg" viewBox="0 0 320 420" fill="none" xmlns="http://www.w3.org/2000/svg">

          <!-- Orbit arc (dashed) -->
          <path class="hi-orbit" d="M 15 408 A 225 255 -18 0 1 305 28"/>

          <!-- Planet with ring -->
          <circle class="hi-stroke" cx="46" cy="152" r="15"/>
          <ellipse class="hi-stroke hi-thin" cx="46" cy="152" rx="27" ry="7" transform="rotate(-15 46 152)"/>

          <!-- ── ROCKET ── -->
          <!-- Body + fins -->
          <path class="hi-stroke hi-thick" d="M 215 18 C 230 26 235 48 235 74 L 235 150 L 252 174 L 235 163 L 195 163 L 178 174 L 195 150 L 195 74 C 195 48 200 26 215 18 Z"/>
          <!-- Nozzle bell -->
          <path class="hi-stroke" d="M 198 163 L 195 178 L 235 178 L 232 163"/>
          <!-- Porthole window -->
          <circle class="hi-stroke" cx="215" cy="95" r="17"/>
          <path class="hi-stroke hi-thin" d="M 205 86 A 10 10 0 0 1 215 82"/>
          <!-- Body band -->
          <line class="hi-stroke hi-thin" x1="195" y1="122" x2="235" y2="122"/>
          <!-- Rivets -->
          <circle class="hi-dot" cx="208" cy="70" r="2.5"/>
          <circle class="hi-dot" cx="222" cy="70" r="2.5"/>
          <!-- Exhaust flames -->
          <path class="hi-fill-soft" d="M 205 178 Q 197 196 202 214 Q 210 196 209 183 Z"/>
          <path class="hi-fill-soft" d="M 215 178 Q 210 200 215 220 Q 220 200 215 178 Z"/>
          <path class="hi-fill-soft" d="M 225 178 Q 233 196 228 214 Q 220 196 221 183 Z"/>
          <!-- Annotation ticks + label -->
          <line class="hi-stroke hi-thin" x1="235" y1="90" x2="246" y2="90"/>
          <line class="hi-stroke hi-thin" x1="235" y1="122" x2="246" y2="122"/>
          <line class="hi-stroke hi-thin" x1="242" y1="90" x2="242" y2="122"/>
          <text class="hi-text" x="248" y="110">RS-01</text>
          <!-- Corner bracket (upper right) -->
          <path class="hi-stroke hi-thin" d="M 280 30 L 280 48 M 280 30 L 263 30"/>

          <!-- ── TETHER ── -->
          <path class="hi-tether" d="M 143 332 C 185 305 213 262 229 163"/>

          <!-- ── ASTRONAUT ── -->
          <!-- Helmet -->
          <circle class="hi-stroke hi-thick" cx="88" cy="265" r="36"/>
          <!-- Visor -->
          <path class="hi-visor" d="M 70 258 Q 70 290 88 290 Q 106 290 106 258 Q 100 244 88 244 Q 76 244 70 258 Z"/>
          <line class="hi-stroke hi-thin" x1="76" y1="252" x2="83" y2="244"/>
          <line class="hi-stroke hi-thin" x1="84" y1="256" x2="94" y2="247"/>
          <!-- Neck ring -->
          <path class="hi-stroke hi-thin" d="M 74 299 L 74 302 L 102 302 L 102 299"/>
          <!-- Body/torso -->
          <path class="hi-stroke hi-thick" d="M 71 302 Q 65 302 65 308 L 65 350 Q 65 355 71 355 L 105 355 Q 111 355 111 350 L 111 308 Q 111 302 105 302 Z"/>
          <!-- Belt -->
          <line class="hi-stroke hi-thin" x1="65" y1="337" x2="111" y2="337"/>
          <!-- Chest badge -->
          <circle class="hi-stroke" cx="88" cy="318" r="9"/>
          <circle class="hi-dot" cx="88" cy="318" r="3"/>
          <!-- PLSS backpack -->
          <path class="hi-stroke" d="M 111 305 L 126 305 L 126 342 L 111 342"/>
          <line class="hi-stroke hi-thin" x1="118" y1="312" x2="118" y2="335"/>
          <line class="hi-stroke hi-thin" x1="113" y1="320" x2="124" y2="320"/>
          <!-- Left arm + glove -->
          <path class="hi-stroke hi-thick" d="M 65 316 Q 50 320 40 334 Q 36 341 43 346"/>
          <ellipse class="hi-stroke" cx="42" cy="347" rx="6.5" ry="5"/>
          <!-- Right arm + glove -->
          <path class="hi-stroke hi-thick" d="M 111 316 Q 127 320 138 332"/>
          <ellipse class="hi-stroke" cx="140" cy="334" rx="6.5" ry="5"/>
          <!-- Left leg + boot -->
          <path class="hi-stroke hi-thick" d="M 77 355 Q 74 369 71 386"/>
          <ellipse class="hi-stroke" cx="71" cy="388" rx="10" ry="5.5"/>
          <!-- Right leg + boot -->
          <path class="hi-stroke hi-thick" d="M 99 355 Q 102 369 105 386"/>
          <ellipse class="hi-stroke" cx="105" cy="388" rx="10" ry="5.5"/>
          <!-- Corner bracket (lower left) -->
          <path class="hi-stroke hi-thin" d="M 15 352 L 15 368 M 15 368 L 31 368"/>

          <!-- Stars (4-pointed) -->
          <path class="hi-fill" d="M 50 57 L 52.7 63.3 L 59 66 L 52.7 68.7 L 50 75 L 47.3 68.7 L 41 66 L 47.3 63.3 Z"/>
          <path class="hi-fill" d="M 269 99 L 271.1 103.9 L 276 106 L 271.1 108.1 L 269 113 L 266.9 108.1 L 262 106 L 266.9 103.9 Z"/>
          <path class="hi-fill" d="M 289 263 L 291.4 268.6 L 297 271 L 291.4 273.4 L 289 279 L 286.6 273.4 L 281 271 L 286.6 268.6 Z"/>
          <path class="hi-fill" d="M 22 187 L 23.6 191 L 28 192.6 L 23.6 194.2 L 22 198.2 L 20.4 194.2 L 16 192.6 L 20.4 191 Z"/>
          <!-- Dot stars -->
          <circle class="hi-dot" cx="150" cy="42" r="2.5"/>
          <circle class="hi-dot" cx="38" cy="236" r="2"/>
          <circle class="hi-dot" cx="297" cy="175" r="1.8"/>
          <circle class="hi-dot" cx="170" cy="390" r="1.5"/>
          <circle class="hi-dot" cx="258" cy="340" r="2"/>
          <circle class="hi-dot" cx="130" cy="160" r="1.5"/>

        </svg>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. SOCIAL PROOF BAR — flight manifest style
       ============================================================ -->
  <section class="proof-bar">
    <div class="proof-rule" aria-hidden="true">
      <div class="proof-rule-line"></div>
      <span class="proof-rule-label">PERFORMANCE LOG</span>
      <div class="proof-rule-line"></div>
    </div>
    <div class="container">
    <div class="proof-grid">
      {proofStats.map((stat: any) => (
        <div class="proof-stat">
          <span class="proof-idx">{stat.idx}</span>
          <div class="proof-data">
            <span class="proof-value">{stat.value}</span>
            <span class="proof-label">{stat.label}</span>
          </div>
        </div>
      ))}
    </div>
    </div>
  </section>

  <!-- ============================================================
       3. SERVICES
       ============================================================ -->
  <section class="services-section">
    <div class="container">
      <div class="services-header">
        <div class="services-header-left">
          <h2 class="services-title" set:html={servicesSectionTitle.replace(/\n/g, '<br />')} />
        </div>
        <p class="services-intro">{servicesSectionIntro}</p>
      </div>
      <div class="services-grid">
        {displayServices.map((svc, i) => (
          <a href={`/services/${svc.slug.current}`} class="svc-row">
            <div class="svc-row-left">
              <span class="svc-idx">0{i + 1}</span>
              <span class="svc-icon" set:html={serviceIcons[i]} />
              <h3 class="svc-title">{svc.title}</h3>
            </div>
            <p class="svc-desc">{svc.description}</p>
            <span class="svc-arrow">
              Learn more
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. WHO WE SERVE
       ============================================================ -->
  <section class="who-section">
    <div class="container who-inner">
      <div class="who-copy">
        <h2 class="who-title">{whoTitle}</h2>
        <p class="who-desc">{whoBody}</p>
        <Button href="/contact" variant="primary">{whoCtaLabel}</Button>
      </div>
      <div class="who-tags-col">
        <p class="who-tags-heading">// Industries Served</p>
        <div class="who-tag-grid">
          {industries.map((ind, i) => (
            <div class="who-tag-item">
              <span class="who-tag-idx">{String(i + 1).padStart(2, '0')}</span>
              <span class="who-tag-name">{ind}</span>
            </div>
          ))}
          <div class="who-tag-item who-tag-item--more">
            <span class="who-tag-idx">+</span>
            <span class="who-tag-name">More</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. FEATURED CASE STUDY
       ============================================================ -->
  <section class="case-section">
    <div class="container">
      <div class="case-wrap">
        <div class="case-content">
          <div class="case-meta">
            <SectionTag label="Client Results" />
          </div>
          <h2 class="case-quote">{caseQuote}</h2>
          <p class="case-body">{caseBody}</p>
          <div class="case-stats">
            {caseStats.map((stat: any, i: number) => (
              <div class="case-stat">
                <span class={`cs-val ${caseStatColors[i] ?? 'cs-green'}`}>{stat.value}</span>
                <span class="cs-lbl">{stat.label}</span>
              </div>
            ))}
          </div>
          <Button href={featuredCase ? `/work/${featuredCase.slug.current}` : '/work/hvac-market-leader'} variant="secondary">
            Read the Case Study
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </Button>
        </div>
        <div class="case-visual">
          <img
            src="/images/F&I Scaled 1500.jpg"
            alt="HVAC business owner reviewing campaign results"
            class="case-img"
            loading="lazy"
            decoding="async"
          />
          <div class="case-img-tag" aria-hidden="true">REF · HVAC-001</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. ABOUT TEASER
       ============================================================ -->
  <section class="about-section">
    <div class="container about-inner">
      <div class="about-copy">
        <h2 class="about-title" set:html={aboutTitle.replace(/\n/g, '<br />')} />
        <p class="about-body">{aboutBody}</p>
        <Button href="/about" variant="primary">
          Our Story
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </Button>
      </div>
      <div class="about-specs">
        <div class="about-specs-header" aria-hidden="true">// MISSION PARAMETERS</div>
        {aboutCards.map((card: any, i: number) => (
          <div class="about-spec-row">
            <span class="about-spec-key">PARAM.{String(i + 1).padStart(2, '0')}</span>
            <div class="about-spec-body">
              <p class="about-spec-label">{card.heading ?? card.label}</p>
              <p class="about-spec-desc">{card.body ?? card.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. BLOG TEASER
       ============================================================ -->
  <section class="blog-section">
    <div class="container">
      <div class="blog-header">
        <div>
          <SectionTag label="From the Blog" />
          <h2 class="blog-title" set:html={blogTitle.replace(/\n/g, '<br />')} />
        </div>
        <p class="blog-intro">{blogIntro}</p>
      </div>

      <div class="blog-list">
        {displayPosts.map((post, i) => (
          <a href={`/blog/${post.slug.current}`} class="blog-row">
            <span class="blog-row-num">0{i + 1}</span>
            <div class="blog-row-date">
              {new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </div>
            <div class="blog-row-body">
              <h3 class="blog-row-title">{post.title}</h3>
              <p class="blog-row-excerpt">{post.excerpt}</p>
            </div>
            <span class="blog-row-arrow">
              Read
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="blog-all">
        <Button href="/blog" variant="secondary">All Posts</Button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. CTA BANNER
       ============================================================ -->
  <CtaBanner
    title={ctaTitle}
    subtitle={ctaSubtitle}
    secondaryText="Send a Message"
    secondaryHref="/contact#message-accordion"
  />

</BaseLayout>

