  ══════════════════════════════════════ */
  .arc-main      { stroke: rgba(56,182,255,0.10); }
  .arc-secondary { stroke: rgba(56,182,255,0.05); }
  .arc-crosshair { stroke: rgba(56,182,255,0.35); }
  .arc-star      { fill: rgba(56,182,255,0.18); }
  .arc-star-4pt  { fill: rgba(56,182,255,0.14); stroke: none; }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr 260px;
      gap: 24px;
    }

    .proof-grid {
      grid-template-columns: repeat(2, 1fr);
    }

