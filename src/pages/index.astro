  }

  /* ══════════════════════════════════════
     7. BLOG — horizontal editorial rows
  ══════════════════════════════════════ */
  .blog-section { padding: 96px 0; }

  .blog-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: end;
    margin-bottom: 48px;
  }

