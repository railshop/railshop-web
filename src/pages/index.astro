---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTag from '../components/ui/SectionTag.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';
import {
  getServices,
  getFeaturedCaseStudy,
  getPosts,
} from '../lib/sanity';

// Fetch data at build time
let services: any[] = [];
let featuredCase: any = null;
let posts: any[] = [];

try {
  [services, featuredCase, posts] = await Promise.all([
    getServices(),
    getFeaturedCaseStudy(),
    getPosts(3),
  ]);
} catch (_) {
  // Sanity not connected yet — use placeholder data
}

// Placeholder services if Sanity is empty
const displayServices = services.length > 0 ? services : [
  { _id: '1', title: 'Web Design & Development', description: 'Fast, conversion-focused websites built for service businesses.', slug: { current: 'web-design' } },
  { _id: '2', title: 'Paid Ads', description: 'Google, Meta, and beyond — campaigns built to drive leads, not just clicks.', slug: { current: 'paid-ads' } },
  { _id: '3', title: 'SEO', description: 'Sustainable organic growth through technical SEO and content that ranks.', slug: { current: 'seo' } },
  { _id: '4', title: 'Content Creation', description: 'Video and photo content that builds authority and keeps your brand visible between campaigns.', slug: { current: 'content-creation' } },
  { _id: '5', title: 'Strategy Consulting', description: 'Not sure where to start? We\'ll assess what your business needs and build a plan.', slug: { current: 'strategy' } },
  { _id: '6', title: 'AI Integration', description: 'Practical AI implementation that saves time, reduces cost, and gives your business a real edge.', slug: { current: 'ai-integration' } },
];

// Placeholder posts if Sanity is empty
const displayPosts = posts.length > 0 ? posts : [
  { _id: '1', title: 'Why Most Service Businesses Fail Online (And What Actually Works)', excerpt: 'The common mistakes we see across every industry — and the framework we use to fix them.', publishedAt: '2026-02-12', slug: { current: 'why-service-businesses-fail-online' } },
  { _id: '2', title: 'Local SEO in 2026: What\'s Changed and What Still Works', excerpt: 'The tactics that have faded and the fundamentals that keep driving rankings for service businesses.', publishedAt: '2026-01-14', slug: { current: 'local-seo-2026' } },
  { _id: '3', title: 'What Makes a Service Business Website Actually Convert', excerpt: 'Speed, structure, and trust signals — the three things that separate websites that generate leads from ones that don\'t.', publishedAt: '2025-12-18', slug: { current: 'service-business-website-conversion' } },
];

const industries = ['Concrete & Hardscape', 'Construction', 'Excavation', 'Home & Business Security', 'HVAC', 'Landscaping', 'Plumbing', 'Roofing', 'Windows & Doors'];

const serviceIcons = [
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10l4.553-2.07A1 1 0 0121 8.868v6.264a1 1 0 01-1.447.899L15 14"/><rect x="2" y="7" width="13" height="10" rx="2"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 017 7c0 2.62-1.4 4.91-3.5 6.19V17a1 1 0 01-1 1h-5a1 1 0 01-1-1v-1.81A7.003 7.003 0 015 9a7 7 0 017-7z"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.5 3.5L17 8l-3.5 1.5L12 13l-1.5-3.5L7 8l3.5-1.5L12 3z"/><path d="M5 17l1 2.5L8.5 20 7 17.5 5 17z"/></svg>`,
];
---

<BaseLayout
  title="Railshop | Digital Marketing for Home & Consumer Service Businesses"
  description="Railshop is a boutique digital growth agency for home and consumer service businesses. We build websites, run paid ads, and drive SEO — delivered by senior leaders who've done it at scale."
>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <!-- Orbital arc SVG -->
      <svg class="hero-arc-svg" viewBox="0 0 1400 700" fill="none" preserveAspectRatio="xMidYMid slice">
        <path class="arc-main" d="M -80 660 Q 380 -60 860 280 Q 1060 430 1480 180" stroke-width="1" fill="none"/>
        <path class="arc-secondary" d="M -80 700 Q 360 -20 830 310 Q 1030 470 1480 220" stroke-width="1" fill="none"/>
        <!-- Crosshair at arc apex -->
        <circle class="arc-crosshair" cx="860" cy="280" r="5" fill="none" stroke-width="1"/>
        <line class="arc-crosshair" x1="844" y1="280" x2="834" y2="280" stroke-width="1"/>
        <line class="arc-crosshair" x1="876" y1="280" x2="886" y2="280" stroke-width="1"/>
        <line class="arc-crosshair" x1="860" y1="264" x2="860" y2="254" stroke-width="1"/>
        <line class="arc-crosshair" x1="860" y1="296" x2="860" y2="306" stroke-width="1"/>
        <!-- Vertical grid ticks -->
        <line class="arc-grid" x1="280" y1="0" x2="280" y2="700" stroke-width="1"/>
        <line class="arc-grid" x1="700" y1="0" x2="700" y2="700" stroke-width="1"/>
        <line class="arc-grid" x1="1050" y1="0" x2="1050" y2="700" stroke-width="1"/>
        <line class="arc-grid" x1="0" y1="220" x2="1400" y2="220" stroke-width="1"/>
        <line class="arc-grid" x1="0" y1="480" x2="1400" y2="480" stroke-width="1"/>
      </svg>
      <!-- Faint glow behind headline -->
      <div class="hero-glow"></div>
    </div>

    <!-- Corner annotations -->
    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: ONLINE</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">40.29°N · 79.55°W</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">MISSION_ID: RS-0001</span>
    </div>

    <div class="container hero-inner">
      <div class="hero-eyebrow">
        <SectionTag label="Digital Growth Partner" />
      </div>

      <h1 class="hero-headline">
        We help service<br />
        businesses grow<br />
        <em class="hero-accent">revenue online.</em>
      </h1>

      <p class="hero-sub">
        Railshop is a boutique growth partner for home and consumer service brands.
        We build what your business needs — and nothing it doesn't.
      </p>

      <p class="hero-tagline" aria-label="Launch with Confidence">
        // Launch with Confidence
      </p>

      <div class="hero-ctas">
        <Button href="/contact#hubspot-meetings" variant="primary">
          Book a Call
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </Button>
        <Button href="/work" variant="secondary">
          See Our Work
        </Button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. SOCIAL PROOF BAR — flight manifest style
       ============================================================ -->
  <section class="proof-bar">
    <div class="proof-rule" aria-hidden="true">
      <div class="proof-rule-line"></div>
      <span class="proof-rule-label">PERFORMANCE LOG</span>
      <div class="proof-rule-line"></div>
    </div>
    <div class="container">
    <div class="proof-grid">
      {[
        { value: '$100M+', label: 'Ad Spend Managed', idx: '01' },
        { value: '8x',     label: 'Avg Blended ROAS', idx: '02' },
        { value: '5+ Yrs', label: 'Avg Client Tenure', idx: '03' },
        { value: '9+',     label: 'Industries Served', idx: '04' },
      ].map((stat) => (
        <div class="proof-stat">
          <span class="proof-idx">{stat.idx}</span>
          <div class="proof-data">
            <span class="proof-value">{stat.value}</span>
            <span class="proof-label">{stat.label}</span>
          </div>
        </div>
      ))}
    </div>
    </div>
  </section>

  <!-- ============================================================
       3. SERVICES
       ============================================================ -->
  <section class="services-section">
    <div class="container">
      <div class="services-header">
        <div class="services-header-left">
          <SectionTag label="What We Do" />
          <h2 class="services-title">Services built for<br />measurable growth</h2>
        </div>
        <p class="services-intro">
          Six ways we help service businesses compete and grow online. Every engagement starts with your goals — not a default package.
        </p>
      </div>
      <div class="services-grid">
        {displayServices.map((svc, i) => (
          <a href={`/services/${svc.slug.current}`} class="svc-row">
            <div class="svc-row-left">
              <span class="svc-idx">0{i + 1}</span>
              <span class="svc-icon" set:html={serviceIcons[i]} />
              <h3 class="svc-title">{svc.title}</h3>
            </div>
            <p class="svc-desc">{svc.description}</p>
            <span class="svc-arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. WHO WE SERVE
       ============================================================ -->
  <section class="who-section">
    <div class="container who-inner">
      <div class="who-copy">
        <SectionTag label="Who We Serve" />
        <h2 class="who-title">Built for service businesses ready to grow.</h2>
        <p class="who-desc">
          You run a great operation. Your digital presence should reflect that — and drive real leads.
          Whether you're a local landscaping company or a regional security provider, we build what
          your business needs to compete and win online.
        </p>
        <Button href="/contact" variant="primary">See If We're a Fit</Button>
      </div>
      <div class="who-tags-col">
        <p class="who-tags-heading">// Industries Served</p>
        <div class="who-tag-list">
          {industries.map((ind, i) => (
            <span class="who-tag">
              <span class="who-tag-idx">{String(i + 1).padStart(2, '0')}</span>
              {ind}
            </span>
          ))}
          <span class="who-tag who-tag--more">+ More</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. FEATURED CASE STUDY
       ============================================================ -->
  <section class="case-section">
    <div class="container">
      <div class="case-wrap">
        <div class="case-content">
          <div class="case-meta">
            <SectionTag label="Client Results" />
          </div>
          <h2 class="case-quote">
            From local HVAC company to regional market leader.
          </h2>
          <p class="case-body">
            A family-owned HVAC business ready to scale but stuck on word-of-mouth and slow seasons.
            We built their digital foundation — web, paid search, SEO, and content — and grew with
            them for five years. The result: 4x revenue growth and an 8x blended return on ad spend.
          </p>
          <div class="case-stats">
            <div class="case-stat">
              <span class="cs-val cs-green">8x</span>
              <span class="cs-lbl">Blended ROAS</span>
            </div>
            <div class="case-stat">
              <span class="cs-val cs-blue">4x</span>
              <span class="cs-lbl">Revenue Growth</span>
            </div>
            <div class="case-stat">
              <span class="cs-val cs-gold">5yr</span>
              <span class="cs-lbl">Partnership</span>
            </div>
          </div>
          <a href={featuredCase ? `/work/${featuredCase.slug.current}` : '/work/hvac-market-leader'} class="case-cta">
            Read the Case Study
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="case-visual">
          <img
            src="/images/F&I Scaled 1500.jpg"
            alt="HVAC business owner reviewing campaign results"
            class="case-img"
            loading="lazy"
            decoding="async"
          />
          <div class="case-img-tag" aria-hidden="true">REF · HVAC-001</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. ABOUT TEASER
       ============================================================ -->
  <section class="about-section">
    <div class="container about-inner">
      <div class="about-copy">
        <SectionTag label="About Railshop" />
        <h2 class="about-title">Enterprise experience.<br />Boutique delivery.</h2>
        <p class="about-body">
          Railshop is a digital growth agency co-founded by a corporate marketing leader and a product management leader in software. We spent years at the senior level inside national brands — building and scaling the kinds of digital programs most agencies only claim to understand. We started Railshop to bring that experience directly to growing service businesses, without the overhead.
        </p>
        <a href="/about" class="text-cta">
          Our Story
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="about-cards">
        {[
          {
            icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>`,
            label: 'Senior-Only Team',
            desc: 'Every engagement handled by experienced practitioners — no juniors, no handoffs.',
          },
          {
            icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
            label: 'The Right People, Every Time',
            desc: 'Senior leadership plus a curated network of specialists. No bloated teams — just the right expertise.',
          },
          {
            icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
            label: 'Built to Partner',
            desc: 'We work as an extension of your team — transparent, responsive, and invested in your growth.',
          },
        ].map((card, i) => (
          <div class="about-card">
            <div class="about-card-num">0{i + 1}</div>
            <div class="about-card-icon" set:html={card.icon} />
            <div>
              <p class="about-card-label">{card.label}</p>
              <p class="about-card-desc">{card.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. BLOG TEASER
       ============================================================ -->
  <section class="blog-section">
    <div class="container">
      <div class="blog-header">
        <div>
          <SectionTag label="From the Blog" />
          <h2 class="blog-title">Straight talk on<br />digital marketing.</h2>
        </div>
        <p class="blog-intro">No fluff, no vanity metrics — just honest perspective on what's working for service businesses online.</p>
      </div>

      <div class="blog-list">
        {displayPosts.map((post, i) => (
          <a href={`/blog/${post.slug.current}`} class="blog-row">
            <span class="blog-row-num">0{i + 1}</span>
            <div class="blog-row-date">
              {new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </div>
            <div class="blog-row-body">
              <h3 class="blog-row-title">{post.title}</h3>
              <p class="blog-row-excerpt">{post.excerpt}</p>
            </div>
            <span class="blog-row-arrow">
              Read
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="blog-all">
        <Button href="/blog" variant="secondary">All Posts</Button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. CTA BANNER
       ============================================================ -->
  <CtaBanner
    title="Ready to grow your<br />service business online?"
    subtitle="We take on a limited number of new clients. Book a call to see if we're the right fit."
    secondaryText="Send a Message"
    secondaryHref="/contact#message-accordion"
  />

</BaseLayout>

<style>
  /* ══════════════════════════════════════
     1. HERO
  ══════════════════════════════════════ */
  .hero {
    position: relative;
    padding: 140px 0 120px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-arc-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-glow {
    position: absolute;
    top: 0;
    left: -10%;
    width: 55%;
    height: 70%;
    background: radial-gradient(ellipse at 30% 40%, rgba(56, 182, 255, 0.05) 0%, transparent 65%);
  }

  /* Corner annotations */
  .hero-annotation {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-annotation--tr { top: 24px; right: 32px; }
  .hero-annotation--bl { bottom: 24px; left: 32px; }

  .anno-code { color: var(--blue); opacity: 0.8; }
  .anno-sep  { opacity: 0.3; }

  /* Hero content */
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 820px;
  }

  .hero-eyebrow { margin-bottom: 32px; }

  .hero-headline {
    font-size: clamp(44px, 5.5vw, 68px);
    font-weight: 800;
    line-height: 1.05;
    color: var(--text-2);
    letter-spacing: -0.04em;
    margin-bottom: 28px;
  }

  .hero-accent {
    font-style: normal;
    font-weight: 800;
    color: var(--blue);
    display: block;
  }

  .hero-sub {
    font-size: 18px;
    color: var(--text-3);
    max-width: 500px;
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .hero-tagline {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.75;
    margin-bottom: 40px;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ══════════════════════════════════════
     2. PROOF BAR
  ══════════════════════════════════════ */
  .proof-bar {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .proof-rule {
    display: flex;
    align-items: center;
    gap: 0;
    height: 32px;
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    overflow: hidden;
  }

  .proof-rule-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .proof-rule-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.35;
    padding: 0 16px;
    white-space: nowrap;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .proof-stat {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 32px 28px;
    border-right: 1px solid var(--border);
    transition: background 0.2s ease;
  }

  .proof-stat:last-child { border-right: none; }

  .proof-stat:hover { background: var(--surface); }

  .proof-idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--text-3);
    opacity: 0.3;
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: 4px;
  }

  .proof-data {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .proof-value {
    font-size: 34px;
    font-weight: 800;
    color: var(--blue);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .proof-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ══════════════════════════════════════
     3. SERVICES — horizontal manifest rows
  ══════════════════════════════════════ */
  .services-section {
    padding: 96px 0;
  }

  .services-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: end;
    margin-bottom: 52px;
  }

  .services-title {
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-top: 18px;
  }

  .services-intro {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.75;
    align-self: end;
    max-width: 440px;
  }

  /* List-style rows instead of a card grid */
  .services-grid {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .svc-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    align-items: center;
    gap: 32px;
    padding: 28px 32px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.2s ease;
    position: relative;
  }

  .svc-row:last-child { border-bottom: none; }

