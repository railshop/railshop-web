---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTag from '../components/ui/SectionTag.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';
import {
  getSiteSettings,
  getHomePage,
  getServices,
  getCaseStudies,
  getPosts,
} from '../lib/sanity';

// Fetch data at build time
let settings: any = null;
let homePage: any = null;
let services: any[] = [];
let caseStudies: any[] = [];
let posts: any[] = [];

try {
  [settings, homePage, services, caseStudies, posts] = await Promise.all([
    getSiteSettings(),
    getHomePage(),
    getServices(),
    getCaseStudies(),
    getPosts(3),
  ]);
} catch (_) {
  // Sanity not connected yet — use placeholder data
}

// Placeholder services if Sanity is empty
const displayServices = services.length > 0 ? services : [
  { _id: '1', title: 'Web Design & Development', description: 'High-converting websites built for service businesses.', slug: { current: 'web-design' } },
  { _id: '2', title: 'Paid Ads', description: 'Google, LSA, and Meta campaigns driven by cost-per-lead.', slug: { current: 'paid-ads' } },
  { _id: '3', title: 'SEO', description: 'Local and technical SEO that compounds over time.', slug: { current: 'seo' } },
  { _id: '4', title: 'Content Creation', description: 'Video and photo that builds authority and brand visibility.', slug: { current: 'content-creation' } },
  { _id: '5', title: 'Strategy Consulting', description: 'We audit your digital presence and build a prioritized plan.', slug: { current: 'strategy' } },
  { _id: '6', title: 'AI Integration', description: 'AI tools that cut costs, save time, and give you a real edge.', slug: { current: 'ai-integration' } },
];

// Placeholder posts if Sanity is empty
const displayPosts = posts.length > 0 ? posts : [
  { _id: '1', title: 'Why Most Service Businesses Fail Online (And What Actually Works)', excerpt: 'The common mistakes we see across every industry, and the framework we use to fix them.', publishedAt: '2026-02-12', slug: { current: 'why-service-businesses-fail-online' } },
  { _id: '2', title: 'Local SEO in 2026: What\'s Changed and What Still Works', excerpt: 'The tactics that have faded and the fundamentals that keep driving rankings for service businesses.', publishedAt: '2026-01-14', slug: { current: 'local-seo-2026' } },
  { _id: '3', title: 'What Makes a Service Business Website Actually Convert', excerpt: 'Speed, structure, and trust signals: the three things that separate websites that generate leads from ones that don\'t.', publishedAt: '2025-12-18', slug: { current: 'service-business-website-conversion' } },
];

// Proof bar stats — from homePage, fallback to hardcoded
const proofStats = (homePage?.proofStats?.length > 0 ? homePage.proofStats : [
  { value: '$100M+', label: 'Ad Spend Managed' },
  { value: '8x',     label: 'Avg Blended ROAS' },
  { value: '5+ Yrs', label: 'Avg Client Tenure' },
  { value: '9+',     label: 'Industries Served' },
]).map((s: any, i: number) => ({ ...s, idx: String(i + 1).padStart(2, '0') }));

// Singleton content with fallbacks
const heroHeadline = homePage?.hero?.headline ?? null;
const heroSubhead  = homePage?.hero?.subhead  ?? null;
const servicesSectionTitle    = homePage?.servicesSection?.title    ?? 'Built to perform.';
const servicesSectionSubtitle = homePage?.servicesSection?.subtitle ?? 'Six services, all tied to one thing: growing your revenue.';
const whoTitle     = homePage?.whoWeServe?.headline ?? 'Industries we serve.';
const whoBody      = homePage?.whoWeServe?.body ?? "You run a great operation. Your digital presence should reflect that and drive real leads. Whether you're a local landscaping company or a regional security provider, we build what your business needs to compete and win online.";
const whoCtaLabel  = homePage?.whoWeServe?.ctaLabel ?? 'See If We\'re a Fit';
const industries   = homePage?.whoWeServe?.industries?.length > 0
  ? homePage.whoWeServe.industries
  : ['Concrete & Hardscape', 'Construction', 'Excavation', 'Financial Services', 'Home & Business Security', 'HVAC', 'Landscaping', 'Nonprofit', 'Plumbing', 'Roofing', 'Windows & Doors'];
const aboutTitle   = homePage?.aboutTeaser?.title ?? 'Enterprise experience.\nBoutique delivery.';
const aboutBody    = homePage?.aboutTeaser?.body ?? "Co-founded by a corporate marketing leader and a software product leader, Railshop brings senior-level experience from national brands directly to growing service businesses. Every engagement is led by us. We're built for long-term partnerships where each program builds on the last.";
const blogTitle    = homePage?.blogTeaser?.title ?? 'Straight talk on digital marketing.';
const blogIntro    = homePage?.blogTeaser?.intro ?? "Written by practitioners running live campaigns. What's working, what's changed, and what to ignore.";
const ctaTitle     = homePage?.ctaBanner?.title ?? 'Ready to grow your<br />service business online?';
const ctaSubtitle  = homePage?.ctaBanner?.subtitle ?? 'We take on a limited number of new clients. Book a call to see if we\'re the right fit.';

// Case studies — take first 3, fallback to placeholder
const displayCases = (caseStudies?.length > 0 ? caseStudies.slice(0, 3) : [
  {
    _id: 'cs-1',
    title: 'From local HVAC company to regional market leader.',
    slug: { current: 'hvac-market-leader' },
    industry: 'HVAC',
    homepagePullQuote: 'From local HVAC company to regional market leader.',
    homepageBody: "A family-owned HVAC business stuck on word-of-mouth and slow seasons. We built their full digital program over five years and turned it into a regional market leader.",
    stats: [{ value: '8x', label: 'Blended ROAS' }, { value: '4x', label: 'Revenue Growth' }, { value: '5yr', label: 'Partnership' }],
  },
  {
    _id: 'cs-2',
    title: 'From zero digital presence to fully booked seasons.',
    slug: { current: 'landscaping-digital-presence' },
    industry: 'Landscaping',
    homepagePullQuote: 'From zero digital presence to fully booked seasons.',
    homepageBody: "A regional landscaping company with no website and no online visibility. We built their site, launched local SEO, and ran targeted paid search to fill their calendar.",
    stats: [{ value: '3.2x', label: 'ROAS' }, { value: 'Page 1', label: 'Rankings in 90 Days' }, { value: 'Booked', label: 'First Spring Season' }],
  },
  {
    _id: 'cs-3',
    title: 'Scaling a home security brand beyond door-to-door.',
    slug: { current: 'home-security-digital-acquisition' },
    industry: 'Home Security',
    homepagePullQuote: 'Scaling a home security brand beyond door-to-door.',
    homepageBody: "A home security company over-reliant on door-to-door sales. We built a scalable inbound channel with paid search, local SEO, and a website that converts.",
    stats: [{ value: '2.8x', label: 'Lead Volume' }, { value: '-47%', label: 'CPL vs. Industry' }, { value: '2yr', label: 'Engagement' }],
  },
]);
const caseStatColors = ['cs-green', 'cs-blue', 'cs-gold'];

const homeSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      'name': homePage?.seo?.metaTitle ?? 'Railshop | Digital Marketing for Home & Consumer Service Businesses',
      'description': homePage?.seo?.metaDescription ?? 'Railshop is a boutique digital growth agency for home and consumer service businesses.',
      'url': 'https://railshop.co',
      'isPartOf': { '@id': 'https://railshop.co/#website' },
    },
    {
      '@type': 'ItemList',
      'name': 'Railshop Services',
      'itemListElement': displayServices.map((svc: any, i: number) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'name': svc.title,
        'url': `https://railshop.co/services/${svc.slug.current}`,
      })),
    },
  ],
};

const serviceIcons = [
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10l4.553-2.07A1 1 0 0121 8.868v6.264a1 1 0 01-1.447.899L15 14"/><rect x="2" y="7" width="13" height="10" rx="2"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 017 7c0 2.62-1.4 4.91-3.5 6.19V17a1 1 0 01-1 1h-5a1 1 0 01-1-1v-1.81A7.003 7.003 0 015 9a7 7 0 017-7z"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.5 3.5L17 8l-3.5 1.5L12 13l-1.5-3.5L7 8l3.5-1.5L12 3z"/><path d="M5 17l1 2.5L8.5 20 7 17.5 5 17z"/></svg>`,
];
---

<BaseLayout
  title={homePage?.seo?.metaTitle ?? 'Railshop | Digital Marketing for Home & Consumer Service Businesses'}
  description={homePage?.seo?.metaDescription ?? 'Railshop is a boutique digital growth agency for home and consumer service businesses. We build websites, run paid ads, and drive SEO. Delivered by senior practitioners with national brand experience.'}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(homeSchema)} />
  </Fragment>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <!-- Orbital arc SVG -->
      <svg class="hero-arc-svg" viewBox="0 0 1400 700" fill="none" preserveAspectRatio="xMidYMid slice">
        <path class="arc-main" d="M -80 660 Q 380 -60 860 280 Q 1060 430 1480 180" stroke-width="1" fill="none"/>
        <path class="arc-secondary" d="M -80 700 Q 360 -20 830 310 Q 1030 470 1480 220" stroke-width="1" fill="none"/>
        <!-- Starfield -->
        <circle class="arc-star" cx="920"  cy="48"  r="1.5"/>
        <circle class="arc-star" cx="1180" cy="82"  r="1"/>
        <circle class="arc-star" cx="1310" cy="155" r="1.5"/>
        <circle class="arc-star" cx="1060" cy="210" r="1"/>
        <circle class="arc-star" cx="830"  cy="130" r="2"/>
        <circle class="arc-star" cx="760"  cy="310" r="1"/>
        <circle class="arc-star" cx="990"  cy="390" r="1.5"/>
        <circle class="arc-star" cx="1240" cy="340" r="1"/>
        <circle class="arc-star" cx="1380" cy="420" r="2"/>
        <circle class="arc-star" cx="1120" cy="490" r="1"/>
        <circle class="arc-star" cx="870"  cy="560" r="1.5"/>
        <circle class="arc-star" cx="1290" cy="580" r="1"/>
        <circle class="arc-star" cx="680"  cy="80"  r="1"/>
        <circle class="arc-star" cx="580"  cy="190" r="1.5"/>
        <circle class="arc-star" cx="1050" cy="640" r="1"/>
        <circle class="arc-star" cx="1400" cy="260" r="1.5"/>
        <circle class="arc-star" cx="940"  cy="290" r="1"/>
        <circle class="arc-star" cx="1160" cy="430" r="2"/>
        <circle class="arc-star" cx="780"  cy="430" r="1"/>
        <circle class="arc-star" cx="1320" cy="68"  r="1"/>
        <!-- 4-pointed star accents -->
        <path class="arc-star-4pt" d="M 1100 120 L 1101.8 124.2 L 1106 126 L 1101.8 127.8 L 1100 132 L 1098.2 127.8 L 1094 126 L 1098.2 124.2 Z"/>
        <path class="arc-star-4pt" d="M 1350 310 L 1351.5 313.5 L 1355 315 L 1351.5 316.5 L 1350 320 L 1348.5 316.5 L 1345 315 L 1348.5 313.5 Z"/>
        <path class="arc-star-4pt" d="M 860 480 L 861.8 484.2 L 866 486 L 861.8 487.8 L 860 492 L 858.2 487.8 L 854 486 L 858.2 484.2 Z"/>
      </svg>
      <!-- Faint glow behind headline -->
      <div class="hero-glow"></div>
    </div>

    <!-- Corner annotations -->
    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: ONLINE</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">40.30°N · 79.54°W</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">MISSION_ID: RS-0001</span>
    </div>

    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow">
          <SectionTag label="Launch with Confidence" />
        </div>

        {heroHeadline ? (
          <h1 class="hero-headline" set:html={heroHeadline.replace(/\n/g, '<br />')} />
        ) : (
          <h1 class="hero-headline">
            We help service<br />
            businesses grow<br />
            <em class="hero-accent">revenue online.</em>
          </h1>
        )}

        <p class="hero-sub">
          {heroSubhead ?? 'Railshop is a boutique growth partner for home and consumer service brands. We build what your business needs and nothing it doesn\'t.'}
        </p>

        <div class="hero-ctas">
          <Button href="/contact#book-a-call" variant="primary">
            Book a Call
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </Button>
          <Button href="/work" variant="secondary">
            See Our Work
          </Button>
        </div>
      </div>

      <!-- Space illustration -->
      <div class="hero-illustration" aria-hidden="true">
        <svg class="hero-svg" viewBox="0 0 320 420" fill="none" xmlns="http://www.w3.org/2000/svg">

          <!-- Orbit arc (dashed) -->
          <path class="hi-orbit" d="M 15 408 A 225 255 -18 0 1 305 28"/>

          <!-- Planet with ring -->
          <circle class="hi-stroke" cx="46" cy="152" r="15"/>
          <ellipse class="hi-stroke hi-thin" cx="46" cy="152" rx="27" ry="7" transform="rotate(-15 46 152)"/>

          <!-- ── ROCKET ── -->
          <!-- Body + fins -->
          <path class="hi-stroke hi-thick" d="M 215 18 C 230 26 235 48 235 74 L 235 150 L 252 174 L 235 163 L 195 163 L 178 174 L 195 150 L 195 74 C 195 48 200 26 215 18 Z"/>
          <!-- Nozzle bell -->
          <path class="hi-stroke" d="M 198 163 L 195 178 L 235 178 L 232 163"/>
          <!-- Porthole window -->
          <circle class="hi-stroke" cx="215" cy="95" r="17"/>
          <path class="hi-stroke hi-thin" d="M 205 86 A 10 10 0 0 1 215 82"/>
          <!-- Body band -->
          <line class="hi-stroke hi-thin" x1="195" y1="122" x2="235" y2="122"/>
          <!-- Rivets -->
          <circle class="hi-dot" cx="208" cy="70" r="2.5"/>
          <circle class="hi-dot" cx="222" cy="70" r="2.5"/>
          <!-- Exhaust flames -->
          <path class="hi-fill-soft" d="M 205 178 Q 197 196 202 214 Q 210 196 209 183 Z"/>
          <path class="hi-fill-soft" d="M 215 178 Q 210 200 215 220 Q 220 200 215 178 Z"/>
          <path class="hi-fill-soft" d="M 225 178 Q 233 196 228 214 Q 220 196 221 183 Z"/>
          <!-- Annotation ticks + label -->
          <line class="hi-stroke hi-thin" x1="235" y1="90" x2="246" y2="90"/>
          <line class="hi-stroke hi-thin" x1="235" y1="122" x2="246" y2="122"/>
          <line class="hi-stroke hi-thin" x1="242" y1="90" x2="242" y2="122"/>
          <text class="hi-text" x="248" y="110">RS-01</text>
          <!-- Corner bracket (upper right) -->
          <path class="hi-stroke hi-thin" d="M 280 30 L 280 48 M 280 30 L 263 30"/>

          <!-- ── TETHER ── -->
          <path class="hi-tether" d="M 143 332 C 185 305 213 262 229 163"/>

          <!-- ── ASTRONAUT ── -->
          <!-- Helmet -->
          <circle class="hi-stroke hi-thick" cx="88" cy="265" r="36"/>
          <!-- Visor -->
          <path class="hi-visor" d="M 70 258 Q 70 290 88 290 Q 106 290 106 258 Q 100 244 88 244 Q 76 244 70 258 Z"/>
          <line class="hi-stroke hi-thin" x1="76" y1="252" x2="83" y2="244"/>
          <line class="hi-stroke hi-thin" x1="84" y1="256" x2="94" y2="247"/>
          <!-- Neck ring -->
          <path class="hi-stroke hi-thin" d="M 74 299 L 74 302 L 102 302 L 102 299"/>
          <!-- Body/torso -->
          <path class="hi-stroke hi-thick" d="M 71 302 Q 65 302 65 308 L 65 350 Q 65 355 71 355 L 105 355 Q 111 355 111 350 L 111 308 Q 111 302 105 302 Z"/>
          <!-- Belt -->
          <line class="hi-stroke hi-thin" x1="65" y1="337" x2="111" y2="337"/>
          <!-- Chest badge -->
          <circle class="hi-stroke" cx="88" cy="318" r="9"/>
          <circle class="hi-dot" cx="88" cy="318" r="3"/>
          <!-- PLSS backpack -->
          <path class="hi-stroke" d="M 111 305 L 126 305 L 126 342 L 111 342"/>
          <line class="hi-stroke hi-thin" x1="118" y1="312" x2="118" y2="335"/>
          <line class="hi-stroke hi-thin" x1="113" y1="320" x2="124" y2="320"/>
          <!-- Left arm + glove -->
          <path class="hi-stroke hi-thick" d="M 65 316 Q 50 320 40 334 Q 36 341 43 346"/>
          <ellipse class="hi-stroke" cx="42" cy="347" rx="6.5" ry="5"/>
          <!-- Right arm + glove -->
          <path class="hi-stroke hi-thick" d="M 111 316 Q 127 320 138 332"/>
          <ellipse class="hi-stroke" cx="140" cy="334" rx="6.5" ry="5"/>
          <!-- Left leg + boot -->
          <path class="hi-stroke hi-thick" d="M 77 355 Q 74 369 71 386"/>
          <ellipse class="hi-stroke" cx="71" cy="388" rx="10" ry="5.5"/>
          <!-- Right leg + boot -->
          <path class="hi-stroke hi-thick" d="M 99 355 Q 102 369 105 386"/>
          <ellipse class="hi-stroke" cx="105" cy="388" rx="10" ry="5.5"/>
          <!-- Corner bracket (lower left) -->
          <path class="hi-stroke hi-thin" d="M 15 352 L 15 368 M 15 368 L 31 368"/>

          <!-- Stars (4-pointed) -->
          <path class="hi-fill" d="M 50 57 L 52.7 63.3 L 59 66 L 52.7 68.7 L 50 75 L 47.3 68.7 L 41 66 L 47.3 63.3 Z"/>
          <path class="hi-fill" d="M 269 99 L 271.1 103.9 L 276 106 L 271.1 108.1 L 269 113 L 266.9 108.1 L 262 106 L 266.9 103.9 Z"/>
          <path class="hi-fill" d="M 289 263 L 291.4 268.6 L 297 271 L 291.4 273.4 L 289 279 L 286.6 273.4 L 281 271 L 286.6 268.6 Z"/>
          <path class="hi-fill" d="M 22 187 L 23.6 191 L 28 192.6 L 23.6 194.2 L 22 198.2 L 20.4 194.2 L 16 192.6 L 20.4 191 Z"/>
          <!-- Dot stars -->
          <circle class="hi-dot" cx="150" cy="42" r="2.5"/>
          <circle class="hi-dot" cx="38" cy="236" r="2"/>
          <circle class="hi-dot" cx="297" cy="175" r="1.8"/>
          <circle class="hi-dot" cx="170" cy="390" r="1.5"/>
          <circle class="hi-dot" cx="258" cy="340" r="2"/>
          <circle class="hi-dot" cx="130" cy="160" r="1.5"/>

        </svg>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. SOCIAL PROOF BAR — flight manifest style
       ============================================================ -->
  <section class="proof-bar">
    <div class="proof-rule" aria-hidden="true">
      <div class="proof-rule-line"></div>
      <span class="proof-rule-label">PERFORMANCE LOG</span>
      <div class="proof-rule-line"></div>
    </div>
    <div class="container">
    <div class="proof-grid">
      {proofStats.map((stat: any) => (
        <div class="proof-stat">
          <span class="proof-idx">{stat.idx}</span>
          <div class="proof-data">
            <span class="proof-value">{stat.value}</span>
            <span class="proof-label">{stat.label}</span>
          </div>
        </div>
      ))}
    </div>
    </div>
  </section>

  <!-- ============================================================
       3. SERVICES
       ============================================================ -->
  <section class="services-section">
    <div class="container">
      <div class="services-header" data-animate>
        <h2 class="services-title" set:html={servicesSectionTitle.replace(/\n/g, '<br />')} />
        <p class="services-subtitle">{servicesSectionSubtitle}</p>
      </div>
      <div class="services-grid">
        {displayServices.map((svc, i) => (
          <a href={`/services/${svc.slug.current}`} class="svc-card" data-animate data-delay={i * 60}>
            <div class="svc-card-top">
              <span class="svc-icon" set:html={serviceIcons[i]} />
              <span class="svc-idx">0{i + 1}</span>
            </div>
            <h3 class="svc-title">{svc.title}</h3>
            <p class="svc-desc">{svc.description}</p>
            <span class="svc-arrow">
              View Service
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. CASE STUDIES (3-up alternating)
       ============================================================ -->
  <section class="case-section">
    <div class="container">
      <div class="case-section-header" data-animate>
        <h2 class="case-section-title">Proven results.</h2>
        <p class="case-section-sub">Real growth for service businesses, from first click to lasting results.</p>
      </div>

      <div class="case-stack">
        {displayCases.map((cs: any, i: number) => {
          const stats = cs.stats?.length > 0 ? cs.stats.slice(0, 3) : [];
          const reversed = i === 1;
          return (
            <div class={`case-wrap ${reversed ? 'case-wrap--reversed' : ''}`} data-animate data-delay={i * 80}>
              <div class="case-content">
                <span class="case-industry">{cs.industry}</span>
                <h3 class="case-quote">{cs.homepagePullQuote ?? cs.title}</h3>
                <p class="case-body">{cs.homepageBody ?? cs.excerpt}</p>
                <div class="case-stats">
                  {stats.map((stat: any, si: number) => (
                    <div class="case-stat">
                      <span class={`cs-val ${caseStatColors[si] ?? 'cs-green'}`}>{stat.value}</span>
                      <span class="cs-lbl">{stat.label}</span>
                    </div>
                  ))}
                </div>
                <Button href={`/work/${cs.slug?.current ?? '#'}`} variant="secondary">
                  Read the Case Study
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </Button>
              </div>
              <div class="case-visual">
                <div class="img-placeholder">
                  <svg class="img-placeholder-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <div class="case-all">
        <Button href="/work" variant="secondary">View All Case Studies</Button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. WHO WE SERVE — title + ticker bar
       ============================================================ -->
  <section class="who-section">
    <div class="container">
      <h2 class="who-title" data-animate>{whoTitle}</h2>
    </div>
    <div class="who-ticker-bar">
      <div class="who-ticker-mask">
        <div class="who-ticker-track">
          {[...Array(2)].map(() => (
            <div class="who-ticker-set" aria-hidden="true">
              {industries.map((ind) => (
                <Fragment>
                  <span class="who-ticker-item">{ind}</span>
                  <span class="who-ticker-dot" aria-hidden="true">·</span>
                </Fragment>
              ))}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. ABOUT TEASER
       ============================================================ -->
  <section class="about-section">
    <div class="container">
      <div class="about-wrap" data-animate>
        <div class="about-copy">
          <h2 class="about-title" set:html={aboutTitle.replace(/\n/g, '<br />')} />
          <p class="about-body">{aboutBody}</p>
          <Button href="/about" variant="primary">
            Our Story
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </Button>
        </div>
        <div class="about-visual">
          <div class="img-placeholder">
            <svg class="img-placeholder-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. BLOG TEASER
       ============================================================ -->
  <section class="blog-section">
    <div class="container">
      <div class="blog-header" data-animate>
        <div>
          <SectionTag label="From the Blog" />
          <h2 class="blog-title" set:html={blogTitle.replace(/\n/g, '<br />')} />
        </div>
      </div>

      <div class="blog-list">
        {displayPosts.map((post, i) => (
          <a href={`/blog/${post.slug.current}`} class="blog-row" data-animate data-delay={i * 60}>
            <span class="blog-row-num">0{i + 1}</span>
            <div class="blog-row-date">
              {new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </div>
            <div class="blog-row-body">
              <h3 class="blog-row-title">{post.title}</h3>
              <p class="blog-row-excerpt">{post.excerpt}</p>
            </div>
            <span class="blog-row-arrow">
              Read
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="blog-all">
        <Button href="/blog" variant="secondary">All Posts</Button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. CTA BANNER
       ============================================================ -->
  <CtaBanner
    title={ctaTitle}
    subtitle={ctaSubtitle}
    secondaryText="Send a Message"
    secondaryHref="/contact#message-accordion"
  />

</BaseLayout>

<style>
  /* ══════════════════════════════════════
     1. HERO
  ══════════════════════════════════════ */
  .hero {
    position: relative;
    padding: 140px 0 120px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-arc-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-glow {
    position: absolute;
    top: 0;
    left: -10%;
    width: 55%;
    height: 70%;
    background: radial-gradient(ellipse at 30% 40%, rgba(56, 182, 255, 0.05) 0%, transparent 65%);
  }

  /* Corner annotations */
  .hero-annotation {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-annotation--tr { top: 24px; right: 32px; }
  .hero-annotation--bl { bottom: 24px; left: 32px; }

  .anno-code { color: var(--blue); opacity: 0.8; }
  .anno-sep  { opacity: 0.3; }

  /* Hero content */
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 330px;
    align-items: center;
    gap: 40px;
    max-width: 980px;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }

  .hero-illustration {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    color: var(--blue);
    opacity: 0.82;
    animation: float 7s ease-in-out infinite;
  }

  .hero-svg {
    width: 100%;
    max-width: 330px;
    height: auto;
  }

  /* SVG illustration element classes */
  .hi-stroke {
    stroke: currentColor;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.6;
  }

  .hi-thick { stroke-width: 2.2; }
  .hi-thin  { stroke-width: 1; stroke-opacity: 0.55; }

  .hi-orbit {
    stroke: currentColor;
    fill: none;
    stroke-linecap: round;
    stroke-dasharray: 7 5;
    stroke-width: 1;
    stroke-opacity: 0.42;
  }

  .hi-tether {
    stroke: currentColor;
    fill: none;
    stroke-linecap: round;
    stroke-width: 1;
    stroke-opacity: 0.5;
  }

  .hi-fill {
    fill: currentColor;
    stroke: none;
    opacity: 0.85;
  }

  .hi-dot {
    fill: currentColor;
    opacity: 0.45;
  }

  .hi-visor {
    fill: currentColor;
    fill-opacity: 0.12;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .hi-fill-soft {
    fill: currentColor;
    fill-opacity: 0.12;
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .hi-text {
    fill: currentColor;
    fill-opacity: 0.65;
    font-family: 'JetBrains Mono', monospace;
    font-size: 6.5px;
    letter-spacing: 0.12em;
  }

  .hero-eyebrow { margin-bottom: 32px; }

  .hero-headline {
    font-size: clamp(44px, 5.5vw, 68px);
    font-weight: 800;
    line-height: 1.05;
    color: var(--text-2);
    letter-spacing: -0.04em;
    margin-bottom: 28px;
    max-width: 560px;
  }

  .hero-accent {
    font-style: normal;
    font-weight: 800;
    color: var(--text-2);
    display: block;
  }

  .hero-sub {
    font-size: 18px;
    color: var(--text-3);
    max-width: 500px;
    line-height: 1.75;
    margin-bottom: 32px;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ══════════════════════════════════════
     2. PROOF BAR
  ══════════════════════════════════════ */
  .proof-bar {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .proof-rule {
    display: flex;
    align-items: center;
    gap: 0;
    height: 32px;
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    overflow: hidden;
  }

  .proof-rule-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .proof-rule-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.35;
    padding: 0 16px;
    white-space: nowrap;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .proof-stat {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 32px 28px;
    border-right: 1px solid var(--border);
    transition: background 0.2s ease;
  }

  .proof-stat:last-child { border-right: none; }

  .proof-stat:hover { background: var(--surface); }

  .proof-idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--text-3);
    opacity: 0.3;
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: 4px;
  }

  .proof-data {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .proof-value {
    font-size: 34px;
    font-weight: 800;
    color: var(--blue);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .proof-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ══════════════════════════════════════
     3. SERVICES — horizontal manifest rows
  ══════════════════════════════════════ */
  .services-section {
    padding: 96px 0;
  }

  .services-header {
    text-align: center;
    margin-bottom: 52px;
  }

  .services-title {
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .services-subtitle {
    margin-top: 12px;
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.6;
  }

  /* List-style rows instead of a card grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .svc-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px;
    border: 1px solid var(--border);
    border-radius: 2px;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .svc-card:hover {
    border-color: var(--border-2);
    transform: translateY(-1px);
  }

  .svc-card:hover .svc-arrow { color: var(--blue); transform: translateX(3px); }
  .svc-card:hover .svc-title { color: var(--blue); }

  .svc-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 4px;
  }

  .svc-idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--text-3);
    opacity: 0.35;
  }

  .svc-icon {
    color: var(--blue);
    opacity: 0.85;
  }

  .svc-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-2);
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .svc-desc {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.7;
    flex: 1;
  }

  .svc-arrow {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-3);
    white-space: nowrap;
    margin-top: 4px;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  /* ══════════════════════════════════════
     5. WHO WE SERVE — title + ticker bar
  ══════════════════════════════════════ */
  .who-section {
    padding: 96px 0 0;
  }

  .who-title {
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 800;
    color: var(--text-2);
    line-height: 1.15;
    letter-spacing: -0.03em;
    text-align: center;
    margin-bottom: 48px;
  }

  .who-ticker-bar {
    background: var(--blue);
    padding: 18px 0;
    overflow: hidden;
  }

  .who-ticker-mask {
    max-width: calc(1200px - var(--space-6) * 2);
    margin: 0 auto;
    overflow: hidden;
  }

  .who-ticker-track {
    display: flex;
    width: max-content;
    animation: ticker 30s linear infinite;
  }

  .who-ticker-bar:hover .who-ticker-track {
    animation-play-state: paused;
  }

  .who-ticker-set {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .who-ticker-item {
    font-size: 13px;
    font-weight: 600;
    color: #111315;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .who-ticker-dot {
    margin: 0 20px;
    font-size: 18px;
    font-weight: 800;
    color: #111315;
    opacity: 0.4;
  }

  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ══════════════════════════════════════
     4. CASE STUDIES — 3-up alternating
  ══════════════════════════════════════ */
  .case-section { padding: 96px 0; }

  .case-section-header {
    margin-bottom: 52px;
  }

  .case-section-title {
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .case-section-sub {
    margin-top: 12px;
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.6;
  }

  .case-stack {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .case-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
    min-height: 420px;
  }

  .case-wrap--reversed .case-content { order: 2; }
  .case-wrap--reversed .case-visual  { order: 1; border-left: none; border-right: 1px solid var(--border); }

  .case-content {
    padding: 48px 44px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    justify-content: center;
  }

  .case-industry {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.7;
  }

  .case-quote {
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 800;
    color: var(--text-2);
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .case-body {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.75;
  }

  .case-stats {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }

  .case-stat {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .cs-val {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .cs-green { color: var(--green); }
  .cs-blue  { color: var(--blue);  }
  .cs-gold  { color: var(--gold);  }

  .cs-lbl {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
    opacity: 0.55;
  }

  .case-visual {
    position: relative;
    border-left: 1px solid var(--border);
    overflow: hidden;
    background: var(--surface);
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
  }

  .img-placeholder-icon {
    color: var(--text-3);
    opacity: 0.15;
  }

  .case-all {
    margin-top: 32px;
    display: flex;
    justify-content: center;
  }

  /* ══════════════════════════════════════
     6. ABOUT
  ══════════════════════════════════════ */
  .about-section {
    padding: 96px 0;
  }

  .about-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    min-height: 420px;
  }

  .about-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    justify-content: center;
  }

  .about-title {
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 800;
    color: var(--text-2);
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .about-body {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.75;
  }

  .about-visual {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    min-height: 380px;
  }

  .about-visual .img-placeholder {
    position: absolute;
    inset: 0;
  }


  /* ══════════════════════════════════════
     7. BLOG — horizontal editorial rows
  ══════════════════════════════════════ */
  .blog-section { padding: 96px 0; }

  .blog-header {
    margin-bottom: 48px;
  }

  .blog-title {
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 800;
    color: var(--text-2);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-top: 18px;
  }

  /* Horizontal rows — editorial list style */
  .blog-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .blog-row {
    display: grid;
    grid-template-columns: 20px 120px 1fr auto;
    align-items: center;
    gap: 28px;
    padding: 28px 32px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .blog-row:last-child { border-bottom: none; }

  .blog-row:hover { background: var(--surface-2); }

  .blog-row:hover .blog-row-arrow {
    color: var(--blue);
    gap: 8px;
  }

  .blog-row-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    color: var(--text-3);
    opacity: 0.3;
  }

  .blog-row-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--blue);
    opacity: 0.7;
    flex-shrink: 0;
  }

  .blog-row-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .blog-row-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-2);
    line-height: 1.35;
  }

  .blog-row-excerpt {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.55;
  }

  .blog-row-arrow {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 700;
    color: var(--text-3);
    opacity: 0.4;
    white-space: nowrap;
    transition: color 0.2s, gap 0.2s, opacity 0.2s;
  }

  .blog-row:hover .blog-row-arrow { opacity: 1; }

  .blog-all {
    margin-top: 32px;
    display: flex;
    justify-content: center;
  }

  /* ══════════════════════════════════════
     HERO SVG ARC STROKES (dark mode default)
  ══════════════════════════════════════ */
  .arc-main      { stroke: rgba(56,182,255,0.10); }
  .arc-secondary { stroke: rgba(56,182,255,0.05); }
  .arc-crosshair { stroke: rgba(56,182,255,0.35); }
  .arc-star      { fill: rgba(56,182,255,0.18); }
  .arc-star-4pt  { fill: rgba(56,182,255,0.14); stroke: none; }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr 260px;
      gap: 24px;
    }

    .proof-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .proof-stat:nth-child(2) { border-right: none; }
    .proof-stat:nth-child(3) {
      border-top: 1px solid var(--border);
    }
    .proof-stat:nth-child(4) {
      border-top: 1px solid var(--border);
    }

    .blog-row {
      grid-template-columns: 20px 100px 1fr auto;
      gap: 20px;
    }
  }

  @media (max-width: 768px) {
    .hero { padding: 96px 0 80px; }
    .hero-annotation { display: none; }
    .hero-inner { grid-template-columns: 1fr; }
    .hero-illustration { display: none; }

    .about-wrap {
      grid-template-columns: 1fr;
    }

    .about-visual {
      min-height: 240px;
      order: -1;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .proof-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .proof-stat { padding: 20px 16px; }
    .proof-idx  { display: none; }

    .case-wrap {
      grid-template-columns: 1fr;
    }

    .case-wrap--reversed .case-content { order: unset; }
    .case-wrap--reversed .case-visual  { order: -1; border-right: none; }

    .case-visual {
      border-left: none;
      border-bottom: 1px solid var(--border);
      min-height: 200px;
      order: -1;
    }

    .case-content { padding: 32px 24px; }

    .blog-row {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 20px 20px;
    }

    .blog-row-num,
    .blog-row-arrow { display: none; }

    .blog-row-date { margin-bottom: 4px; }

  }

  /* ══════════════════════════════════════
     SCROLL ANIMATIONS
  ══════════════════════════════════════ */
  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-animate] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const els = document.querySelectorAll('[data-animate]');

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const delay = el.dataset.delay ? parseInt(el.dataset.delay, 10) : 0;
          setTimeout(() => el.classList.add('is-visible'), delay);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.15 });

    els.forEach((el) => observer.observe(el));
  } else {
    els.forEach((el) => el.classList.add('is-visible'));
  }
</script>
