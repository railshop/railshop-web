---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTag from '../components/ui/SectionTag.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import {
  getServices,
  getFeaturedCaseStudy,
  getPosts,
} from '../lib/sanity';

// Fetch data at build time
let services: any[] = [];
let featuredCase: any = null;
let posts: any[] = [];

try {
  [services, featuredCase, posts] = await Promise.all([
    getServices(),
    getFeaturedCaseStudy(),
    getPosts(3),
  ]);
} catch (_) {
  // Sanity not connected yet — use placeholder data
}

// Placeholder services if Sanity is empty
const displayServices = services.length > 0 ? services : [
  { _id: '1', title: 'Web Design & Development', description: 'Fast, conversion-focused websites built for service businesses.', slug: { current: 'web-design' } },
  { _id: '2', title: 'Paid Ads', description: 'Google, Meta, and beyond — campaigns built to drive leads, not just clicks.', slug: { current: 'paid-ads' } },
  { _id: '3', title: 'SEO', description: 'Sustainable organic growth through technical SEO and content that ranks.', slug: { current: 'seo' } },
  { _id: '4', title: 'Content Creation', description: 'Video and photo content that builds authority and keeps your brand visible between campaigns.', slug: { current: 'content-creation' } },
  { _id: '5', title: 'Strategy & Consulting', description: 'Not sure where to start? We\'ll assess what your business needs and build a plan.', slug: { current: 'strategy' } },
  { _id: '6', title: 'AI Integration & Consulting', description: 'Practical AI implementation that saves time, reduces cost, and gives your business a real edge.', slug: { current: 'ai-integration' } },
];

// Placeholder posts if Sanity is empty
const displayPosts = posts.length > 0 ? posts : [
  { _id: '1', title: 'Why Most Service Businesses Fail Online (And What Actually Works)', excerpt: 'The common mistakes we see across every industry — and the framework we use to fix them.', publishedAt: '2026-02-12', slug: { current: 'why-service-businesses-fail-online' } },
  { _id: '2', title: 'Local SEO in 2026: What\'s Changed and What Still Works', excerpt: 'The tactics that have faded and the fundamentals that keep driving rankings for service businesses.', publishedAt: '2026-01-14', slug: { current: 'local-seo-2026' } },
  { _id: '3', title: 'What Makes a Service Business Website Actually Convert', excerpt: 'Speed, structure, and trust signals — the three things that separate websites that generate leads from ones that don\'t.', publishedAt: '2025-12-18', slug: { current: 'service-business-website-conversion' } },
];

const industries = ['Concrete & Hardscape', 'Construction', 'Excavation', 'Home & Business Security', 'HVAC', 'Landscaping', 'Plumbing', 'Roofing', 'Windows & Doors'];
---

<BaseLayout
  title="Railshop | Digital Marketing for Home & Consumer Service Businesses"
  description="Railshop is a boutique digital growth agency for home and consumer service businesses. We build websites, run paid ads, and drive SEO — delivered by senior leaders who've done it at scale."
>
  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-grid"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-eyebrow">
        <SectionTag label="Digital Growth Partner" />
      </div>
      <h1 class="hero-headline">
        We help service businesses<br />
        <span class="hero-headline-accent">grow revenue online.</span>
      </h1>
      <p class="hero-subhead">
        Railshop is a boutique growth partner for home and consumer service brands.
        We build what your business needs — and nothing it doesn't.
      </p>
      <div class="hero-ctas">
        <Button href="/contact#hubspot-meetings" variant="primary">
          Book a Call
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </Button>
        <Button href="/work" variant="secondary">
          See Our Work
        </Button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. SOCIAL PROOF BAR
       ============================================================ -->
  <section class="proof-bar">
    <div class="container proof-inner">
      {[
        { value: '$100M+', label: 'Ad Spend Managed' },
        { value: '8x', label: 'Avg Blended ROAS' },
        { value: '5+ Yrs', label: 'Avg Client Tenure' },
        { value: '9+', label: 'Industries Served' },
      ].map((stat) => (
        <div class="proof-stat">
          <span class="proof-value">{stat.value}</span>
          <span class="proof-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================================
       3. SERVICES OVERVIEW
       ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <SectionTag label="What We Do" />
        <h2 class="section-title">Services built for<br />measurable growth</h2>
        <p class="section-desc">
          Six ways we help service businesses compete and grow online. Every engagement starts with your goals — not a default package.
        </p>
      </div>
      <div class="services-grid stagger">
        {displayServices.map((svc) => (
          <Card href={`/services/${svc.slug.current}`} animate class="service-card">
            <span class="service-icon">
              {svc._id === '1' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
              )}
              {svc._id === '2' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>
                </svg>
              )}
              {svc._id === '3' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
              )}
              {svc._id === '4' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 10l4.553-2.07A1 1 0 0121 8.868v6.264a1 1 0 01-1.447.899L15 14"/><rect x="2" y="7" width="13" height="10" rx="2"/>
                </svg>
              )}
              {svc._id === '5' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 017 7c0 2.62-1.4 4.91-3.5 6.19V17a1 1 0 01-1 1h-5a1 1 0 01-1-1v-1.81A7.003 7.003 0 015 9a7 7 0 017-7z"/>
                </svg>
              )}
              {svc._id === '6' && (
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3l1.5 3.5L17 8l-3.5 1.5L12 13l-1.5-3.5L7 8l3.5-1.5L12 3z"/><path d="M5 17l1 2.5L8.5 20 7 17.5 5 17z"/><path d="M17 14l1 2.5L20.5 17 19 14.5 17 14z"/>
                </svg>
              )}
            </span>
            <h3 class="service-title">{svc.title}</h3>
            <p class="service-desc">{svc.description}</p>
            <span class="service-arrow">
              Learn more
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. WHO WE SERVE
       ============================================================ -->
  <section class="who-we-serve">
    <div class="container">
      <div class="who-inner">
        <div class="who-copy">
          <SectionTag label="Who We Serve" />
          <h2 class="who-title">Built for service businesses ready to grow.</h2>
          <p class="who-desc">
            You run a great operation. Your digital presence should reflect that — and drive real leads.
            Whether you're a local landscaping company or a regional security provider, we build what
            your business needs to compete and win online.
          </p>
          <Button href="/contact" variant="primary">See If We're a Fit</Button>
        </div>
        <div class="who-tags">
          <p class="who-tags-label">Industries we serve</p>
          <div class="who-tag-list">
            {industries.map((ind) => (
              <span class="who-tag">{ind}</span>
            ))}
            <span class="who-tag who-tag--more">+ More</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. FEATURED CASE STUDY
       ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="case-study-card">
        <div class="case-study-content">
          <SectionTag label="Client Results" />
          <p class="case-study-eyebrow">HVAC · 5-Year Partnership</p>
          <h2 class="case-study-title">
            From local HVAC company to regional market leader.
          </h2>
          <p class="case-study-excerpt">
            A family-owned HVAC business ready to scale but stuck on word-of-mouth and slow seasons.
            We built their digital foundation — web, paid search, SEO, and content — and grew with
            them for five years. The result: 4x revenue growth and an 8x blended return on ad spend.
          </p>
          <div class="case-study-stats">
            <span class="cs-stat cs-stat--green">8x Blended ROAS</span>
            <span class="cs-stat cs-stat--blue">4x Revenue Growth</span>
            <span class="cs-stat cs-stat--gold">5-Year Partnership</span>
          </div>
          <a href={featuredCase ? `/work/${featuredCase.slug.current}` : '/work/hvac-market-leader'} class="cs-cta">
            Read the Case Study
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="case-study-visual">
          <img
            src="/images/F&I Scaled 1500.jpg"
            alt="HVAC business owner reviewing campaign results with a client"
            class="cs-image"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ============================================================
       6. ABOUT TEASER
       ============================================================ -->
  <section class="about-teaser">
    <div class="container">
      <div class="about-inner">
        <div class="about-copy">
          <SectionTag label="About Railshop" />
          <h2 class="about-title">Enterprise experience.<br />Boutique delivery.</h2>
          <p class="about-desc">
            Railshop is a digital growth agency co-founded by a corporate marketing leader and a product management leader in software. We spent years at the senior level inside national brands — building and scaling the kinds of digital programs most agencies only claim to understand. We started Railshop to bring that experience directly to growing service businesses, without the overhead.
          </p>
          <a href="/about" class="about-cta">
            Our Story
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="about-cards">
          <div class="about-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
            </svg>
            <div>
              <p class="about-card-label">Senior-Only Team</p>
              <p class="about-card-desc">Every engagement handled by experienced practitioners — no juniors, no handoffs.</p>
            </div>
          </div>
          <div class="about-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>
            </svg>
            <div>
              <p class="about-card-label">The Right People, Every Time</p>
              <p class="about-card-desc">Senior leadership plus a curated network of specialists. No bloated teams — just the right expertise for your engagement.</p>
            </div>
          </div>
          <div class="about-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
            <div>
              <p class="about-card-label">Built to Partner</p>
              <p class="about-card-desc">We work as an extension of your team — transparent, responsive, and invested in your growth.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. BLOG TEASER
       ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <SectionTag label="From the Blog" />
        <h2 class="section-title">Straight talk on<br />digital marketing.</h2>
        <p class="section-desc">No fluff, no vanity metrics — just honest perspective on what's working for service businesses online.</p>
      </div>
      <div class="blog-grid stagger">
        {displayPosts.map((post) => (
          <Card href={`/blog/${post.slug.current}`} animate class="blog-card">
            <p class="blog-date">
              {new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </p>
            <h3 class="blog-title">{post.title}</h3>
            <p class="blog-excerpt">{post.excerpt}</p>
            <span class="blog-read-more">
              Read post
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </Card>
        ))}
      </div>
      <div style="text-align: center; margin-top: 40px;">
        <Button href="/blog" variant="secondary">All Posts</Button>
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. CTA BANNER
       ============================================================ -->
  <section class="cta-banner">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container cta-inner">
      <SectionTag label="Let's Talk" />
      <h2 class="cta-title">
        Ready to grow your service<br />business online?
      </h2>
      <p class="cta-desc">
        We take on a limited number of new clients. Book a call to see if we're the right fit.
      </p>
      <div class="cta-buttons">
        <Button href="/contact#hubspot-meetings" variant="primary">
          Book a Call
        </Button>
        <Button href="/contact" variant="secondary">
          Send a Message
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    padding: 140px 0 120px;
    overflow: hidden;
    text-align: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.35;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 30%, transparent 100%);
  }

  .hero-glow {
    position: absolute;
    top: -80px;
    right: -100px;
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(56, 182, 255, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-eyebrow {
    margin-bottom: 24px;
  }

  .hero-headline {
    font-size: clamp(48px, 7vw, 80px);
    font-weight: 800;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 24px;
    letter-spacing: -0.03em;
    max-width: 900px;
  }

  .hero-headline-accent {
    color: var(--blue);
  }

  .hero-subhead {
    font-size: 18px;
    color: var(--text-3);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ---- Social Proof Bar ---- */
  .proof-bar {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .proof-inner {
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 32px 24px;
    gap: 24px;
    flex-wrap: wrap;
  }

  .proof-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .proof-value {
    font-size: 28px;
    font-weight: 800;
    color: var(--blue);
    letter-spacing: -0.02em;
  }

  .proof-label {
    font-size: 12px;
    color: var(--text-3);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ---- Section Helpers ---- */
  .section-header {
    margin-bottom: 48px;
  }

  .section-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: var(--text-2);
    margin-top: 16px;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .section-desc {
    font-size: 16px;
    color: var(--text-3);
    max-width: 500px;
    line-height: 1.7;
    margin-top: 12px;
  }

  /* ---- Services Grid ---- */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  :global(.service-card) {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 32px;
    text-decoration: none;
  }

  .service-icon {
    display: flex;
    align-items: center;
  }

  .service-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-2);
  }

  .service-desc {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.6;
    flex: 1;
  }

  .service-arrow {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--blue);
    font-weight: 600;
    margin-top: 4px;
  }

  /* ---- Who We Serve ---- */
  .who-we-serve {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 100px 0;
  }

  .who-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .who-copy {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: flex-start;
  }

  .who-title {
    font-size: clamp(26px, 3.5vw, 36px);
    font-weight: 800;
    color: var(--text-2);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .who-desc {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.75;
    max-width: 480px;
  }

  .who-tags-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
    margin-bottom: 20px;
  }

  .who-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .who-tag {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-3);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 6px 14px;
    background: var(--surface-2);
  }

  .who-tag--more {
    color: var(--text-3);
    border-style: dashed;
    opacity: 0.6;
    font-style: italic;
  }

  /* ---- Featured Case Study ---- */
  .case-study-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    min-height: 400px;
  }

  .case-study-content {
    padding: 48px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .case-study-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
  }

  .case-study-title {
    font-size: clamp(22px, 2.5vw, 28px);
    font-weight: 800;
    color: var(--text-2);
    line-height: 1.25;
    letter-spacing: -0.02em;
  }

  .case-study-excerpt {
    font-size: 15px;
    color: var(--text-3);
    line-height: 1.75;
  }

  .case-study-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cs-stat {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 20px;
  }

  .cs-stat--green {
    background: rgba(52, 211, 153, 0.1);
    color: var(--green);
  }

  .cs-stat--blue {
    background: rgba(56, 182, 255, 0.08);
    color: var(--blue);
  }

  .cs-stat--gold {
    background: rgba(251, 191, 36, 0.08);
    color: var(--gold);
  }

  .cs-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--blue);
    border: 1px solid var(--blue-border);
    border-radius: 8px;
    padding: 9px 16px;
    transition: background 0.15s, border-color 0.15s;
  }

  .cs-cta:hover {
    background: var(--blue-glow);
    border-color: var(--blue);
  }

  .case-study-visual {
    border-left: 1px solid var(--border);
    overflow: hidden;
  }

  .cs-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ---- Section divider ---- */
  .section-divider {
    border: none;
