<style>
  /* ── Page eyebrow (SectionTag style) ────────────────────────── */
  .ds-page-eyebrow {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.65;
    margin-bottom: var(--space-3);
  }

  /* ── Component preview helpers ───────────────────────────────── */
  .ds-eyebrow-sample {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.65;
  }

  .ds-card-eyebrow {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.65;
    margin-bottom: var(--space-4);
  }

  .ds-card-title {
    font-size: var(--fs-h3);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-snug);
    line-height: var(--lh-title);
    color: var(--text-2);
    margin: 0 0 var(--space-3);
  }

  .ds-card-body {
    font-size: var(--fs-body-sm);
    color: var(--text-3);
    line-height: var(--lh-body);
    margin: 0 0 var(--space-5);
  }

  /* ── Page shell ──────────────────────────────────────────────── */
  .ds-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-10) var(--space-6) var(--space-24);
  }

  /* ── Shared token label styles ───────────────────────────────── */
  .ds-token-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    color: var(--text-3);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
  }

  .ds-token-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    color: var(--text-3);
    opacity: 0.55;
  }

  .ds-inline-code {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 2px 5px;
    color: var(--blue);
  }

  /* ── Page header ─────────────────────────────────────────────── */
  .ds-header {
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-10);
  }

  .ds-header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .ds-title {
    font-size: var(--fs-display);
    font-weight: var(--fw-black);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
    color: var(--text-2);
    margin: var(--space-3) 0 var(--space-4);
  }

  .ds-subtitle {
    font-size: var(--fs-body);
    color: var(--text-3);
    line-height: var(--lh-body);
    max-width: 560px;
    margin: 0;
  }

  .ds-theme-toggle {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
    flex-shrink: 0;
    padding-top: var(--space-3);
  }

  .ds-meta {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  /* ── Section shell ───────────────────────────────────────────── */
  .ds-section {
    padding: var(--space-10) 0;
    border-bottom: 1px solid var(--border);
  }

  .ds-section-label {
    margin-bottom: var(--space-8);
  }

  .ds-group-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    margin: 0 0 var(--space-4);
  }

  /* ── Colour ──────────────────────────────────────────────────── */
  .ds-colour-groups {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .ds-swatches {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .ds-swatch {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .ds-swatch-block {
    width: 80px;
    height: 56px;
    border-radius: var(--radius-md);
  }

  .ds-swatch-hex {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    color: var(--text-3);
    opacity: 0.5;
  }

  /* ── Typography ──────────────────────────────────────────────── */
  .ds-type-rows {
    display: flex;
    flex-direction: column;
  }

  .ds-type-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-8);
    align-items: start;
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--border);
  }

  .ds-type-row:last-child {
    border-bottom: none;
  }

  .ds-type-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-top: var(--space-2);
  }

  .ds-type-role {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    color: var(--text-3);
    opacity: 0.4;
  }

  .ds-type-sample { color: var(--text-2); font-weight: var(--fw-black); line-height: var(--lh-heading); }
  .ds-type-sample--display   { font-size: var(--fs-display);    letter-spacing: var(--ls-display); }
  .ds-type-sample--h1        { font-size: var(--fs-h1);         letter-spacing: var(--ls-heading); }
  .ds-type-sample--h1-article{ font-size: var(--fs-h1-article); letter-spacing: var(--ls-heading); }
  .ds-type-sample--h2        { font-size: var(--fs-h2);         letter-spacing: var(--ls-heading); }
  .ds-type-sample--h2-cta    { font-size: var(--fs-h2-cta);     letter-spacing: var(--ls-heading); }
  .ds-type-sample--h3        { font-size: var(--fs-h3);         letter-spacing: var(--ls-snug);    }
  .ds-type-sample--body      { font-size: var(--fs-body);       font-weight: var(--fw-regular); line-height: var(--lh-body); letter-spacing: var(--ls-normal); color: var(--text-3); }
  .ds-type-sample--body-sm   { font-size: var(--fs-body-sm);    font-weight: var(--fw-regular); line-height: var(--lh-body); letter-spacing: var(--ls-normal); color: var(--text-3); }
  .ds-type-sample--label     { font-size: var(--fs-label);  font-weight: var(--fw-bold);    text-transform: uppercase; letter-spacing: var(--ls-wider); color: var(--blue); }
  .ds-type-sample--eyebrow   { font-family: 'JetBrains Mono', monospace; font-size: var(--fs-micro); letter-spacing: var(--ls-widest); text-transform: uppercase; color: var(--blue); opacity: 0.65; font-weight: var(--fw-medium); }
  .ds-type-sample--micro     { font-family: 'JetBrains Mono', monospace; font-size: var(--fs-micro); letter-spacing: var(--ls-wide); color: var(--text-3); }

  /* ── Font weights ────────────────────────────────────────────── */
  .ds-weights {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ds-weight-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-8);
    align-items: center;
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--border);
  }

  .ds-weight-row:last-child { border-bottom: none; }

  .ds-weight-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .ds-weight-sample {
    font-size: 20px;
    color: var(--text-2);
    letter-spacing: -0.02em;
  }

  /* ── Spacing ─────────────────────────────────────────────────── */
  .ds-spacing {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .ds-space-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-6);
    align-items: center;
  }

  .ds-space-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .ds-space-bar-track {
    flex: 1;
  }

  .ds-space-bar {
    height: 12px;
    background: var(--blue);
    opacity: 0.25;
    border-radius: 2px;
    min-width: 4px;
  }

  /* ── Border radius ───────────────────────────────────────────── */
  .ds-radii {
    display: flex;
    gap: var(--space-10);
    flex-wrap: wrap;
  }

