---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTag from '../components/ui/SectionTag.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout
  title="About — Railshop"
  description="Railshop is a boutique performance marketing agency. Senior practitioners, no account managers, no black boxes."
>

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <SectionTag label="About Railshop" />
      <h1 class="page-title">
        Built different<br />
        <span class="accent">on purpose.</span>
      </h1>
    </div>
  </section>

  <!-- Our Story -->
  <section class="story-section">
    <div class="container story-grid">

      <!-- Left: copy -->
      <div class="story-left">
        <SectionTag label="Our Story" />
        <div class="story-blocks">
          <div class="story-block">
            <h2 class="story-h2">Why we started Railshop</h2>
            <p>
              We spent years inside agencies watching the same story play out. A brand
              hires a large agency. Their account gets assigned to a mid-level manager
              who runs templated strategies and calls it a win when spend scales but
              profitability doesn't. The senior people who closed the deal are never
              actually in the account.
            </p>
            <p>
              We built Railshop because we believe you deserve better than that.
              Every account at Railshop is managed by a practitioner with real
              experience — someone who has built and scaled paid media programs from
              scratch, across industries, and who can speak frankly about what's
              working and what isn't.
            </p>
          </div>
          <div class="story-block">
            <h2 class="story-h2">How we work</h2>
            <p>
              We're deliberately small. That's not a constraint — it's a feature. We
              take on a limited number of clients so that every engagement gets our
              full attention. We run retainer-based partnerships, not project-by-project
              work, because compounding results require continuity.
            </p>
            <p>
              We believe in radical transparency. You'll always know where your budget
              is going, what we're testing, and what the data is actually telling us —
              not a curated highlight reel.
            </p>
          </div>
        </div>
      </div>

      <!-- Right: office photo -->
      <div class="story-photo">
        <img src="/images/office.jpg" alt="Railshop office" class="story-photo-img" />
      </div>

    </div>
  </section>

  <!-- Team -->
  <section class="team-section">
    <div class="container">
      <div class="section-header">
        <SectionTag label="The Team" />
        <h2 class="section-headline">Senior experience. No hand-offs.</h2>
        <p class="section-subhead">Every client works directly with us — not a coordinator or a junior hire.</p>
      </div>
      <div class="team-grid">

        <div class="team-card">
          <div class="team-photo">
            <img src="/images/drew 169 cropped.jpg" alt="Andrew Opalinski" class="team-photo-img" />
          </div>
          <div class="team-info">
            <p class="team-name">Andrew Opalinski</p>
            <p class="team-title">Co-Founder, Head of Digital Strategy</p>
            <p class="team-bio">Former Head of Digital Marketing at Window Nation and Vector Security, where he built and scaled paid media, SEO, and web programs across national markets. Drew brings that enterprise playbook directly to growing service businesses.</p>
            <a href="https://linkedin.com/in/drewrailshop" class="linkedin-link" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>

        <div class="team-card">
          <div class="team-photo">
            <img src="/images/sean 169 cropped.jpg" alt="Sean Connelly" class="team-photo-img" />
          </div>
          <div class="team-info">
            <p class="team-name">Sean Connelly</p>
            <p class="team-title">Co-Founder, Head of Product & Operations</p>
            <p class="team-bio">VP of Product at Momentive Software, where he leads product development and systems thinking at scale. Sean brings that same discipline to every Railshop engagement — making sure strategy translates into execution that actually ships.</p>
            <a href="https://linkedin.com/in/seanrailshop" class="linkedin-link" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Client Logo Strip -->
  <section class="logos-section">
    <div class="container">
      <div class="logos-header">
        <SectionTag label="Clients We've Worked With" />
        <p class="logos-subhead">Names shared on request — we respect client confidentiality.</p>
      </div>
      <div class="logos-row">
        <div class="logo-tile">
          <img src="/images/logos/window nation logo.png" alt="Window Nation" class="logo-img logo-window-nation" />
        </div>
        <div class="logo-tile">
          <img src="/images/logos/vector security logo.svg" alt="Vector Security" class="logo-img logo-vector-security" />
        </div>
        <div class="logo-tile">
          <img src="/images/logos/fire and ice logo.png" alt="Fire & Ice" class="logo-img logo-fire-ice" />
        </div>
        <div class="logo-tile">
          <img src="/images/logos/country farms logo.png" alt="Country Farms" class="logo-img logo-country-farms" />
        </div>
        <div class="logo-tile">
          <img src="/images/logos/jp operations logo.svg" alt="JP Operations" class="logo-img logo-jp-operations" />
        </div>
        <div class="logo-tile">
          <img src="/images/logos/cedar crek logo.jpg" alt="Cedar Creek" class="logo-img logo-cedar-creek" />
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="values-section">
    <div class="container">
      <div class="section-header">
        <SectionTag label="How We Operate" />
        <h2 class="section-headline">A few things we believe in.</h2>
      </div>
      <div class="values-grid">

        <div class="value-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 11l3 3L22 4"/>
            <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
          </svg>
          <h3 class="value-title">Honest Reporting</h3>
          <p class="value-desc">We tell you what the data says, even when it's bad news.</p>
        </div>

        <div class="value-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="20" x2="18" y2="10"/>
            <line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
          <h3 class="value-title">No Vanity Metrics</h3>
          <p class="value-desc">We optimise for business outcomes, not platform metrics that look good in a slide deck.</p>
        </div>

        <div class="value-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 00-3-3.87"/>
            <path d="M16 3.13a4 4 0 010 7.75"/>
          </svg>
          <h3 class="value-title">Senior-Only Delivery</h3>
          <p class="value-desc">No account managers between you and the person doing the work.</p>
        </div>

        <div class="value-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="23 6 13.5 15.5 8.5 10.5 2 17"/>
            <polyline points="17 6 23 6 23 12"/>
          </svg>
          <h3 class="value-title">Long-Term Thinking</h3>
          <p class="value-desc">We build programs designed to compound over years, not spike for a quarter.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container cta-inner">
      <SectionTag label="Let's Talk" />
      <h2 class="cta-title">Ready to work with a team that's actually in your account?</h2>
      <p class="cta-desc">We take on a limited number of new clients. Book a call to see if we're the right fit.</p>
      <div class="cta-buttons">
        <Button href="/contact#hubspot-meetings" variant="primary">Book a Call</Button>
        <Button href="/work" variant="secondary">See Our Work</Button>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .page-hero {
    padding: 80px 0 56px;
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    color: var(--text-2);
    margin-top: 16px;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .accent { color: var(--blue); }

  /* ── Our Story ── */
  .story-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 48px;
    align-items: stretch;
  }

  .story-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
  }

  .story-blocks {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .story-block {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .story-h2 {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-2);
  }

  .story-block p {
    font-size: 15px;
    color: var(--text-3);
    line-height: 1.8;
  }

  /* ── Story photo ── */
  .story-photo {
    border-radius: 12px;
    overflow: hidden;
    min-height: 480px;
  }

  .story-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Team ── */
  .team-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(56, 182, 255, 0.04) 0%, transparent 70%);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    margin-bottom: 48px;
  }

  .section-headline {
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .section-subhead {
    font-size: 16px;
    color: var(--text-3);
    max-width: 480px;
    line-height: 1.7;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 860px;
    margin: 0 auto;
  }

  .team-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .team-photo {
    height: 240px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .team-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .team-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 28px 32px 32px;
  }

  .team-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-2);
  }

  .team-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--blue);
  }

  .team-bio {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.75;
    margin-top: 8px;
  }

  .linkedin-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-3);
    text-decoration: none;
    margin-top: 12px;
    transition: color 0.15s;
  }

  .linkedin-link:hover { color: var(--blue); }

  /* ── Logo Strip ── */
  .logos-section {
    padding: 64px 0;
    border-bottom: 1px solid var(--border);
  }

  .logos-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
    margin-bottom: 40px;
  }

  .logos-subhead {
    font-size: 14px;
    color: var(--text-3);
  }

  .logos-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .logo-tile {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    width: 180px;
    height: 88px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .logo-tile:hover { opacity: 1; }

  .logo-img {
    width: 120px;
    height: 44px;
    object-fit: contain;
    display: block;
    filter: brightness(0) invert(1);
  }

  .logo-window-nation { width: 174px; height: 76px; }
  .logo-vector-security { width: 148px; height: 60px; }

  /* ── Values ── */
  .values-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .value-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .value-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-2);
  }

  .value-desc {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.7;
  }

  /* ── CTA Banner ── */
  .cta-banner {
    position: relative;
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 80px 0;
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    top: -80px;
    right: -80px;
    width: 500px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(56, 182, 255, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .cta-title {
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.2;
    max-width: 640px;
  }

  .cta-desc {
    font-size: 16px;
    color: var(--text-3);
    max-width: 480px;
    line-height: 1.7;
  }

  .cta-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .story-grid { grid-template-columns: 1fr; }
    .story-photo { min-height: 280px; }
  }

  @media (max-width: 768px) {
    .team-grid { grid-template-columns: 1fr; max-width: 480px; }
    .values-grid { grid-template-columns: 1fr; }
    .logos-row { gap: 8px; }
    .logo-tile { padding: 16px 24px; }
  }
</style>
