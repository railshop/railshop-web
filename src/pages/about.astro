---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import CtaBanner from '../components/ui/CtaBanner.astro';
import { getAboutPage, getTeamMembers, urlForImage } from '../lib/sanity';

let aboutPage: any = null;
let teamMembers: any[] = [];
try {
  [aboutPage, teamMembers] = await Promise.all([getAboutPage(), getTeamMembers()]);
} catch (_) {}

// Fallbacks
const heroEyebrow  = aboutPage?.hero?.eyebrow  ?? null;
const heroHeadline = aboutPage?.hero?.headline ?? null;
const heroSubhead  = aboutPage?.hero?.subhead  ?? null;
const ctaTitle     = aboutPage?.ctaBanner?.title    ?? 'Senior experience. No hand-offs.';
const ctaSubtitle  = aboutPage?.ctaBanner?.subtitle ?? "We take on a limited number of new clients. Book a call to see if we're the right fit.";

// Team members — from Sanity or fallback
const displayTeam = teamMembers.length > 0 ? teamMembers : [
  { name: 'Andrew Opalinski', role: 'Co-Founder · Head of Digital Strategy', bio: 'Former Head of Digital Marketing at Window Nation and Vector Security, where he built and scaled paid media, SEO, and web programs across national markets. Drew brings that enterprise playbook directly to growing service businesses.', photo: null, linkedinUrl: 'https://linkedin.com/in/drewrailshop', _fallbackImg: '/images/drew 169 cropped.jpg' },
  { name: 'Sean Connelly', role: 'Co-Founder · Head of Product & Operations', bio: 'VP of Product at Momentive Software, where he leads product development and systems thinking at scale. Sean brings that same discipline to every Railshop engagement — making sure strategy translates into execution that actually ships.', photo: null, linkedinUrl: 'https://linkedin.com/in/seanrailshop', _fallbackImg: '/images/sean 169 cropped.jpg' },
];
---

<BaseLayout
  title={aboutPage?.seo?.metaTitle ?? 'About — Railshop'}
  description={aboutPage?.seo?.metaDescription ?? 'Railshop is a boutique performance marketing agency. Senior practitioners, no account managers, no black boxes.'}
>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <svg class="hero-grid-svg" viewBox="0 0 1400 480" fill="none" preserveAspectRatio="xMidYMid slice">
        <line class="grid-line" x1="350" y1="0" x2="350" y2="480"/>
        <line class="grid-line" x1="700" y1="0" x2="700" y2="480"/>
        <line class="grid-line" x1="1050" y1="0" x2="1050" y2="480"/>
        <line class="grid-line" x1="0" y1="160" x2="1400" y2="160"/>
        <line class="grid-line" x1="0" y1="320" x2="1400" y2="320"/>
        <path class="corner-bracket" d="M 32 24 L 32 60 M 32 24 L 68 24"/>
        <path class="corner-bracket" d="M 1368 456 L 1368 420 M 1368 456 L 1332 456"/>
        <line class="tick-mark" x1="350" y1="468" x2="350" y2="480"/>
        <line class="tick-mark" x1="700" y1="468" x2="700" y2="480"/>
        <line class="tick-mark" x1="1050" y1="468" x2="1050" y2="480"/>
      </svg>
      <div class="hero-glow"></div>
    </div>

    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: ABOUT</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">ABT-001</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">// TEAM &amp; MISSION</span>
    </div>

    <div class="container">
      <div class="hero-inner">
        <div class="hero-left">
          {heroHeadline ? (
            <h1 class="hero-headline" set:html={heroHeadline.replace(/\n/g, '<br />')} />
          ) : (
            <h1 class="hero-headline">
              Built different<br />
              <span class="hero-accent">on purpose.</span>
            </h1>
          )}
          <p class="hero-sub">
            {heroSubhead ?? 'We started Railshop because great service businesses deserve better than what most agencies offer.'}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. OUR STORY
       ============================================================ -->
  <section class="story-section">
    <div class="container">
      <div class="block-header story-section-header">
        <h2 class="block-title">Why we started Railshop.</h2>
      </div>
    </div>
    <div class="container story-grid">

      <div class="story-left">
        <div class="story-blocks">
          <div class="story-block">
            <h3 class="story-h3">Why we started</h3>
            <p class="story-copy">
              Between us, we bring backgrounds on opposite sides of digital. One side is performance marketing — paid media, SEO, and web programs built and scaled at national service brands, with tens of millions in ad spend managed directly. The other side is product and software — leading development at scale, building the systems that make sure strategy actually ships.
            </p>
            <p class="story-copy">
              Most agencies don't have both. We thought it was worth building something that does.
            </p>
          </div>

          <div class="story-block">
            <h3 class="story-h3">The Railshop difference</h3>
            <p class="story-copy">
              We kept seeing the same pattern: service businesses with real growth potential being handed off to junior account managers at agencies that barely understood their industry. Generic campaigns. Vanity reporting. Businesses left wondering why the phone wasn't ringing at the rate the dashboards suggested it should be.
            </p>
            <p class="story-copy">
              We knew we could do better — so we built a model where senior experience is the baseline, not the upsell. Strategy and execution, from people who've done it at scale.
            </p>
          </div>
        </div>
      </div>

      <div class="story-photo-wrap">
        <div class="story-photo">
          <img src="/images/office.jpg" alt="Railshop office" class="story-photo-img" loading="lazy" decoding="async" />
          <div class="story-photo-overlay" aria-hidden="true">
            <span class="story-photo-label">// RAILSHOP HQ</span>
          </div>
          <span class="story-tick story-tick--tl" aria-hidden="true"></span>
          <span class="story-tick story-tick--tr" aria-hidden="true"></span>
          <span class="story-tick story-tick--bl" aria-hidden="true"></span>
          <span class="story-tick story-tick--br" aria-hidden="true"></span>
        </div>
      </div>

    </div>
  </section>

  <!-- ============================================================
       3. TEAM
       ============================================================ -->
  <section class="team-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-headline">Senior experience. No hand-offs.</h2>
        <p class="section-subhead">Every client works directly with us — not a coordinator or a junior hire.</p>
      </div>

      <div class="team-grid">
        {displayTeam.map((member: any, i: number) => {
          const photoSrc = member.photo ? urlForImage(member.photo).url() : member._fallbackImg;
          return (
            <div class="team-card">
              <div class="team-photo-wrap">
                {photoSrc && <img src={photoSrc} alt={member.name} class="team-photo-img" loading="lazy" decoding="async" />}
                <div class="team-photo-overlay" aria-hidden="true"></div>
              </div>
              <div class="team-info">
                <div class="team-meta">
                  <span class="team-idx">{String(i + 1).padStart(2, '0')}</span>
                  <span class="team-role">{member.role}</span>
                </div>
                <p class="team-name">{member.name}</p>
                <p class="team-bio">{member.bio}</p>
                {member.linkedinUrl && (
                  <a href={member.linkedinUrl} class="linkedin-link" target="_blank" rel="noopener noreferrer">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
                      <rect x="2" y="9" width="4" height="12"/>
                      <circle cx="4" cy="4" r="2"/>
                    </svg>
                    LinkedIn
                  </a>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. CLIENT LOGOS
       ============================================================ -->
  <section class="logos-section">
    <div class="container">
      <div class="logos-header">
        <h2 class="section-headline">Brands we've worked with.</h2>
      </div>
      <div class="logos-row">
        <div class="logo-tile">
          <img src="/images/logos/window nation logo.png" alt="Window Nation" class="logo-img logo-window-nation" loading="lazy" decoding="async" />
        </div>
        <div class="logo-tile">
          <img src="/images/logos/vector security logo.svg" alt="Vector Security" class="logo-img logo-vector-security" loading="lazy" decoding="async" />
        </div>
        <div class="logo-tile">
          <img src="/images/logos/fire and ice logo.png" alt="Fire &amp; Ice" class="logo-img logo-fire-ice" loading="lazy" decoding="async" />
        </div>
        <div class="logo-tile">
          <img src="/images/logos/jp operations logo.svg" alt="JP Operations" class="logo-img logo-jp-operations" loading="lazy" decoding="async" />
        </div>
        <div class="logo-tile logo-tile--placeholder"></div>
        <div class="logo-tile logo-tile--placeholder"></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. VALUES
       ============================================================ -->
  <section class="values-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-headline">How we work.</h2>
      </div>
      <div class="values-grid">

        <div class="value-card">
          <div class="value-top">
            <span class="value-idx">01</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 11l3 3L22 4"/>
              <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            </svg>
          </div>
          <h3 class="value-title">Honest Reporting</h3>
          <p class="value-desc">You'll always know what's working and what isn't. No vanity metrics, no spin.</p>
        </div>

        <div class="value-card">
          <div class="value-top">
            <span class="value-idx">02</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="20" x2="18" y2="10"/>
              <line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
          </div>
          <h3 class="value-title">No Vanity Metrics</h3>
          <p class="value-desc">We measure what moves your business forward. ROAS, CPL, revenue — not impressions and reach.</p>
        </div>

        <div class="value-card">
          <div class="value-top">
            <span class="value-idx">03</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87"/>
              <path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <h3 class="value-title">Senior-Only Delivery</h3>
          <p class="value-desc">Every engagement is led by co-founders, not coordinators. You deal directly with the people doing the work.</p>
        </div>

        <div class="value-card">
          <div class="value-top">
            <span class="value-idx">04</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="23 6 13.5 15.5 8.5 10.5 2 17"/>
              <polyline points="17 6 23 6 23 12"/>
            </svg>
          </div>
          <h3 class="value-title">Long-Term Thinking</h3>
          <p class="value-desc">We're not optimizing for the next 30 days. We're building programs that compound.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       6. CTA BANNER
       ============================================================ -->
  <CtaBanner
    title={ctaTitle}
    subtitle={ctaSubtitle}
    secondaryText="See Our Work"
    secondaryHref="/work"
    secondaryVariant="link"
  />

</BaseLayout>

<style>
  /* ══════════════════════════════════════
     SHARED TOKENS
  ══════════════════════════════════════ */
  .block-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .block-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-2);
    letter-spacing: -0.01em;
  }

  /* ══════════════════════════════════════
     1. HERO
  ══════════════════════════════════════ */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-grid-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .grid-line   { stroke: var(--border); stroke-width: 1; opacity: 0.4; }
  .corner-bracket { stroke: var(--border); stroke-width: 1.5; opacity: 0.35; }
  .tick-mark   { stroke: var(--border); stroke-width: 1; opacity: 0.5; }

  .hero-glow {
    position: absolute;
    top: -40px;
    left: -5%;
    width: 55%;
    height: 100%;
    background: radial-gradient(ellipse at 30% 40%, rgba(56, 182, 255, 0.04) 0%, transparent 65%);
  }

  .hero-annotation {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    pointer-events: none;
    z-index: 2;
  }

  .hero-annotation--tr { top: 20px; right: 32px; }
  .hero-annotation--bl { bottom: 20px; left: 32px; }
  .anno-code { color: var(--blue); opacity: 0.8; }
  .anno-sep  { opacity: 0.3; }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 56px 0 64px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .hero-accent { color: var(--blue); }

  .hero-sub {
    font-size: 16px;
    color: var(--text-3);
    max-width: 540px;
    line-height: 1.75;
  }

  /* ══════════════════════════════════════
     2. OUR STORY
  ══════════════════════════════════════ */
  .story-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 64px;
    align-items: stretch;
  }

  .story-section-header {
    margin-bottom: 40px;
  }

  .story-left {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .story-blocks {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .story-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .story-h3 {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-2);
    padding-left: 14px;
    position: relative;
  }

  .story-h3::before {
    content: '';
    position: absolute;
    left: 0;
    top: 3px;
    bottom: 3px;
    width: 3px;
    background: var(--blue);
    opacity: 0.5;
    border-radius: 2px;
  }

  .story-copy {
    font-size: 15px;
    color: var(--text-3);
    line-height: 1.8;
  }

  /* Story photo */
  .story-photo-wrap {
    position: relative;
    height: 100%;
  }

  .story-photo {
    position: relative;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
    height: 100%;
    min-height: 360px;
  }

  .story-photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .story-photo-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 14px 16px;
    background: linear-gradient(transparent, rgba(0,0,0,0.55));
  }

  .story-photo-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }

  .story-tick {
    position: absolute;
    width: 10px;
    height: 10px;
    pointer-events: none;
    z-index: 2;
  }

  .story-tick--tl { top: 8px; left: 8px; border-top: 1px solid var(--border-2); border-left: 1px solid var(--border-2); opacity: 0.5; }
  .story-tick--tr { top: 8px; right: 8px; border-top: 1px solid var(--border-2); border-right: 1px solid var(--border-2); opacity: 0.5; }
  .story-tick--bl { bottom: 8px; left: 8px; border-bottom: 1px solid var(--border-2); border-left: 1px solid var(--border-2); opacity: 0.5; }
  .story-tick--br { bottom: 8px; right: 8px; border-bottom: 1px solid var(--border-2); border-right: 1px solid var(--border-2); opacity: 0.5; }

  /* ══════════════════════════════════════
     3. TEAM
  ══════════════════════════════════════ */
  .team-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
    margin-bottom: 48px;
  }

  .section-headline {
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .section-subhead {
    font-size: 15px;
    color: var(--text-3);
    max-width: 460px;
    line-height: 1.7;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    max-width: 860px;
    margin: 0 auto;
  }

  .team-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s;
  }

  .team-card:hover { border-color: var(--border-2); }

  .team-photo-wrap {
    position: relative;
    height: 240px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .team-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .team-card:hover .team-photo-img { transform: scale(1.02); }

  .team-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(transparent 50%, rgba(0,0,0,0.3));
  }

  .team-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 24px 28px 28px;
  }

  .team-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }

  .team-idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--text-3);
    opacity: 0.25;
    flex-shrink: 0;
  }

  .team-role {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.75;
  }

  .team-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-2);
    letter-spacing: -0.01em;
  }

  .team-bio {
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.75;
    margin-top: 6px;
  }

  .linkedin-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    text-decoration: none;
    margin-top: 10px;
    transition: opacity 0.15s, color 0.15s;
  }

  .linkedin-link:hover { opacity: 1; color: var(--blue); }

  /* ══════════════════════════════════════
     4. LOGOS
  ══════════════════════════════════════ */
  .logos-section {
    padding: 64px 0;
    border-bottom: 1px solid var(--border);
  }

  .logos-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
    margin-bottom: 40px;
  }

  .logos-subhead {
    font-size: 13px;
    color: var(--text-3);
    opacity: 0.5;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
  }

  .logos-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .logo-tile {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    width: 176px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
    transition: opacity 0.2s, border-color 0.2s;
  }

  .logo-tile:hover { opacity: 0.85; border-color: var(--border-2); }

  .logo-img {
    width: 120px;
    height: 44px;
    object-fit: contain;
    display: block;
    filter: brightness(0) invert(1);
  }

  .logo-window-nation  { width: 170px; height: 70px; }
  .logo-vector-security { width: 144px; height: 56px; }

  /* ══════════════════════════════════════
     5. VALUES
  ══════════════════════════════════════ */
  .values-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }

  .value-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    transition: border-color 0.2s;
  }

  .value-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--blue);
    opacity: 0.3;
    border-radius: 2px 0 0 2px;
    transition: opacity 0.2s;
  }

  .value-card:hover { border-color: var(--border-2); }
  .value-card:hover::before { opacity: 1; }

  .value-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .value-idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
