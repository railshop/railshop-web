---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import CtaBanner from '../../components/ui/CtaBanner.astro';
import { getServices, getServicesPage } from '../../lib/sanity';

let services: any[] = [];
let servicesPage: any = null;
try {
  [services, servicesPage] = await Promise.all([getServices(), getServicesPage()]);
} catch (_) {}

// Singleton content with fallbacks
const heroHeadline    = servicesPage?.hero?.headline ?? null;
const heroSubhead     = servicesPage?.hero?.subhead  ?? null;
const manifestTitle   = servicesPage?.manifest?.title ?? 'Services built for measurable growth';
const manifestIntro   = servicesPage?.manifest?.intro ?? 'Six ways we help service businesses compete and grow online. Every engagement starts with your goals, not a default package.';
const approachTitle   = servicesPage?.approach?.title ?? 'A process built for measurable outcomes.';
const approachSub     = servicesPage?.approach?.sub   ?? 'Every engagement follows the same principle: find what works, build on it, and grow.';
const ctaTitle        = servicesPage?.ctaBanner?.title    ?? 'Not sure where to start?';
const ctaSubtitle     = servicesPage?.ctaBanner?.subtitle ?? "Most clients begin with a 30-minute call. We'll tell you exactly where we'd focus first. Come with questions. Leave with a clear picture.";

const displayServices = services.length > 0 ? services : [
  { _id: '1', title: 'Web Design & Development', description: 'High-converting websites built for service businesses. Strategy-first, not template-first.', slug: { current: 'web-design' } },
  { _id: '2', title: 'Paid Ads', description: 'Google Ads, LSA, and Meta campaigns built around your cost-per-lead goals. Not vanity metrics.', slug: { current: 'paid-ads' } },
  { _id: '3', title: 'SEO', description: 'Local and technical SEO that compounds over time and reduces your reliance on paid.', slug: { current: 'seo' } },
  { _id: '4', title: 'Content Creation', description: 'Video and photo content that builds authority and keeps your brand visible between campaigns.', slug: { current: 'content-creation' } },
  { _id: '5', title: 'Strategy Consulting', description: "Not sure where to start? We'll audit your full digital presence and build a prioritized plan.", slug: { current: 'strategy' } },
  { _id: '6', title: 'AI Integration', description: 'Practical AI implementation that reduces cost, saves time, and gives your business a real edge.', slug: { current: 'ai-integration' } },
];

const serviceIcons = [
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10l4.553-2.07A1 1 0 0121 8.868v6.264a1 1 0 01-1.447.899L15 14"/><rect x="2" y="7" width="13" height="10" rx="2"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 017 7c0 2.62-1.4 4.91-3.5 6.19V17a1 1 0 01-1 1h-5a1 1 0 01-1-1v-1.81A7.003 7.003 0 015 9a7 7 0 017-7z"/></svg>`,
  `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.5 3.5L17 8l-3.5 1.5L12 13l-1.5-3.5L7 8l3.5-1.5L12 3z"/><path d="M5 17l1 2.5L8.5 20 7 17.5 5 17z"/><path d="M17 14l1 2.5L20.5 17 19 14.5 17 14z"/></svg>`,
];

const phaseCodes = ['ASSESS', 'BUILD', 'GROW'];
---

<BaseLayout
  title={servicesPage?.seo?.metaTitle ?? 'Services — Railshop'}
  description={servicesPage?.seo?.metaDescription ?? 'Digital growth services for service businesses: web design, paid ads, SEO, content, strategy, and AI integration.'}
>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <!-- Grid lines -->
      <svg class="hero-grid-svg" viewBox="0 0 1400 480" fill="none" preserveAspectRatio="xMidYMid slice">
        <line class="grid-line" x1="350" y1="0" x2="350" y2="480"/>
        <line class="grid-line" x1="700" y1="0" x2="700" y2="480"/>
        <line class="grid-line" x1="1050" y1="0" x2="1050" y2="480"/>
        <line class="grid-line" x1="0" y1="160" x2="1400" y2="160"/>
        <line class="grid-line" x1="0" y1="320" x2="1400" y2="320"/>
        <path class="corner-bracket" d="M 32 24 L 32 60 M 32 24 L 68 24"/>
        <path class="corner-bracket" d="M 1368 456 L 1368 420 M 1368 456 L 1332 456"/>
        <line class="tick-mark" x1="350" y1="468" x2="350" y2="480"/>
        <line class="tick-mark" x1="700" y1="468" x2="700" y2="480"/>
        <line class="tick-mark" x1="1050" y1="468" x2="1050" y2="480"/>
      </svg>
      <div class="hero-glow"></div>
    </div>

    <!-- Corner annotations -->
    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: SERVICES</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">6 CHANNELS ACTIVE</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">MODULE: SVC-001</span>
    </div>

    <div class="container">
      <div class="hero-inner">
        <div class="hero-left">
          {heroHeadline ? (
            <h1 class="hero-headline" set:html={heroHeadline.replace(/\n/g, '<br />')} />
          ) : (
            <h1 class="hero-headline">
              What we<br />
              <span class="hero-accent">do best.</span>
            </h1>
          )}
          <p class="hero-sub">
            {heroSubhead ?? 'We build what service businesses need to compete online: websites, paid ads, SEO, content, and AI integration. Senior-level experience on every engagement. You work directly with the people doing the work.'}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. SERVICES MANIFEST
       ============================================================ -->
  <section class="services-section">
    <div class="container">
      <div class="services-header">
        <div class="services-header-left">
          <h2 class="services-title" set:html={manifestTitle.replace(/\n/g, '<br />')} />
        </div>
        <p class="services-intro">{manifestIntro}</p>
      </div>

      <div class="services-manifest">
        {displayServices.map((svc, i) => (
          <a href={`/services/${svc.slug.current}`} class="svc-row">
            <div class="svc-row-left">
              <span class="svc-idx">0{i + 1}</span>
              <span class="svc-icon" set:html={serviceIcons[i]} />
              <h3 class="svc-title">{svc.title}</h3>
            </div>
            <p class="svc-desc">{svc.description}</p>
            <span class="svc-arrow">
              Learn more
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. HOW WE WORK — Phase sequence
       ============================================================ -->
  <section class="approach-section">
    <!-- Divider rule -->
    <div class="section-rule" aria-hidden="true">
      <div class="section-rule-line"></div>
      <span class="section-rule-label">ENGAGEMENT PROTOCOL</span>
      <div class="section-rule-line"></div>
    </div>

    <div class="container">
      <div class="approach-header">
        <h2 class="approach-title" set:html={approachTitle.replace(/\n/g, '<br />')} />
        <p class="approach-sub">{approachSub}</p>
      </div>

      <div class="phases">
        <!-- Phase 01 -->
        <div class="phase-card">
          <div class="phase-top">
            <span class="phase-code">PHASE 01</span>
            <div class="phase-status">
              <span class="phase-dot"></span>
              <span class="phase-status-label">INITIATED</span>
            </div>
          </div>
          <div class="phase-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </div>
          <h3 class="phase-title">Assess</h3>
          <p class="phase-desc">We start with an honest audit of where you stand: website, paid media, SEO, and competitive position. No assumptions, no default packages.</p>
          <div class="phase-deliverables">
            <span class="phase-d-label">Deliverables</span>
            <ul class="phase-d-list">
              <li>Market & competitor audit</li>
              <li>Channel opportunity analysis</li>
              <li>Prioritised growth roadmap</li>
            </ul>
          </div>
        </div>

        <!-- Connector -->
        <div class="phase-connector" aria-hidden="true">
          <div class="connector-line"></div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="connector-arrow">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </div>

        <!-- Phase 02 -->
        <div class="phase-card">
          <div class="phase-top">
            <span class="phase-code">PHASE 02</span>
            <div class="phase-status phase-status--gold">
              <span class="phase-dot phase-dot--gold"></span>
              <span class="phase-status-label">IN PROGRESS</span>
            </div>
          </div>
          <div class="phase-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
            </svg>
          </div>
          <h3 class="phase-title">Build</h3>
          <p class="phase-desc">We build or rebuild the foundation your growth depends on. Conversion-focused websites, properly structured campaigns, and the tracking to know what's actually working.</p>
          <div class="phase-deliverables">
            <span class="phase-d-label">Deliverables</span>
            <ul class="phase-d-list">
              <li>Channel setup & configuration</li>
              <li>Creative & asset production</li>
              <li>Launch-ready campaigns</li>
            </ul>
          </div>
        </div>

        <!-- Connector -->
        <div class="phase-connector" aria-hidden="true">
          <div class="connector-line"></div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="connector-arrow">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </div>

        <!-- Phase 03 -->
        <div class="phase-card">
          <div class="phase-top">
            <span class="phase-code">PHASE 03</span>
            <div class="phase-status phase-status--live">
              <span class="phase-dot phase-dot--live"></span>
              <span class="phase-status-label">LIVE</span>
            </div>
          </div>
          <div class="phase-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>
            </svg>
          </div>
          <h3 class="phase-title">Grow</h3>
          <p class="phase-desc">With the foundation right, we scale what's working and cut what isn't. Month over month, we're driving toward your revenue goals, not just maintaining the status quo.</p>
          <div class="phase-deliverables">
            <span class="phase-d-label">Deliverables</span>
            <ul class="phase-d-list">
              <li>Performance reporting</li>
              <li>Continuous optimisation</li>
              <li>Scaled budget deployment</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. CTA BANNER
       ============================================================ -->
  <CtaBanner
    title={ctaTitle}
    subtitle={ctaSubtitle}
    secondaryText="Send a Message"
    secondaryHref="/contact#message-accordion"
  />

</BaseLayout>

<style>
  /* ══════════════════════════════════════
     1. HERO
  ══════════════════════════════════════ */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-grid-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .grid-line {
    stroke: var(--border);
    stroke-width: 1;
    opacity: 0.4;
  }

  .corner-bracket {
    stroke: var(--border);
    stroke-width: 1.5;
    opacity: 0.35;
  }

  .tick-mark {
    stroke: var(--border);
    stroke-width: 1;
    opacity: 0.5;
  }

  .hero-glow {
    position: absolute;
    top: -40px;
    left: -5%;
    width: 50%;
    height: 80%;
    background: radial-gradient(ellipse at 30% 40%, rgba(56, 182, 255, 0.045) 0%, transparent 65%);
  }

  /* Corner annotations */
  .hero-annotation {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-annotation--tr { top: 20px; right: 32px; }
  .hero-annotation--bl { bottom: 20px; left: 32px; }

  .anno-code { color: var(--blue); opacity: 0.8; }
  .anno-sep  { opacity: 0.3; }

  /* Hero content */
  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 56px 0 64px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-accent { color: var(--blue); }

  .hero-headline {
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    max-width: 680px;
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--text-3);
    max-width: 540px;
    line-height: 1.75;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ══════════════════════════════════════
     SHARED: SECTION RULE DIVIDER
  ══════════════════════════════════════ */
  .section-rule {
    display: flex;
    align-items: center;
    height: 32px;
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    overflow: hidden;
  }

  .section-rule-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .section-rule-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.35;
    padding: 0 16px;
    white-space: nowrap;
  }

  /* ══════════════════════════════════════
     2. SERVICES MANIFEST
  ══════════════════════════════════════ */
  .services-section {
    border-top: 1px solid var(--border);
  }

  .services-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: end;
    padding: 64px 0 52px;
  }

  .services-title {
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .services-intro {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.75;
    align-self: end;
    max-width: 440px;
  }

  /* Manifest rows */
  .services-manifest {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 80px;
  }

  .svc-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    align-items: center;
    gap: 32px;
    padding: 28px 32px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    position: relative;
    transition: background 0.2s ease;
  }

  .svc-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--blue);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .svc-row:last-child { border-bottom: none; }

  .svc-row:hover { background: var(--surface); }
  .svc-row:hover::before { opacity: 1; }
  .svc-row:hover .svc-arrow { color: var(--blue); transform: translateX(3px); }
  .svc-row:hover .svc-title { color: var(--blue); }

  .svc-row-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .svc-idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--text-3);
    opacity: 0.35;
    flex-shrink: 0;
    width: 20px;
  }

  .svc-icon {
    color: var(--blue);
    flex-shrink: 0;
    opacity: 0.85;
  }

  .svc-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-2);
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .svc-desc {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.7;
  }

  .svc-arrow {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-3);
    white-space: nowrap;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  /* ══════════════════════════════════════
     3. HOW WE WORK — Phase sequence
  ══════════════════════════════════════ */
  .approach-section {
    border-top: 1px solid var(--border);
    background: radial-gradient(ellipse 80% 60% at 50% 100%, rgba(56, 182, 255, 0.03) 0%, transparent 70%);
  }

  .approach-header {
    padding: 64px 0 56px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    max-width: 520px;
  }

  .approach-title {
    font-size: clamp(26px, 3.5vw, 38px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .approach-sub {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.7;
  }

  /* Phase cards in a row */
  .phases {
    display: flex;
    align-items: stretch;
    gap: 0;
    padding-bottom: 80px;
  }

  .phase-card {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    transition: border-color 0.2s ease;
  }

  .phase-card:hover {
    border-color: var(--border-2);
  }

  .phase-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .phase-code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.7;
  }

  .phase-status {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .phase-status-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.5;
  }

  .phase-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--border-2);
    flex-shrink: 0;
  }

  .phase-dot--gold {
    background: var(--gold);
  }

  .phase-status--gold .phase-status-label {
    color: var(--gold);
    opacity: 0.8;
  }

  .phase-dot--live {
    background: var(--green);
    box-shadow: 0 0 6px rgba(52, 211, 153, 0.5);
  }

  .phase-status--live .phase-status-label {
    color: var(--green);
    opacity: 0.8;
  }

  .phase-icon { display: flex; }

  .phase-title {
    font-size: 20px;
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.02em;
  }

  .phase-desc {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.75;
    flex: 1;
  }

  .phase-deliverables {
    border-top: 1px solid var(--border);
    padding-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 4px;
  }

  .phase-d-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.45;
  }

  .phase-d-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .phase-d-list li {
    font-size: 12px;
    color: var(--text-3);
    padding-left: 12px;
    position: relative;
  }

  .phase-d-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--blue);
    opacity: 0.5;
    font-size: 10px;
  }

  /* Connector between phase cards */
  .phase-connector {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    width: 48px;
    flex-shrink: 0;
    gap: 4px;
