---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import CtaBanner from '../../components/ui/CtaBanner.astro';
import { getServiceBySlug, getAllServiceSlugs } from '../../lib/sanity';
import { serviceSamples } from '../../lib/sampleData';

export async function getStaticPaths() {
  try {
    const slugs = await getAllServiceSlugs();
    if (slugs.length > 0) {
      return slugs.map((s: { slug: string }) => ({ params: { slug: s.slug } }));
    }
  } catch (_) {}
  return Object.keys(serviceSamples).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

let service: any = null;
try {
  service = await getServiceBySlug(slug);
} catch (_) {}

// Fall back to sample data
const sample = serviceSamples[slug];
const data = {
  title:        service?.title           ?? sample?.title        ?? slug,
  description:  service?.description     ?? sample?.description  ?? '',
  deliverables: service?.whatIsIncluded?.length > 0
                  ? service.whatIsIncluded
                  : sample?.deliverables ?? [],
  approach:     service?.approach?.length > 0
                  ? service.approach
                  : sample?.approach ?? [],
  whoFor:       service?.whoThisIsFor?.length > 0
                  ? service.whoThisIsFor
                  : sample?.whoFor ?? [],
  ctaHeadline:  service?.ctaHeadline ?? null,
  relatedSlugs: sample?.relatedSlugs ?? [],
};

const serviceOrder = ['web-design', 'paid-ads', 'seo', 'content-creation', 'strategy-consulting', 'ai-integration'];
const currentIdx = serviceOrder.indexOf(slug);
const moduleId = `SVC-${String(currentIdx + 1).padStart(3, '0')}`;

const allServices = [
  { slug: 'web-design',       title: 'Web Design & Development' },
  { slug: 'paid-ads',         title: 'Paid Ads' },
  { slug: 'seo',              title: 'SEO' },
  { slug: 'content-creation', title: 'Content Creation' },
  { slug: 'strategy-consulting', title: 'Strategy Consulting' },
  { slug: 'ai-integration',   title: 'AI Integration' },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      'name': data.title,
      'description': data.description,
      'provider': { '@id': 'https://railshop.co/#organization' },
      'serviceType': 'Digital Marketing',
      'areaServed': { '@type': 'Country', 'name': 'United States' },
      'url': `https://railshop.co/services/${slug}`,
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://railshop.co' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Services', 'item': 'https://railshop.co/services' },
        { '@type': 'ListItem', 'position': 3, 'name': data.title, 'item': `https://railshop.co/services/${slug}` },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${data.title} — Railshop`}
  description={service?.seo?.metaDescription ?? data.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <svg class="hero-bg-svg" viewBox="0 0 1400 480" fill="none" preserveAspectRatio="xMidYMid slice">
        <path class="hero-arc-main"      d="M -80 520 Q 380 40 860 260 Q 1060 390 1480 180" stroke-width="1" fill="none"/>
        <path class="hero-arc-secondary" d="M -80 560 Q 360 60 830 290 Q 1030 420 1480 220" stroke-width="1" fill="none"/>
        <circle class="hero-bg-star" cx="885"  cy="44"  r="1.5"/>
        <circle class="hero-bg-star" cx="1102" cy="29"  r="1"/>
        <circle class="hero-bg-star" cx="1248" cy="74"  r="2"/>
        <circle class="hero-bg-star" cx="1342" cy="42"  r="1.5"/>
        <circle class="hero-bg-star" cx="1064" cy="142" r="1"/>
        <circle class="hero-bg-star" cx="1285" cy="184" r="1.5"/>
        <circle class="hero-bg-star" cx="950"  cy="244" r="1"/>
        <circle class="hero-bg-star" cx="1380" cy="260" r="2"/>
        <circle class="hero-bg-star" cx="822"  cy="352" r="1"/>
        <circle class="hero-bg-star" cx="1154" cy="384" r="1.5"/>
        <circle class="hero-bg-star" cx="684"  cy="80"  r="1"/>
        <path class="hero-bg-star-4pt" d="M 1022 56 L 1023.8 60.2 L 1028 62 L 1023.8 63.8 L 1022 68 L 1020.2 63.8 L 1016 62 L 1020.2 60.2 Z"/>
        <path class="hero-bg-star-4pt" d="M 1220 146 L 1221.5 149.5 L 1225 151 L 1221.5 152.5 L 1220 156 L 1218.5 152.5 L 1215 151 L 1218.5 149.5 Z"/>
        <path class="hero-bg-star-4pt" d="M 870 316 L 871.8 320.2 L 876 322 L 871.8 323.8 L 870 328 L 868.2 323.8 L 864 322 L 868.2 320.2 Z"/>
      </svg>
      <div class="hero-glow"></div>
    </div>

    <!-- Corner annotations -->
    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: SERVICES</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">{moduleId}</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">// CHANNEL DETAIL</span>
    </div>

    <div class="container">
      <!-- Breadcrumb inside hero -->
      <div class="breadcrumb">
        <a href="/services" class="breadcrumb-link">Services</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{data.title}</span>
      </div>

      <div class="hero-inner">
        <div class="hero-left">
          <h1 class="hero-headline">{data.title}</h1>
          <p class="hero-sub">{data.description}</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       2. CONTENT — main + sidebar
       ============================================================ -->
  <div class="content-wrap">
    <div class="container content-grid">

      <!-- Main column -->
      <div class="main-col">

        <!-- Deliverables -->
        {data.deliverables.length > 0 && (
          <div class="content-block">
            <div class="block-header">
              <h2 class="block-title">What's included</h2>
            </div>
            <ul class="deliverables-list">
              {data.deliverables.map((item, i) => (
                <li class="deliverable-item">
                  <span class="deliverable-idx">{String(i + 1).padStart(2, '0')}</span>
                  <svg class="check-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Approach -->
        {data.approach.length > 0 && (
          <div class="content-block">
            <div class="block-header">
              <h2 class="block-title">Our approach</h2>
            </div>
            <div class="approach-steps">
              {data.approach.map((step, i) => (
                <div class="approach-step">
                  <div class="step-top">
                    <span class="step-number">{String(i + 1).padStart(2, '0')}</span>
                    <h3 class="step-heading">{step.step}</h3>
                  </div>
                  <p class="step-detail">{step.detail}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Who it's for -->
        {data.whoFor.length > 0 && (
          <div class="content-block">
            <div class="block-header">
              <h2 class="block-title">Who this is for</h2>
            </div>
            <div class="who-list">
              {data.whoFor.map((item) => (
                <div class="who-item">
                  <span class="who-dash">—</span>
                  <p>{item}</p>
                </div>
              ))}
            </div>
          </div>
        )}

      </div>

      <!-- Sidebar -->
      <aside class="sidebar">

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <div class="sidebar-cta-status">
            <span class="sidebar-cta-dot"></span>
            <span class="sidebar-cta-label">Taking new clients</span>
          </div>
          <p class="sidebar-cta-heading">Ready to get started?</p>
          <p class="sidebar-cta-body">Book a call and we'll walk you through exactly how we'd approach this for your business.</p>
          <a href="/contact#book-a-call" class="sidebar-cta-btn">
            Book a Call
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- All services nav -->
        <div class="sidebar-card">
          <p class="sidebar-nav-label">// ALL SERVICES</p>
          <nav class="sidebar-nav-list">
            {allServices.map((svc, i) => {
              const isActive = svc.slug === slug;
              return (
                <a href={`/services/${svc.slug}`} class={`sidebar-nav-item ${isActive ? 'sidebar-nav-item--active' : ''}`}>
                  <span class="sidebar-nav-idx">0{i + 1}</span>
                  <span class="sidebar-nav-title">{svc.title}</span>
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="sidebar-nav-arrow" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              );
            })}
          </nav>
        </div>

      </aside>
    </div>
  </div>

  <!-- ============================================================
       3. CTA BANNER
       ============================================================ -->
  <CtaBanner
    title={data.ctaHeadline ?? `Ready to put ${data.title} to work for your business?`}
    subtitle="We take on a limited number of new clients. Let's talk about whether we're the right fit."
    secondaryText="All Services"
    secondaryHref="/services"
    secondaryVariant="link"
  />

</BaseLayout>

<style>
  /* ══════════════════════════════════════
     1. HERO
  ══════════════════════════════════════ */
  .hero {
    position: relative;
    padding: 0 0 0;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-bg-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-arc-main      { stroke: rgba(56, 182, 255, 0.10); }
  .hero-arc-secondary { stroke: rgba(56, 182, 255, 0.05); }
  .hero-bg-star       { fill:   rgba(56, 182, 255, 0.18); }
  .hero-bg-star-4pt   { fill:   rgba(56, 182, 255, 0.14); }

.hero-glow {
    position: absolute;
    top: -40px;
    left: -5%;
    width: 50%;
    height: 80%;
    background: radial-gradient(ellipse at 30% 40%, rgba(56, 182, 255, 0.045) 0%, transparent 65%);
  }

  /* Corner annotations */
  .hero-annotation {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    pointer-events: none;
    z-index: 2;
  }

  .hero-annotation--tr { top: 20px; right: 32px; }
  .hero-annotation--bl { bottom: 20px; left: 32px; }
  .anno-code { color: var(--blue); opacity: 0.8; }
  .anno-sep  { opacity: 0.3; }

  /* Breadcrumb */
  .breadcrumb {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 20px 0 0;
    font-size: 12px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 20px;
    margin-bottom: 0;
  }

  .breadcrumb-link { color: var(--text-3); transition: color 0.15s; }
  .breadcrumb-link:hover { color: var(--blue); }
  .breadcrumb-sep { color: var(--border-2); }
  .breadcrumb-current { color: var(--text-3); }

  /* Hero inner layout */
  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 56px 0 64px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .hero-headline {
    max-width: 520px;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--text-3);
    max-width: 480px;
    line-height: 1.75;
    margin-bottom: 32px;
  }



  /* ══════════════════════════════════════
     2. CONTENT AREA
  ══════════════════════════════════════ */
  .content-wrap {
    padding: 64px 0 80px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 64px;
    align-items: start;
  }

  .main-col {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  /* Content blocks */
  .content-block {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .block-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .block-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-2);
    letter-spacing: -0.01em;
  }

  /* Deliverables */
  .deliverables-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .deliverable-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 20px;
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.6;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  .deliverable-item:last-child { border-bottom: none; }
  .deliverable-item:hover { background: var(--surface); }

  .deliverable-idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--text-3);
    opacity: 0.25;
    flex-shrink: 0;
    width: 18px;
    margin-top: 2px;
  }

  .check-icon { flex-shrink: 0; margin-top: 2px; }

  /* Approach steps */
  .approach-steps {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .approach-step {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    transition: border-color 0.2s;
  }

  .approach-step::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--blue);
    opacity: 0.4;
    border-radius: 2px 0 0 2px;
    transition: opacity 0.2s;
  }

  .approach-step:hover { border-color: var(--border-2); }
  .approach-step:hover::before { opacity: 1; }

  .step-top {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .step-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 28px;
    font-weight: 700;
    color: var(--blue);
    line-height: 1;
    opacity: 0.35;
    flex-shrink: 0;
  }

  .step-heading {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-2);
  }

  .step-detail {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.75;
    padding-left: 42px;
  }

  /* Who it's for */
  .who-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .who-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.65;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  .who-item:last-child { border-bottom: none; }
  .who-item:hover { background: var(--surface); }

  .who-dash {
    font-family: 'JetBrains Mono', monospace;
    color: var(--blue);
    opacity: 0.5;
    flex-shrink: 0;
    font-size: 12px;
    margin-top: 1px;
  }

  /* ══════════════════════════════════════
     SIDEBAR
  ══════════════════════════════════════ */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 88px;
  }

  .sidebar-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  /* CTA card */
  .sidebar-card--cta {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--surface-2);
  }

  .sidebar-cta-status {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .sidebar-cta-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--green);
    animation: ctapulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes ctapulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }

  .sidebar-cta-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green);
    opacity: 0.8;
  }

  .sidebar-cta-heading {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-2);
  }

  .sidebar-cta-body {
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.65;
  }

  .sidebar-cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: var(--blue);
    color: #111315;
    font-weight: 700;
    font-size: 13px;
    border-radius: 2px;
    padding: 10px 16px;
    transition: background 0.2s;
    text-decoration: none;
    margin-top: 4px;
  }

.sidebar-cta-btn:hover { background: var(--blue-dim); }

  /* Services nav */
  .sidebar-nav-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-nav-list {
    display: flex;
    flex-direction: column;
  }

  .sidebar-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-3);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s, color 0.15s;
  }

  .sidebar-nav-item:last-child { border-bottom: none; }

  .sidebar-nav-item:hover {
    background: var(--surface-2);
    color: var(--text-2);
  }

  .sidebar-nav-item--active {
    background: var(--surface-2);
    color: var(--blue);
  }

  .sidebar-nav-idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--text-3);
    opacity: 0.3;
    flex-shrink: 0;
    width: 18px;
  }

  .sidebar-nav-title { flex: 1; }

  .sidebar-nav-arrow {
    flex-shrink: 0;
    opacity: 0.2;
    transition: opacity 0.15s;
  }

  .sidebar-nav-item:hover .sidebar-nav-arrow,
  .sidebar-nav-item--active .sidebar-nav-arrow {
    opacity: 1;
    color: var(--blue);
  }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero-annotation--tr,
    .hero-annotation--bl { display: none; }

    .sidebar { grid-template-columns: 1fr; }

    .step-detail { padding-left: 0; }
  }
</style>
