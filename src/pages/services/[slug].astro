---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/ui/CtaBanner.astro';
import { getServiceBySlug, getAllServiceSlugs, getCaseStudies, urlForImage } from '../../lib/sanity';
import { serviceSamples, caseStudySamples } from '../../lib/sampleData';

export async function getStaticPaths() {
  try {
    const slugs = await getAllServiceSlugs();
    if (slugs.length > 0) {
      return slugs.map((s: { slug: string }) => ({ params: { slug: s.slug } }));
    }
  } catch (_) {}
  return Object.keys(serviceSamples).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

let service: any = null;
let caseStudies: any[] = [];
try {
  [service, caseStudies] = await Promise.all([
    getServiceBySlug(slug),
    getCaseStudies(),
  ]);
} catch (_) {}

// Fall back to sample data
const sample = serviceSamples[slug];
const data = {
  title:        service?.title           ?? sample?.title        ?? slug,
  description:  service?.description     ?? sample?.description  ?? '',
  intro:        sample?.intro            ?? [],
  image:        sample?.image            ?? null,
  imageLabel:   sample?.imageLabel        ?? null,
  approach:     service?.approach?.length > 0
                  ? service.approach
                  : sample?.approach ?? [],
  ctaHeadline:  service?.ctaHeadline ?? null,
};

// Related work — case studies that include this service
const serviceTitle = data.title;
const sampleCaseStudies = Object.entries(caseStudySamples).map(([csSlug, cs]) => ({
  slug: csSlug,
  title: cs.title,
  excerpt: cs.excerpt,
  industry: cs.industry,
  services: cs.services,
}));

const allCases = caseStudies.length > 0
  ? caseStudies.map((cs: any) => ({
      slug: cs.slug?.current,
      title: cs.title,
      excerpt: cs.excerpt,
      industry: cs.industry,
      coverImage: cs.coverImage,
      services: cs.services ?? [],
    }))
  : sampleCaseStudies;

const relatedWork = allCases
  .filter((cs: any) => cs.services?.some((s: any) => {
    const svcName = typeof s === 'string' ? s : s?.title ?? '';
    return svcName === serviceTitle;
  }))
  .slice(0, 3);

const serviceOrder = ['web-design', 'paid-ads', 'seo', 'content-creation', 'strategy-consulting', 'ai-integration'];
const currentIdx = serviceOrder.indexOf(slug);
const moduleId = `SVC-${String(currentIdx + 1).padStart(3, '0')}`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      'name': data.title,
      'description': data.description,
      'provider': { '@id': 'https://railshop.co/#organization' },
      'serviceType': 'Digital Marketing',
      'areaServed': { '@type': 'Country', 'name': 'United States' },
      'url': `https://railshop.co/services/${slug}`,
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://railshop.co' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Services', 'item': 'https://railshop.co/services' },
        { '@type': 'ListItem', 'position': 3, 'name': data.title, 'item': `https://railshop.co/services/${slug}` },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${data.title} — Railshop`}
  description={service?.seo?.metaDescription ?? data.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <svg class="hero-bg-svg" viewBox="0 0 1400 480" fill="none" preserveAspectRatio="xMidYMid slice">
        <path class="hero-arc-main"      d="M -80 520 Q 380 40 860 260 Q 1060 390 1480 180" stroke-width="1" fill="none"/>
        <path class="hero-arc-secondary" d="M -80 560 Q 360 60 830 290 Q 1030 420 1480 220" stroke-width="1" fill="none"/>
        <circle class="hero-bg-star" cx="885"  cy="44"  r="1.5"/>
        <circle class="hero-bg-star" cx="1102" cy="29"  r="1"/>
        <circle class="hero-bg-star" cx="1248" cy="74"  r="2"/>
        <circle class="hero-bg-star" cx="1342" cy="42"  r="1.5"/>
        <circle class="hero-bg-star" cx="1064" cy="142" r="1"/>
        <circle class="hero-bg-star" cx="1285" cy="184" r="1.5"/>
        <circle class="hero-bg-star" cx="950"  cy="244" r="1"/>
        <circle class="hero-bg-star" cx="1380" cy="260" r="2"/>
        <circle class="hero-bg-star" cx="822"  cy="352" r="1"/>
        <circle class="hero-bg-star" cx="1154" cy="384" r="1.5"/>
        <circle class="hero-bg-star" cx="684"  cy="80"  r="1"/>
        <path class="hero-bg-star-4pt" d="M 1022 56 L 1023.8 60.2 L 1028 62 L 1023.8 63.8 L 1022 68 L 1020.2 63.8 L 1016 62 L 1020.2 60.2 Z"/>
        <path class="hero-bg-star-4pt" d="M 1220 146 L 1221.5 149.5 L 1225 151 L 1221.5 152.5 L 1220 156 L 1218.5 152.5 L 1215 151 L 1218.5 149.5 Z"/>
        <path class="hero-bg-star-4pt" d="M 870 316 L 871.8 320.2 L 876 322 L 871.8 323.8 L 870 328 L 868.2 323.8 L 864 322 L 868.2 320.2 Z"/>
      </svg>
      <div class="hero-glow"></div>
    </div>

    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: SERVICES</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">{moduleId}</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">// CHANNEL DETAIL</span>
    </div>

    <div class="container">
      <div class="breadcrumb">
        <a href="/services" class="breadcrumb-link">Services</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{data.title}</span>
      </div>

      <div class="hero-inner">
        <div class="hero-left">
          <h1 class="hero-headline">{data.title}</h1>
          <p class="hero-sub">{data.description}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. OVERVIEW — asymmetric grid: prose + image
       ============================================================ -->
  <section class="overview-section">
    <div class="container">
      <div class="overview-grid">
      <div class="overview-prose">
        <h2 class="overview-title">What this looks like.</h2>
        {data.intro.map((paragraph) => (
          <p class="overview-copy">{paragraph}</p>
        ))}
      </div>

      <div class="overview-photo-wrap">
        <div class="overview-photo">
          <div class="img-placeholder">
            <svg class="img-placeholder-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          </div>
        </div>
      </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. HOW WE WORK — interactive step rows
       ============================================================ -->
  {data.approach.length > 0 && (
    <section class="process-section">
      <div class="container">
        <div class="process-header">
          <h2 class="process-title">A process built around your business.</h2>
          <p class="process-sub">Every engagement follows the same principle: understand first, then build, then refine.</p>
        </div>

        <div class="process-rows">
          {data.approach.map((step, i) => (
            <div class="process-row">
              <div class="process-row-top">
                <span class="process-idx">{String(i + 1).padStart(2, '0')}</span>
                <h3 class="process-step-title">{step.step}</h3>
              </div>
              <p class="process-step-detail">{step.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================================
       4. RELATED WORK
       ============================================================ -->
  {relatedWork.length > 0 && (
    <section class="related-section">
      <div class="container">
        <div class="related-header">
          <span class="related-label">// RELATED WORK</span>
          <div class="related-rule"></div>
        </div>
        <div class="related-grid">
          {relatedWork.map((cs: any) => {
            const imgSrc = cs.coverImage ? urlForImage(cs.coverImage).width(640).url() : null;
            return (
              <a href={`/work/${cs.slug}`} class="related-card">
                <div class="related-image">
                  <div class="img-placeholder">
                    <svg class="img-placeholder-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                  </div>
                </div>
                <div class="related-content">
                  <h3 class="related-title">{cs.title}</h3>
                  {cs.excerpt && <p class="related-excerpt">{cs.excerpt}</p>}
                  <span class="related-cta">
                    View case study
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================================
       5. CTA BANNER
       ============================================================ -->
  <CtaBanner
    title={data.ctaHeadline ?? `Ready to put ${data.title} to work for your business?`}
    subtitle="We take on a limited number of new clients. Let's talk about whether we're the right fit."
    secondaryText="All Services"
    secondaryHref="/services"
    secondaryVariant="link"
  />

</BaseLayout>

<style>
  /* ══════════════════════════════════════
     1. HERO
  ══════════════════════════════════════ */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-bg-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-arc-main      { stroke: rgba(56, 182, 255, 0.10); }
  .hero-arc-secondary { stroke: rgba(56, 182, 255, 0.05); }
  .hero-bg-star       { fill:   rgba(56, 182, 255, 0.18); }
  .hero-bg-star-4pt   { fill:   rgba(56, 182, 255, 0.14); }

  .hero-glow {
    position: absolute;
    top: -40px;
    left: -5%;
    width: 50%;
    height: 80%;
    background: radial-gradient(ellipse at 30% 40%, rgba(56, 182, 255, 0.045) 0%, transparent 65%);
  }

  .hero-annotation {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    pointer-events: none;
    z-index: 2;
  }

  .hero-annotation--tr { top: 20px; right: 32px; }
  .hero-annotation--bl { bottom: 20px; left: 32px; }
  .anno-code { color: var(--blue); opacity: 0.8; }
  .anno-sep  { opacity: 0.3; }

  .breadcrumb {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-5) 0;
    font-size: 12px;
    border-bottom: 1px solid var(--border);
  }

  .breadcrumb-link { color: var(--text-3); transition: color 0.15s; }
  .breadcrumb-link:hover { color: var(--blue); }
  .breadcrumb-sep { color: var(--border-2); }
  .breadcrumb-current { color: var(--text-3); }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding: var(--space-14) 0 var(--space-16);
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-headline { max-width: 520px; }

  .hero-sub {
    font-size: var(--fs-body);
    color: var(--text-3);
    max-width: 480px;
    line-height: var(--lh-body);
  }

  /* ══════════════════════════════════════
     2. OVERVIEW — asymmetric grid + image
  ══════════════════════════════════════ */
  .overview-section {
  }

  .overview-grid {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: var(--space-16);
    align-items: start;
    padding: var(--space-16) 0 var(--space-20);
  }

  .overview-prose {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .overview-title {
    font-size: 20px;
    font-weight: var(--fw-bold);
    color: var(--text-2);
    letter-spacing: var(--ls-snug);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-2);
  }

  .overview-copy {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.8;
  }

  /* Image tile — matches about page story photo */
  .overview-photo-wrap {
    position: relative;
    height: 100%;
  }

  .overview-photo {
    position: relative;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    height: 100%;
    min-height: 320px;
  }

  .overview-photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .overview-photo-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 14px 16px;
    background: linear-gradient(transparent, rgba(0,0,0,0.55));
  }

  .overview-photo-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }

  /* Corner tick marks */
  .ov-tick {
    position: absolute;
    width: 10px;
    height: 10px;
    pointer-events: none;
    z-index: 2;
  }

  .ov-tick--tl { top: 8px; left: 8px; border-top: 1px solid var(--border-2); border-left: 1px solid var(--border-2); opacity: 0.5; }
  .ov-tick--tr { top: 8px; right: 8px; border-top: 1px solid var(--border-2); border-right: 1px solid var(--border-2); opacity: 0.5; }
  .ov-tick--bl { bottom: 8px; left: 8px; border-bottom: 1px solid var(--border-2); border-left: 1px solid var(--border-2); opacity: 0.5; }
  .ov-tick--br { bottom: 8px; right: 8px; border-bottom: 1px solid var(--border-2); border-right: 1px solid var(--border-2); opacity: 0.5; }

  /* ══════════════════════════════════════
     3. HOW WE WORK — step rows
  ══════════════════════════════════════ */
  .process-section {
    background: radial-gradient(ellipse 80% 60% at 50% 100%, rgba(56, 182, 255, 0.03) 0%, transparent 70%);
  }

  .process-header {
    padding: var(--space-16) 0 var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    max-width: 520px;
  }

  .process-title {
    font-size: clamp(26px, 3.5vw, 38px);
    font-weight: var(--fw-black);
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .process-sub {
    font-size: var(--fs-body);
    color: var(--text-3);
    line-height: 1.7;
  }

  .process-rows {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    margin-bottom: var(--space-20);
  }

  .process-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-8);
    border-bottom: 1px solid var(--border);
    position: relative;
    transition: background 0.2s ease;
  }

  .process-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--blue);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .process-row:last-child { border-bottom: none; }

  .process-row:hover { background: var(--surface); }
  .process-row:hover::before { opacity: 1; }

  .process-row-top {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
  }

  .process-idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--text-3);
    opacity: 0.35;
    flex-shrink: 0;
    width: 20px;
  }

  .process-step-title {
    font-size: 15px;
    font-weight: var(--fw-bold);
    color: var(--text-2);
    letter-spacing: var(--ls-snug);
    transition: color 0.2s ease;
  }

  .process-row:hover .process-step-title { color: var(--blue); }

  .process-step-detail {
    font-size: var(--fs-body-sm);
    color: var(--text-3);
    line-height: var(--lh-body);
    padding-left: 36px;
  }

  /* ══════════════════════════════════════
     4. RELATED WORK
  ══════════════════════════════════════ */
  .related-section {
    border-top: 1px solid var(--border);
    padding: var(--space-14) 0 var(--space-20);
  }

  .related-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .related-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.65;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .related-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .related-card:hover {
    border-color: var(--border-2);
    transform: translateY(-2px);
  }

  .related-image {
    position: relative;
    height: 160px;
    background: var(--surface-3);
    overflow: hidden;
    flex-shrink: 0;
  }

  .related-image-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }

  .related-card:hover .related-image-img { transform: scale(1.03); }

  .related-image-placeholder {
    width: 100%;
    height: 100%;
    background: var(--surface-3);
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
  }

  .img-placeholder-icon {
    color: var(--text-3);
    opacity: 0.15;
  }

  .related-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: 18px 20px 20px;
    flex: 1;
  }

  .related-title {
    font-size: var(--fs-body-sm);
    font-weight: var(--fw-bold);
    color: var(--text-2);
    line-height: 1.35;
    transition: color 0.15s ease;
  }

  .related-card:hover .related-title { color: var(--blue); }

  .related-excerpt {
    font-size: 12px;
    color: var(--text-3);
    line-height: var(--lh-body);
    flex: 1;
  }

  .related-cta {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: var(--fs-label);
    font-weight: var(--fw-semi);
    color: var(--text-3);
    margin-top: var(--space-1);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .related-card:hover .related-cta {
    color: var(--blue);
    transform: translateX(3px);
  }

  /* HUD overlay on card images */
  .card-hud {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 6px 10px;
    background: linear-gradient(to top, rgba(17,19,21,0.85) 0%, transparent 100%);
  }

  .hud-cat {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--fs-micro);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-2);
    background: rgba(42, 47, 51, 0.8);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-sm);
    padding: 2px 6px;
    backdrop-filter: blur(4px);
  }

  /* Corner brackets on card images */
  .img-corner {
    position: absolute;
    width: 10px;
    height: 10px;
    pointer-events: none;
    opacity: 0.5;
  }

  .img-corner--tl { top: 8px;    left: 8px;  border-top: 1px solid var(--blue); border-left: 1px solid var(--blue); }
  .img-corner--tr { top: 8px;    right: 8px; border-top: 1px solid var(--blue); border-right: 1px solid var(--blue); }
  .img-corner--bl { bottom: 30px; left: 8px;  border-bottom: 1px solid var(--blue); border-left: 1px solid var(--blue); }
  .img-corner--br { bottom: 30px; right: 8px; border-bottom: 1px solid var(--blue); border-right: 1px solid var(--blue); }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .overview-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .overview-photo { min-height: 280px; }
  }

  @media (max-width: 900px) and (min-width: 769px) {
    .related-grid { grid-template-columns: 1fr 1fr; }
    .related-grid > :last-child { display: none; }
  }

  @media (max-width: 768px) {
    .hero-annotation--tr,
    .hero-annotation--bl { display: none; }

    .process-step-detail { padding-left: 0; }
    .process-row { padding: var(--space-5) var(--space-5); }

    .related-grid { grid-template-columns: 1fr; }
  }

</style>
