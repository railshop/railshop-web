---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import CtaBanner from '../../components/ui/CtaBanner.astro';
import { getCaseStudyBySlug, getAllCaseStudySlugs, urlForImage } from '../../lib/sanity';
import { caseStudySamples } from '../../lib/sampleData';

export async function getStaticPaths() {
  try {
    const slugs = await getAllCaseStudySlugs();
    if (slugs.length > 0) {
      return slugs.map((s: { slug: string }) => ({ params: { slug: s.slug } }));
    }
  } catch (_) {}
  return Object.keys(caseStudySamples).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

let sanityCs: any = null;
try {
  sanityCs = await getCaseStudyBySlug(slug);
} catch (_) {}

const sample = caseStudySamples[slug];
const cs = {
  title:       sanityCs?.title       ?? sample?.title    ?? 'Case Study',
  client:      sanityCs?.client      ?? sample?.client   ?? 'Confidential Client',
  industry:    sanityCs?.industry    ?? sample?.industry ?? '',
  excerpt:     sanityCs?.excerpt     ?? sample?.excerpt  ?? '',
  // stats replaces old `results` string — use Sanity stats array, fall back to sample outcomes
  outcomes:    sanityCs?.stats?.length > 0
                 ? sanityCs.stats
                 : sample?.outcomes ?? [],
  duration:    sample?.duration      ?? '',
  services:    sanityCs?.services?.length > 0
                 ? sanityCs.services
                 : sample?.services ?? [],
  challenge:   sanityCs?.challenge   ?? sample?.challenge  ?? '',
  approach:    sanityCs?.approach?.length > 0
                 ? sanityCs.approach
                 : sample?.approach ?? [],
  testimonial: sanityCs?.testimonial ?? sample?.testimonial,
};

// Testimonial — supports both Sanity (name/role) and sampleData (author/role) shapes
const testimonialAuthor = cs.testimonial?.name ?? cs.testimonial?.author ?? '';
const testimonialRole   = cs.testimonial?.role ?? '';

const caseStudyGraphNodes: Record<string, unknown>[] = [
  {
    '@type': 'Article',
    'articleSection': 'Case Study',
    'headline': cs.title,
    'description': cs.excerpt,
    'url': `https://railshop.co/work/${slug}`,
    'author': { '@id': 'https://railshop.co/#organization' },
    'publisher': { '@id': 'https://railshop.co/#organization' },
    'isPartOf': { '@id': 'https://railshop.co/#website' },
    ...(cs.industry ? { 'about': { '@type': 'Thing', 'name': cs.industry } } : {}),
  },
  {
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://railshop.co' },
      { '@type': 'ListItem', 'position': 2, 'name': 'Work', 'item': 'https://railshop.co/work' },
      { '@type': 'ListItem', 'position': 3, 'name': cs.title, 'item': `https://railshop.co/work/${slug}` },
    ],
  },
];

const testimonialQuote = cs.testimonial?.quote ?? '';
if (testimonialQuote && testimonialAuthor) {
  caseStudyGraphNodes.push({
    '@type': 'Review',
    'reviewBody': testimonialQuote,
    'author': {
      '@type': 'Person',
      'name': testimonialAuthor,
      ...(testimonialRole ? { 'jobTitle': testimonialRole } : {}),
    },
    'itemReviewed': { '@id': 'https://railshop.co/#organization' },
  });
}

const caseStudySchema = {
  '@context': 'https://schema.org',
  '@graph': caseStudyGraphNodes,
};

// Module ID from slug index
const allSlugs = Object.keys(caseStudySamples);
const slugIdx = allSlugs.indexOf(slug);
const moduleId = `CS-${String(slugIdx + 1).padStart(3, '0')}`;
const shortLabel = cs.industry ? cs.industry.toUpperCase() : 'CLIENT';

// Industry icon paths (SVG inner paths)
const industryIcons: Record<string, string> = {
  'HVAC':         '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  'LANDSCAPING':  '<path d="M12 22V12"/><path d="M5 4a9 9 0 0114 0"/><path d="M5 4c0 6 7 8 7 8s7-2 7-8"/>',
  'EXCAVATION':   '<path d="M2 22 16 8"/><path d="M3.47 12.53 5 11l1.53 1.53a3.5 3.5 0 010 4.94L5 19l-1.53-1.53a3.5 3.5 0 010-4.94z"/><path d="M7.47 8.53 9 7l1.53 1.53a3.5 3.5 0 010 4.94L9 15l-1.53-1.53a3.5 3.5 0 010-4.94z"/>',
  'ROOFING':      '<polyline points="3 9 12 2 21 9"/><polyline points="9 22 9 13 15 13 15 22"/><line x1="3" y1="9" x2="3" y2="22"/><line x1="21" y1="9" x2="21" y2="22"/>',
  'PLUMBING':     '<path d="M20 7h-9a2 2 0 00-2 2v9a2 2 0 002 2h9a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M14 7V5a2 2 0 00-2-2H5a2 2 0 00-2 2v7a2 2 0 002 2h2"/>',
};
const industryKey = cs.industry?.toUpperCase();
const iconPaths = industryIcons[industryKey] ?? '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>';

const initials = testimonialAuthor
  ? testimonialAuthor.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase()
  : 'CL';
const testimonialPhotoUrl = sanityCs?.testimonial?.photo?.asset
  ? urlForImage(sanityCs.testimonial.photo).width(72).height(72).url()
  : null;
---

<BaseLayout
  title={`${cs.title} — Railshop Work`}
  description={sanityCs?.seo?.metaDescription ?? cs.excerpt}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(caseStudySchema)} />
  </Fragment>

  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <svg class="hero-bg-svg" viewBox="0 0 1400 480" fill="none" preserveAspectRatio="xMidYMid slice">
        <path class="hero-arc-main"      d="M -80 520 Q 380 40 860 260 Q 1060 390 1480 180" stroke-width="1" fill="none"/>
        <path class="hero-arc-secondary" d="M -80 560 Q 360 60 830 290 Q 1030 420 1480 220" stroke-width="1" fill="none"/>
        <circle class="hero-bg-star" cx="885"  cy="44"  r="1.5"/>
        <circle class="hero-bg-star" cx="1102" cy="29"  r="1"/>
        <circle class="hero-bg-star" cx="1248" cy="74"  r="2"/>
        <circle class="hero-bg-star" cx="1342" cy="42"  r="1.5"/>
        <circle class="hero-bg-star" cx="1064" cy="142" r="1"/>
        <circle class="hero-bg-star" cx="1285" cy="184" r="1.5"/>
        <circle class="hero-bg-star" cx="950"  cy="244" r="1"/>
        <circle class="hero-bg-star" cx="1380" cy="260" r="2"/>
        <circle class="hero-bg-star" cx="822"  cy="352" r="1"/>
        <circle class="hero-bg-star" cx="1154" cy="384" r="1.5"/>
        <circle class="hero-bg-star" cx="684"  cy="80"  r="1"/>
        <path class="hero-bg-star-4pt" d="M 1022 56 L 1023.8 60.2 L 1028 62 L 1023.8 63.8 L 1022 68 L 1020.2 63.8 L 1016 62 L 1020.2 60.2 Z"/>
        <path class="hero-bg-star-4pt" d="M 1220 146 L 1221.5 149.5 L 1225 151 L 1221.5 152.5 L 1220 156 L 1218.5 152.5 L 1215 151 L 1218.5 149.5 Z"/>
        <path class="hero-bg-star-4pt" d="M 870 316 L 871.8 320.2 L 876 322 L 871.8 323.8 L 870 328 L 868.2 323.8 L 864 322 L 868.2 320.2 Z"/>
      </svg>
      <div class="hero-glow"></div>
    </div>

    <!-- Corner annotations -->
    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: CASE STUDIES</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">{moduleId}</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">// ENGAGEMENT DETAIL</span>
    </div>

    <div class="container">
      <!-- Breadcrumb inside hero -->
      <div class="breadcrumb">
        <a href="/work" class="breadcrumb-link">Work</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{cs.title}</span>
      </div>

      <div class="hero-inner">
        <div class="hero-left">
          <h1 class="hero-headline">{cs.title}</h1>
          <p class="hero-sub">{cs.excerpt}</p>

          {cs.outcomes.length > 0 && (
            <div class="result-pill">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                <polyline points="17 6 23 6 23 12"/>
              </svg>
              <span class="result-pill-text">{cs.outcomes[0].value} {cs.outcomes[0].label}</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       3. CONTENT — main + sidebar
       ============================================================ -->
  <div class="content-wrap">
    <div class="container content-grid">

      <!-- Main column -->
      <div class="main-col">

        <!-- Challenge -->
        {cs.challenge && (
          <div class="content-block">
            <div class="block-header">
              <h2 class="block-title">The Challenge</h2>
            </div>
            <p class="body-copy">{cs.challenge}</p>
          </div>
        )}

        <!-- Key Results -->
        {cs.outcomes.length > 0 && (
          <div class="content-block">
            <div class="block-header">
              <h2 class="block-title">Results</h2>
            </div>
            <div class="results-grid">
              {cs.outcomes.map((o) => (
                <div class="result-cell">
                  <span class="result-value">{o.value}</span>
                  <span class="result-label">{o.label}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Photo grid -->
        {cs.challenge && (
          <div class="content-block">
            <div class="block-header">
              <h2 class="block-title">From the Engagement</h2>
            </div>
            <div class="photo-grid">
              {[0,1,2,3].map(() => (
                <div class="photo-tile">
                  <div class="img-placeholder">
                    <svg class="img-placeholder-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Approach -->
        {cs.approach.length > 0 && (
          <div class="content-block">
            <div class="block-header">
              <h2 class="block-title">Our Approach</h2>
            </div>
            <div class="approach-steps">
              {cs.approach.map((block, i) => (
                <div class="approach-step">
                  <div class="step-top">
                    <span class="step-number">{String(i + 1).padStart(2, '0')}</span>
                    <h3 class="step-heading">{block.heading}</h3>
                  </div>
                  <p class="step-detail">{block.body}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Testimonial -->
        {cs.testimonial && (
          <div class="content-block">
            <div class="block-header">
              <h2 class="block-title">In Their Words</h2>
            </div>
            <blockquote class="testimonial">
              <p class="testimonial-quote">"{cs.testimonial.quote}"</p>
              <footer class="testimonial-footer">
                <div class="testimonial-avatar" aria-hidden="true">
                  {testimonialPhotoUrl
                    ? <img src={testimonialPhotoUrl} alt={testimonialAuthor} class="testimonial-photo" />
                    : <span class="testimonial-initials">{initials}</span>
                  }
                </div>
                <div class="testimonial-attribution">
                  <span class="testimonial-author">{testimonialAuthor}</span>
                  <span class="testimonial-role">{testimonialRole}</span>
                </div>
              </footer>
            </blockquote>
          </div>
        )}

      </div>

      <!-- Sidebar -->
      <aside class="sidebar">

        <!-- Project details card -->
        <div class="sidebar-card">
          <p class="sidebar-eyebrow">// PROJECT DETAILS</p>
          <div class="sidebar-details">
            {cs.client && (
              <div class="detail-row">
                <span class="detail-label">CLIENT</span>
                <span class="detail-value">{cs.client}</span>
              </div>
            )}
            {cs.industry && (
              <div class="detail-row">
                <span class="detail-label">INDUSTRY</span>
                <span class="detail-value">{cs.industry}</span>
              </div>
            )}
            {cs.services.length > 0 && (
              <div class="detail-row">
                <span class="detail-label">SERVICES</span>
                <div class="detail-tags">
                  {cs.services.map((svc) => <span class="tag">{svc}</span>)}
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <div class="sidebar-cta-status">
            <span class="sidebar-cta-dot"></span>
            <span class="sidebar-cta-label">Taking new clients</span>
          </div>
          <p class="sidebar-cta-heading">Want results like these?</p>
          <p class="sidebar-cta-body">Book a call and let's talk about what growth looks like for your business.</p>
          <a href="/contact#book-a-call" class="sidebar-cta-btn">
            Book a Call
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <!-- Back link -->
        <a href="/work" class="sidebar-back-link">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          All case studies
        </a>

      </aside>
    </div>
  </div>

  <!-- ============================================================
       4. CTA BANNER
       ============================================================ -->
  <CtaBanner
    title="Want results like these?"
    subtitle="We take on a limited number of new clients. Let's talk about whether we're the right fit."
    secondaryText="All Case Studies"
    secondaryHref="/work"
    secondaryVariant="link"
  />

</BaseLayout>

<style>
  /* ══════════════════════════════════════
     1. HERO
  ══════════════════════════════════════ */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-bg-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-arc-main      { stroke: rgba(56, 182, 255, 0.10); }
  .hero-arc-secondary { stroke: rgba(56, 182, 255, 0.05); }
  .hero-bg-star       { fill:   rgba(56, 182, 255, 0.18); }
  .hero-bg-star-4pt   { fill:   rgba(56, 182, 255, 0.14); }

.hero-glow {
    position: absolute;
    top: -40px;
    left: -5%;
    width: 50%;
    height: 80%;
    background: radial-gradient(ellipse at 30% 40%, rgba(56, 182, 255, 0.045) 0%, transparent 65%);
  }

  /* Corner annotations */
  .hero-annotation {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    pointer-events: none;
    z-index: 2;
  }

  .hero-annotation--tr { top: 20px; right: 32px; }
  .hero-annotation--bl { bottom: 20px; left: 32px; }
  .anno-code { color: var(--blue); opacity: 0.8; }
  .anno-sep  { opacity: 0.3; }

  /* Breadcrumb */
  .breadcrumb {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 20px 0;
    font-size: 12px;
    border-bottom: 1px solid var(--border);
  }

  .breadcrumb-link { color: var(--text-3); transition: color 0.15s; }
  .breadcrumb-link:hover { color: var(--blue); }
  .breadcrumb-sep { color: var(--border-2); }
  .breadcrumb-current {
    color: var(--text-3);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 420px;
  }

  /* Hero inner */
  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 56px 0 64px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .hero-headline {
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    max-width: 760px;
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--text-3);
    max-width: 580px;
    line-height: 1.75;
    margin-bottom: 28px;
  }

  /* Result pill */
  .result-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(52, 211, 153, 0.06);
    border: 1px solid rgba(52, 211, 153, 0.22);
    border-radius: 2px;
    padding: 8px 14px;
  }

  .result-pill-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--green);
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  /* ══════════════════════════════════════
     2. CONTENT AREA
  ══════════════════════════════════════ */
  .content-wrap { padding: 64px 0 80px; }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 64px;
    align-items: start;
  }

  .main-col {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  /* Content blocks */
  .content-block {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .block-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .block-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-2);
    letter-spacing: -0.01em;
  }

  .body-copy {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.8;
  }

  /* Key Results grid */
  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .result-cell {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 24px 20px;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .result-cell:last-child { border-right: none; }

  .result-value {
    font-size: 34px;
    font-weight: 800;
    color: var(--blue);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .result-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Photo grid */
  .photo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .photo-tile {
    position: relative;
    height: 210px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .photo-tile:hover { border-color: var(--border-2); }

  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
  }

  .img-placeholder-icon {
    color: var(--text-3);
    opacity: 0.15;
  }

  .photo-tile-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(56, 182, 255, 0.025) 0%, transparent 65%);
  }

  /* Corner ticks */
  .tick {
    position: absolute;
    pointer-events: none;
  }

  .tick--tl,
  .tick--tr,
  .tick--bl,
  .tick--br {
    width: 10px;
    height: 10px;
  }

  .tick--tl {
    top: 8px; left: 8px;
    border-top: 1px solid var(--border-2);
    border-left: 1px solid var(--border-2);
    opacity: 0.5;
  }

  .tick--tr {
    top: 8px; right: 8px;
    border-top: 1px solid var(--border-2);
    border-right: 1px solid var(--border-2);
    opacity: 0.5;
  }

  .tick--bl {
    bottom: 8px; left: 8px;
    border-bottom: 1px solid var(--border-2);
    border-left: 1px solid var(--border-2);
    opacity: 0.5;
  }

  .tick--br {
    bottom: 8px; right: 8px;
    border-bottom: 1px solid var(--border-2);
    border-right: 1px solid var(--border-2);
    opacity: 0.5;
  }

  /* Crosshair */
  .crosshair {
    position: relative;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 1;
  }

  .crosshair-h {
    position: absolute;
    width: 24px;
    height: 1px;
    background: var(--border-2);
    opacity: 0.4;
  }

  .crosshair-v {
    position: absolute;
    width: 1px;
    height: 24px;
    background: var(--border-2);
    opacity: 0.4;
  }

  .crosshair-dot {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--blue);
    opacity: 0.35;
  }

  .photo-tile-label {
    position: absolute;
    bottom: 14px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-3);
    opacity: 0.3;
    z-index: 1;
  }

  /* Approach steps */
  .approach-steps {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .approach-step {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    transition: border-color 0.2s;
  }

