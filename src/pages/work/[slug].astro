---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTag from '../../components/ui/SectionTag.astro';
import Button from '../../components/ui/Button.astro';
import { getCaseStudyBySlug, getAllCaseStudySlugs } from '../../lib/sanity';
import { caseStudySamples } from '../../lib/sampleData';

export async function getStaticPaths() {
  try {
    const slugs = await getAllCaseStudySlugs();
    if (slugs.length > 0) {
      return slugs.map((s: { slug: string }) => ({ params: { slug: s.slug } }));
    }
  } catch (_) {}
  return Object.keys(caseStudySamples).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

let sanityCs: any = null;
try {
  sanityCs = await getCaseStudyBySlug(slug);
} catch (_) {}

const sample = caseStudySamples[slug];
const cs = {
  title:       sanityCs?.title    ?? sample?.title    ?? 'Case Study',
  client:      sanityCs?.client   ?? sample?.client   ?? 'Confidential Client',
  industry:    sanityCs?.industry ?? sample?.industry ?? '',
  excerpt:     sanityCs?.excerpt  ?? sample?.excerpt  ?? '',
  results:     sanityCs?.results  ?? sample?.results  ?? '',
  duration:    sample?.duration   ?? '',
  services:    sample?.services   ?? [],
  challenge:   sample?.challenge  ?? '',
  approach:    sample?.approach   ?? [],
  outcomes:    sample?.outcomes   ?? [],
  testimonial: sample?.testimonial,
};
---

<BaseLayout
  title={`${cs.title} — Railshop Work`}
  description={sanityCs?.seo?.metaDescription ?? cs.excerpt}
>
  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <div class="container breadcrumb-inner">
      <a href="/work" class="breadcrumb-link">Work</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{cs.title}</span>
    </div>
  </div>

  <!-- Hero -->
  <section class="case-hero">
    <div class="container">
      <div class="case-hero-meta">
        {cs.industry && <span class="tag">{cs.industry}</span>}
        {cs.services.map((svc) => <span class="tag">{svc}</span>)}
      </div>
      <h1 class="case-title">{cs.title}</h1>
      <p class="case-excerpt">{cs.excerpt}</p>
      {cs.results && (
        <div class="case-result">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
            <polyline points="17 6 23 6 23 12"/>
          </svg>
          <span class="case-result-text">{cs.results}</span>
        </div>
      )}
    </div>
  </section>

  <!-- Outcomes bar -->
  {cs.outcomes.length > 0 && (
    <div class="outcomes-bar">
      <div class="container outcomes-inner">
        {cs.outcomes.map((o) => (
          <div class="outcome-stat">
            <span class="outcome-value">{o.value}</span>
            <span class="outcome-label">{o.label}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Body -->
  <div class="content-wrap">
    <div class="container content-grid">

      <div class="main-col">

        <!-- Challenge -->
        {cs.challenge && (
          <div class="content-section">
            <h2 class="section-h2">The Challenge</h2>
            <p class="body-copy">{cs.challenge}</p>
          </div>
        )}

        <!-- Photo grid -->
        {cs.challenge && (
          <div class="photo-section">
            <p class="photo-eyebrow">From the Engagement</p>
            <div class="photo-grid">
              {[1,2,3,4].map(() => (
                <div class="photo-tile">
                  <div class="photo-tile-glow" aria-hidden="true"></div>
                  <span class="photo-tile-label">Client Photo</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Approach -->
        {cs.approach.length > 0 && (
          <div class="content-section">
            <h2 class="section-h2">Our Approach</h2>
            <div class="approach-blocks">
              {cs.approach.map((block) => (
                <div class="approach-block">
                  <h3 class="approach-heading">{block.heading}</h3>
                  <p class="body-copy">{block.body}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Testimonial -->
        {cs.testimonial && (
          <blockquote class="testimonial">
            <p class="testimonial-quote">"{cs.testimonial.quote}"</p>
            <footer class="testimonial-footer">
              <div class="testimonial-avatar" aria-hidden="true">
                <span class="testimonial-initials">CL</span>
              </div>
              <div class="testimonial-attribution">
                <span class="testimonial-author">{cs.testimonial.author}</span>
                <span class="testimonial-role">{cs.testimonial.role}</span>
              </div>
            </footer>
          </blockquote>
        )}

      </div>

      <!-- Sidebar -->
      <aside class="sidebar">

        <!-- Project details card -->
        <div class="sidebar-card">
          <p class="sidebar-eyebrow">Project Details</p>
          <div class="sidebar-details">
            {cs.client && (
              <div class="detail-row">
                <span class="detail-label">Client</span>
                <span class="detail-value">{cs.client}</span>
              </div>
            )}
            {cs.duration && (
              <div class="detail-row">
                <span class="detail-label">Duration</span>
                <span class="detail-value">{cs.duration}</span>
              </div>
            )}
            {cs.services.length > 0 && (
              <div class="detail-row">
                <span class="detail-label">Services</span>
                <div class="detail-tags">
                  {cs.services.map((svc) => <span class="tag">{svc}</span>)}
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card">
          <p class="sidebar-eyebrow sidebar-eyebrow--blue">Want Results Like This?</p>
          <p class="sidebar-body">Book a call to discuss your program and see what's possible.</p>
          <a href="/contact#hubspot-meetings" class="sidebar-btn-link">Book a Call</a>
        </div>

        <a href="/work" class="sidebar-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          All case studies
        </a>
      </aside>

    </div>
  </div>

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container cta-inner">
      <SectionTag label="Let's Talk" />
      <h2 class="cta-title">Want results like these?</h2>
      <p class="cta-desc">We take on a limited number of new clients each quarter. Book a call to see if we're the right fit.</p>
      <div class="cta-buttons">
        <Button href="/contact#hubspot-meetings" variant="primary">Book a Call</Button>
        <Button href="/work" variant="secondary">All Case Studies</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb { border-bottom: 1px solid var(--border); background: var(--surface); }
  .breadcrumb-inner { display: flex; align-items: center; gap: 8px; padding: 14px 24px; font-size: 13px; }
  .breadcrumb-link { color: var(--text-3); transition: color 0.15s; }
  .breadcrumb-link:hover { color: var(--text); }
  .breadcrumb-sep { color: var(--border-2); }
  .breadcrumb-current { color: var(--text-3); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 360px; }

  /* Hero */
  .case-hero { padding: 64px 0 56px; border-bottom: 1px solid var(--border); }

  .case-hero-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }

  .case-title {
    font-size: clamp(28px, 4.5vw, 48px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.15;
    max-width: 800px;
    margin-bottom: 18px;
  }

  .case-excerpt {
    font-size: 17px;
    color: var(--text-3);
    max-width: 680px;
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .case-result {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(52, 211, 153, 0.06);
    border: 1px solid rgba(52, 211, 153, 0.2);
    border-radius: 8px;
    padding: 10px 16px;
    width: fit-content;
  }

  .case-result-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--green);
    font-weight: 500;
  }

  /* Outcomes bar */
  .outcomes-bar { background: var(--surface); border-bottom: 1px solid var(--border); }

  .outcomes-inner {
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 32px 24px;
    gap: 24px;
    flex-wrap: wrap;
  }

  .outcome-stat { display: flex; flex-direction: column; align-items: center; gap: 4px; }

  .outcome-value {
    font-size: 28px;
    font-weight: 800;
    color: var(--blue);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .outcome-label {
    font-size: 11px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
  }

  /* Content layout */
  .content-wrap { padding: 64px 0 80px; }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 64px;
    align-items: start;
  }

  .main-col { display: flex; flex-direction: column; gap: 56px; }

  .content-section { display: flex; flex-direction: column; gap: 24px; }

  .section-h2 {
    font-size: 22px;
    font-weight: 700;
    color: var(--text-2);
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }

  .body-copy { font-size: 15px; color: var(--text-3); line-height: 1.8; }

  /* Photo grid */
  .photo-section { display: flex; flex-direction: column; gap: 16px; }

  .photo-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
  }

  .photo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .photo-tile {
    position: relative;
    height: 220px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .photo-tile:hover { border-color: var(--border-2); }

  .photo-tile:hover .photo-tile-glow {
    background: radial-gradient(ellipse at center, rgba(56, 182, 255, 0.06) 0%, transparent 70%);
  }

  .photo-tile-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    transition: background 0.2s;
  }

  .photo-tile-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
    opacity: 0.5;
    position: relative;
    z-index: 1;
  }

  /* Approach */
  .approach-blocks { display: flex; flex-direction: column; gap: 36px; }

  .approach-heading {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-2);
    margin-bottom: 10px;
    position: relative;
    padding-left: 14px;
  }

  .approach-heading::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    bottom: 4px;
    width: 3px;
    background: var(--blue);
    border-radius: 2px;
  }

  /* Testimonial */
  .testimonial {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--blue);
    border-radius: 12px;
    padding: 28px 32px;
    margin: 0;
  }

  .testimonial-quote {
    font-size: 16px;
    color: var(--text);
    line-height: 1.75;
    font-style: italic;
    margin-bottom: 20px;
  }

  .testimonial-footer {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .testimonial-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--surface-2);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonial-initials {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text-3);
    font-weight: 500;
  }

  .testimonial-attribution { display: flex; flex-direction: column; gap: 2px; }
  .testimonial-author { font-size: 14px; font-weight: 600; color: var(--text-2); }
  .testimonial-role { font-size: 12px; color: var(--text-3); font-family: 'JetBrains Mono', monospace; }

  /* Sidebar */
  .sidebar { display: flex; flex-direction: column; gap: 16px; position: sticky; top: 88px; }

  .sidebar-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sidebar-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
  }

  .sidebar-eyebrow--blue { color: var(--blue); }

  .sidebar-details { display: flex; flex-direction: column; gap: 16px; }

  .detail-row { display: flex; flex-direction: column; gap: 6px; }

  .detail-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-3);
  }

  .detail-value { font-size: 13px; color: var(--text-2); font-weight: 500; line-height: 1.5; }

  .detail-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 2px; }

  .sidebar-body { font-size: 14px; color: var(--text-3); line-height: 1.65; }

  .sidebar-btn-link {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--blue);
    color: #111315;
    font-weight: 700;
    font-size: 14px;
    border-radius: 8px;
    padding: 10px 18px;
    transition: background 0.2s;
    text-decoration: none;
  }

  :global([data-theme="light"]) .sidebar-btn-link { color: #FFFFFF; }

  .sidebar-btn-link:hover { background: var(--blue-dim); }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-3);
    padding: 8px 0;
    transition: color 0.15s;
    text-decoration: none;
  }

  .sidebar-link:hover { color: var(--text); }

  /* CTA Banner */
  .cta-banner {
    position: relative;
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 80px 0;
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    top: -80px;
    right: -80px;
    width: 500px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(56, 182, 255, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .cta-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .cta-desc {
    font-size: 16px;
    color: var(--text-3);
    max-width: 480px;
    line-height: 1.7;
  }

  .cta-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  @media (max-width: 900px) {
    .content-grid { grid-template-columns: 1fr; }
    .sidebar { position: static; }
  }
</style>
