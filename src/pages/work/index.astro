---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTag from '../../components/ui/SectionTag.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import { getCaseStudies } from '../../lib/sanity';

let caseStudies: any[] = [];
try {
  caseStudies = await getCaseStudies();
} catch (_) {}

const displayCases = caseStudies.length > 0 ? caseStudies : [
  { _id: '1', title: 'From stagnant ROAS to category leadership in 90 days', client: 'Confidential Client', industry: 'E-Commerce', results: '3.2× ROAS improvement', excerpt: 'A DTC brand with strong product but a paid media program that had plateaued. We rebuilt the architecture and introduced a systematic creative testing cadence.', slug: { current: 'ecom-roas-turnaround' } },
  { _id: '2', title: 'Scaling a SaaS brand from $40K to $200K/mo in paid social', client: 'Confidential Client', industry: 'SaaS', results: '5× spend scale, stable CPA', excerpt: 'LinkedIn + Meta program for a B2B SaaS brand entering a new market segment. Full-funnel strategy from awareness to demo-booked.', slug: { current: 'saas-paid-social-scale' } },
  { _id: '3', title: 'Building a measurement foundation for a multi-location retailer', client: 'Confidential Client', industry: 'Retail', results: '40% improvement in attribution accuracy', excerpt: 'GA4 implementation, offline conversion imports, and custom dashboards that finally connected ad spend to in-store revenue.', slug: { current: 'retail-measurement' } },
];
---

<BaseLayout title="Work — Railshop" description="Case studies from Railshop. See how we've helped brands scale paid media programs and drive measurable growth.">
  <!-- Header -->
  <section class="page-hero">
    <div class="container">
      <SectionTag label="Case Studies" />
      <h1 class="page-title">Our work</h1>
      <p class="page-desc">
        A selection of client engagements. Details are anonymised where requested.
        We're happy to share more specifics on a call.
      </p>
    </div>
  </section>

  <!-- Case Study Grid -->
  <section class="section">
    <div class="container">
      <div class="cases-grid stagger">
        {displayCases.map((cs) => (
          <Card href={`/work/${cs.slug.current}`} animate class="case-card">
            <div class="case-meta">
              <span class="tag">{cs.industry}</span>
            </div>
            <h2 class="case-title">{cs.title}</h2>
            <p class="case-excerpt">{cs.excerpt}</p>
            <div class="case-result">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              <span class="case-result-text">{cs.results}</span>
            </div>
            <span class="case-link">
              Read case study
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-strip">
    <div class="container cta-inner">
      <div>
        <h2 class="cta-title">Want results like these?</h2>
        <p class="cta-desc">Book a call and let's see what's possible for your program.</p>
      </div>
      <Button href="/contact#hubspot-meetings" variant="primary">Book a Call</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 80px 0 48px;
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    color: var(--text-2);
    margin-top: 16px;
    letter-spacing: -0.02em;
  }

  .page-desc {
    font-size: 17px;
    color: var(--text-3);
    max-width: 540px;
    line-height: 1.7;
    margin-top: 12px;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  :global(.case-card) {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 32px;
    text-decoration: none;
  }

  .case-meta { display: flex; gap: 8px; }
  .case-title { font-size: 20px; font-weight: 700; color: var(--text-2); line-height: 1.3; }
  .case-excerpt { font-size: 14px; color: var(--text-3); line-height: 1.8; flex: 1; }

  .case-result {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(52, 211, 153, 0.06);
    border: 1px solid rgba(52, 211, 153, 0.2);
    border-radius: 6px;
    padding: 6px 10px;
    width: fit-content;
  }

  .case-result-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--green);
    font-weight: 500;
  }

  .case-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--blue);
    font-weight: 600;
  }

  .cta-strip {
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
    padding-top: 48px;
    padding-bottom: 48px;
  }

  .cta-title { font-size: 22px; font-weight: 700; color: var(--text-2); }
  .cta-desc { font-size: 14px; color: var(--text-3); margin-top: 6px; }

  @media (max-width: 768px) {
    .cases-grid { grid-template-columns: 1fr; }
  }
</style>
