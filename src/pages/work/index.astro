---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTag from '../../components/ui/SectionTag.astro';
import Button from '../../components/ui/Button.astro';
import CtaBanner from '../../components/ui/CtaBanner.astro';
import PageHero from '../../components/ui/PageHero.astro';
import { getCaseStudies, getWorkPage } from '../../lib/sanity';

let caseStudies: any[] = [];
let workPage: any = null;
try {
  [caseStudies, workPage] = await Promise.all([getCaseStudies(), getWorkPage()]);
} catch (_) {}

// Position-based stat colors
const statColors = ['green', 'blue', 'gold'];

const displayCases = caseStudies.length > 0 ? caseStudies : [
  {
    _id: '1',
    industry: 'HVAC',
    title: 'From local HVAC company to regional market leader.',
    excerpt: 'Five years. Full digital buildout. 8x blended ROAS and 4x revenue growth.',
    stats: [
      { value: '8x',  label: 'Blended ROAS' },
      { value: '4x',  label: 'Revenue Growth' },
    ],
    slug: { current: 'hvac-market-leader' },
  },
  {
    _id: '2',
    industry: 'Landscaping',
    title: 'From zero digital presence to fully booked seasons.',
    excerpt: 'Built from the ground up: web, SEO, and paid ads. First page rankings in 90 days.',
    stats: [
      { value: '3.2x',    label: 'ROAS' },
      { value: '90 days', label: 'First Page Rankings' },
    ],
    slug: { current: 'landscaping-digital-presence' },
  },
  {
    _id: '3',
    industry: 'Excavation',
    title: 'Building a digital foundation for a growing excavation company.',
    excerpt: 'A new inbound channel from scratch. 68% lower cost-per-lead than their previous efforts.',
    stats: [
      { value: '68%',  label: 'Lower CPL vs. Industry Avg' },
    ],
    slug: { current: 'excavation-digital-foundation' },
  },
  {
    _id: '4',
    industry: 'Home Security',
    title: 'Scaling a home security brand beyond door-to-door.',
    excerpt: '2.8x lead volume. 47% lower CPL. A program built to run without constant intervention.',
    stats: [
      { value: '2.8x', label: 'Lead Volume' },
      { value: '47%',  label: 'Lower CPL' },
    ],
    slug: { current: 'home-security-digital-acquisition' },
  },
];

// Singleton content with fallbacks
const heroHeadline = workPage?.hero?.headline ?? null;
const heroSubhead  = workPage?.hero?.subhead  ?? null;
const ctaTitle     = workPage?.ctaBanner?.title    ?? 'Want results like these?';
const ctaSubtitle  = workPage?.ctaBanner?.subtitle ?? "We take on a limited number of new clients. Book a call to see if we're the right fit.";

const workIndexSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      'name': 'Work — Railshop',
      'url': 'https://railshop.co/work',
      'isPartOf': { '@id': 'https://railshop.co/#website' },
    },
    {
      '@type': 'ItemList',
      'name': 'Railshop Case Studies',
      'itemListElement': displayCases.map((c: any, i: number) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'name': c.title,
        'url': `https://railshop.co/work/${c.slug.current}`,
      })),
    },
  ],
};
---

<BaseLayout
  title={workPage?.seo?.metaTitle ?? 'Work — Railshop'}
  description={workPage?.seo?.metaDescription ?? "Case studies from Railshop. See how we've helped service businesses build their digital presence and drive real growth."}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(workIndexSchema)} />
  </Fragment>

  <!-- Hero -->
  <PageHero
    headline={heroHeadline ?? "A look at the work we're proud of."}
    sub={heroSubhead ?? "Numbers matter. So does context. Here's some of the work we've done and why it worked."}
    annoCode="SYS: WORK"
    annoExtra={`${displayCases.length} CASES ACTIVE`}
    annoModule="MODULE: WRK-001"
    illustration="planet"
  />

  <!-- Mission Log -->
  <section class="section">
    <div class="container">

      <!-- Case study grid -->
      <div class="cases-grid">
        {displayCases.map((cs, i) => (
          <a href={`/work/${cs.slug.current}`} class="case-card">

            <!-- Image -->
            <div class="card-image">
              <div class="img-placeholder">
                <svg class="img-placeholder-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            </div>

            <!-- Content -->
            <div class="card-body">
              <h2 class="card-title">{cs.title}</h2>
              <p class="card-excerpt">{cs.excerpt}</p>
              <div class="card-footer">
                <div class="card-metrics">
                  {(cs.stats ?? []).map((stat: { value: string; label: string }, si: number) => (
                    <span class={`metric metric--${statColors[si] ?? 'blue'}`}>
                      {stat.value} {stat.label}
                    </span>
                  ))}
                </div>
                <span class="card-cta">
                  Read case study
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </div>

          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <CtaBanner
    title={ctaTitle}
    subtitle={ctaSubtitle}
    secondaryText="Send a Message"
    secondaryHref="/contact#message-accordion"
  />

</BaseLayout>

<style>
  /* ── Cases Grid ──────────────────────────────── */
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .case-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .case-card:hover {
    border-color: var(--border-2);
    transform: translateY(-2px);
  }

  /* Image area */
  .card-image {
    position: relative;
    height: 220px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--surface-3);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }

  .case-card:hover .card-img {
    transform: scale(1.03);
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
  }

  .img-placeholder-icon {
    color: var(--text-3);
    opacity: 0.15;
  }

  /* HUD overlay strip at bottom of image */
  .card-hud {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 14px;
    background: linear-gradient(to top, rgba(17,19,21,0.85) 0%, transparent 100%);
  }

  .hud-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(248, 250, 252, 0.5);
  }

  .hud-sector {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-2);
    background: rgba(42, 47, 51, 0.8);
    border: 1px solid var(--border-2);
    border-radius: 2px;
    padding: 3px 8px;
    backdrop-filter: blur(4px);
  }

  /* Corner brackets on image */
  .img-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    pointer-events: none;
    opacity: 0.5;
  }

  .img-corner--tl { top: 10px; left: 10px; border-top: 1px solid var(--blue); border-left: 1px solid var(--blue); }
  .img-corner--tr { top: 10px; right: 10px; border-top: 1px solid var(--blue); border-right: 1px solid var(--blue); }
  .img-corner--bl { bottom: 36px; left: 10px; border-bottom: 1px solid var(--blue); border-left: 1px solid var(--blue); }
  .img-corner--br { bottom: 36px; right: 10px; border-bottom: 1px solid var(--blue); border-right: 1px solid var(--blue); }

  /* Card body */
  .card-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px 28px 28px;
    flex: 1;
  }

  .card-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-2);
    line-height: 1.35;
    transition: color 0.15s ease;
  }

  .case-card:hover .card-title {
    color: var(--blue);
  }

  .card-excerpt {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.8;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-top: 4px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .card-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .metric {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    padding: 4px 9px;
    border-radius: 2px;
    white-space: nowrap;
  }

  .metric--green {
    background: rgba(52, 211, 153, 0.08);
    color: var(--green);
    border: 1px solid rgba(52, 211, 153, 0.2);
  }

  .metric--blue {
    background: rgba(56, 182, 255, 0.08);
    color: var(--blue);
    border: 1px solid rgba(56, 182, 255, 0.2);
  }

  .metric--gold {
    background: rgba(251, 191, 36, 0.08);
    color: var(--gold);
    border: 1px solid rgba(251, 191, 36, 0.2);
  }

  .card-cta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-3);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .case-card:hover .card-cta {
    color: var(--blue);
    transform: translateX(3px);
  }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 768px) {
    .cases-grid { grid-template-columns: 1fr; }
  }
</style>
