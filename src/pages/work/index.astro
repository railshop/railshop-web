---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTag from '../../components/ui/SectionTag.astro';
import Button from '../../components/ui/Button.astro';
import CtaBanner from '../../components/ui/CtaBanner.astro';
import { getCaseStudies, getWorkPage } from '../../lib/sanity';

let caseStudies: any[] = [];
let workPage: any = null;
try {
  [caseStudies, workPage] = await Promise.all([getCaseStudies(), getWorkPage()]);
} catch (_) {}

// Position-based stat colors
const statColors = ['green', 'blue', 'gold'];

const displayCases = caseStudies.length > 0 ? caseStudies : [
  {
    _id: '1',
    industry: 'HVAC',
    title: 'From local HVAC company to regional market leader.',
    excerpt: 'Five years. Full digital buildout. 8x blended ROAS and 4x revenue growth.',
    stats: [
      { value: '8x',  label: 'Blended ROAS' },
      { value: '4x',  label: 'Revenue Growth' },
    ],
    slug: { current: 'hvac-market-leader' },
  },
  {
    _id: '2',
    industry: 'Landscaping',
    title: 'From zero digital presence to fully booked seasons.',
    excerpt: 'Built from the ground up: web, SEO, and paid ads. First page rankings in 90 days.',
    stats: [
      { value: '3.2x',    label: 'ROAS' },
      { value: '90 days', label: 'First Page Rankings' },
    ],
    slug: { current: 'landscaping-digital-presence' },
  },
  {
    _id: '3',
    industry: 'Excavation',
    title: 'Building a digital foundation for a growing excavation company.',
    excerpt: 'A new inbound channel from scratch. 68% lower cost-per-lead than their previous efforts.',
    stats: [
      { value: '68%',  label: 'Lower CPL vs. Industry Avg' },
    ],
    slug: { current: 'excavation-digital-foundation' },
  },
  {
    _id: '4',
    industry: 'Home Security',
    title: 'Scaling a home security brand beyond door-to-door.',
    excerpt: '2.8x lead volume. 47% lower CPL. A program built to run without constant intervention.',
    stats: [
      { value: '2.8x', label: 'Lead Volume' },
      { value: '47%',  label: 'Lower CPL' },
    ],
    slug: { current: 'home-security-digital-acquisition' },
  },
];

// Singleton content with fallbacks
const heroHeadline = workPage?.hero?.headline ?? null;
const heroSubhead  = workPage?.hero?.subhead  ?? null;
const ctaTitle     = workPage?.ctaBanner?.title    ?? 'Want results like these?';
const ctaSubtitle  = workPage?.ctaBanner?.subtitle ?? "We take on a limited number of new clients. Book a call to see if we're the right fit.";
---

<BaseLayout
  title={workPage?.seo?.metaTitle ?? 'Work — Railshop'}
  description={workPage?.seo?.metaDescription ?? "Case studies from Railshop. See how we've helped service businesses build their digital presence and drive real growth."}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <svg class="hero-grid-svg" viewBox="0 0 1400 480" fill="none" preserveAspectRatio="xMidYMid slice">
        <line class="grid-line" x1="350" y1="0" x2="350" y2="480"/>
        <line class="grid-line" x1="700" y1="0" x2="700" y2="480"/>
        <line class="grid-line" x1="1050" y1="0" x2="1050" y2="480"/>
        <line class="grid-line" x1="0" y1="160" x2="1400" y2="160"/>
        <line class="grid-line" x1="0" y1="320" x2="1400" y2="320"/>
        <path class="corner-bracket" d="M 32 24 L 32 60 M 32 24 L 68 24"/>
        <path class="corner-bracket" d="M 1368 456 L 1368 420 M 1368 456 L 1332 456"/>
        <line class="tick-mark" x1="350" y1="468" x2="350" y2="480"/>
        <line class="tick-mark" x1="700" y1="468" x2="700" y2="480"/>
        <line class="tick-mark" x1="1050" y1="468" x2="1050" y2="480"/>
      </svg>
      <div class="hero-glow"></div>
    </div>

    <!-- Corner annotations -->
    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: WORK</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">{displayCases.length} CASES ACTIVE</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">MODULE: WRK-001</span>
    </div>

    <div class="container">
      <div class="hero-inner">
        <div class="hero-left">
          {heroHeadline ? (
            <h1 class="hero-headline" set:html={heroHeadline.replace(/\n/g, '<br />')} />
          ) : (
            <h1 class="hero-headline">
              Real results for<br />
              <span class="hero-accent">service businesses.</span>
            </h1>
          )}
          <p class="hero-sub">
            {heroSubhead ?? 'Numbers matter. So does context. These are some of the programs we\'re proud of, and why they worked.'}
          </p>
        </div>
      </div>
    </div>

  </section>

  <!-- Mission Log -->
  <section class="section">
    <div class="container">

      <!-- Case study grid -->
      <div class="cases-grid">
        {displayCases.map((cs, i) => (
          <a href={`/work/${cs.slug.current}`} class="case-card">

            <!-- Image -->
            <div class="card-image">
              {cs._id === '1' ? (
                <img
                  src="/images/F&I Scaled 1500.jpg"
                  alt="HVAC business owner reviewing campaign results"
                  class="card-img"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="card-img-placeholder" aria-hidden="true">
                  <svg class="placeholder-grid" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                      <pattern id={`pg-${i}`} width="32" height="32" patternUnits="userSpaceOnUse">
                        <path d="M 32 0 L 0 0 0 32" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.4"/>
                      </pattern>
                    </defs>
                    <rect width="100%" height="100%" fill={`url(#pg-${i})`} />
                  </svg>
                  <span class="placeholder-label">Photo Coming Soon</span>
                </div>
              )}
              <!-- HUD overlay -->
              <div class="card-hud" aria-hidden="true">
                <span class="hud-id">CS-{String(i + 1).padStart(3, '0')}</span>
                <span class="hud-sector">{cs.industry}</span>
              </div>
              <!-- Corner brackets -->
              <span class="img-corner img-corner--tl" aria-hidden="true"></span>
              <span class="img-corner img-corner--tr" aria-hidden="true"></span>
              <span class="img-corner img-corner--bl" aria-hidden="true"></span>
              <span class="img-corner img-corner--br" aria-hidden="true"></span>
            </div>

            <!-- Content -->
            <div class="card-body">
              <h2 class="card-title">{cs.title}</h2>
              <p class="card-excerpt">{cs.excerpt}</p>
              <div class="card-footer">
                <div class="card-metrics">
                  {(cs.stats ?? []).map((stat: { value: string; label: string }, si: number) => (
                    <span class={`metric metric--${statColors[si] ?? 'blue'}`}>
                      {stat.value} {stat.label}
                    </span>
                  ))}
                </div>
                <span class="card-cta">
                  Read case study
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </div>

          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <CtaBanner
    title={ctaTitle}
    subtitle={ctaSubtitle}
    secondaryText="Send a Message"
    secondaryHref="/contact#message-accordion"
  />

</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-grid-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .grid-line {
    stroke: var(--border);
    stroke-width: 1;
    opacity: 0.4;
  }

  .corner-bracket {
    stroke: var(--border);
    stroke-width: 1.5;
    opacity: 0.35;
  }

  .tick-mark {
    stroke: var(--border);
    stroke-width: 1;
    opacity: 0.5;
  }

  .hero-glow {
    position: absolute;
    top: -40px;
    left: -5%;
    width: 50%;
    height: 80%;
    background: radial-gradient(ellipse at 30% 40%, rgba(56, 182, 255, 0.045) 0%, transparent 65%);
  }

  .hero-annotation {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-annotation--tr { top: 20px; right: 32px; }
  .hero-annotation--bl { bottom: 20px; left: 32px; }

  .anno-code { color: var(--blue); opacity: 0.8; }
  .anno-sep  { opacity: 0.3; }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 56px 0 64px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-accent { color: var(--blue); }

  .hero-headline {
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    max-width: 680px;
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--text-3);
    max-width: 540px;
    line-height: 1.75;
  }

  .section-rule {
    display: flex;
    align-items: center;
    height: 32px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    overflow: hidden;
  }

  .section-rule-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .section-rule-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.35;
    padding: 0 16px;
  }

  /* ── Cases Grid ──────────────────────────────── */
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .case-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .case-card:hover {
    border-color: var(--border-2);
    transform: translateY(-2px);
  }

  /* Image area */
  .card-image {
    position: relative;
    height: 220px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--surface-3);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }

  .case-card:hover .card-img {
    transform: scale(1.03);
  }

  .card-img-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--border-2);
  }

  .placeholder-grid {
    position: absolute;
    inset: 0;
  }

  .placeholder-label {
    position: relative;
    z-index: 1;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-3);
    opacity: 0.4;
  }

  /* HUD overlay strip at bottom of image */
  .card-hud {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 14px;
    background: linear-gradient(to top, rgba(17,19,21,0.85) 0%, transparent 100%);
  }

  .hud-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(248, 250, 252, 0.5);
  }

  .hud-sector {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-2);
    background: rgba(42, 47, 51, 0.8);
    border: 1px solid var(--border-2);
    border-radius: 2px;
    padding: 3px 8px;
    backdrop-filter: blur(4px);
  }

  /* Corner brackets on image */
  .img-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    pointer-events: none;
    opacity: 0.5;
  }

  .img-corner--tl { top: 10px; left: 10px; border-top: 1px solid var(--blue); border-left: 1px solid var(--blue); }
  .img-corner--tr { top: 10px; right: 10px; border-top: 1px solid var(--blue); border-right: 1px solid var(--blue); }
  .img-corner--bl { bottom: 36px; left: 10px; border-bottom: 1px solid var(--blue); border-left: 1px solid var(--blue); }
  .img-corner--br { bottom: 36px; right: 10px; border-bottom: 1px solid var(--blue); border-right: 1px solid var(--blue); }

  /* Card body */
  .card-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px 28px 28px;
    flex: 1;
  }

  .card-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-2);
    line-height: 1.35;
    transition: color 0.15s ease;
  }

  .case-card:hover .card-title {
    color: var(--blue);
  }

  .card-excerpt {
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.8;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-top: 4px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .card-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .metric {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    padding: 4px 9px;
    border-radius: 2px;
    white-space: nowrap;
  }

  .metric--green {
    background: rgba(52, 211, 153, 0.08);
    color: var(--green);
    border: 1px solid rgba(52, 211, 153, 0.2);
  }

  .metric--blue {
    background: rgba(56, 182, 255, 0.08);
    color: var(--blue);
    border: 1px solid rgba(56, 182, 255, 0.2);
  }

  .metric--gold {
    background: rgba(251, 191, 36, 0.08);
    color: var(--gold);
    border: 1px solid rgba(251, 191, 36, 0.2);
  }

  .card-cta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-3);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .case-card:hover .card-cta {
    color: var(--blue);
    transform: translateX(3px);
  }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 768px) {
    .cases-grid { grid-template-columns: 1fr; }
  }
</style>
