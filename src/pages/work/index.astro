---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTag from '../../components/ui/SectionTag.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import { getCaseStudies } from '../../lib/sanity';

let caseStudies: any[] = [];
try {
  caseStudies = await getCaseStudies();
} catch (_) {}

const displayCases = caseStudies.length > 0 ? caseStudies : [
  {
    _id: '1',
    industry: 'HVAC',
    title: 'From local HVAC company to regional market leader.',
    excerpt: 'A family-owned HVAC business stuck on word-of-mouth and slow seasons. We built their digital foundation — web, paid search, SEO, and content — and grew with them for five years.',
    stats: [
      { label: '8x Blended ROAS', color: 'green' },
      { label: '4x Revenue Growth', color: 'blue' },
    ],
    slug: { current: 'hvac-market-leader' },
  },
  {
    _id: '2',
    industry: 'Landscaping',
    title: 'From zero digital presence to fully booked seasons.',
    excerpt: 'A regional landscaping company with no website and no online visibility. We built their site, launched local SEO, and ran targeted paid search during peak seasons.',
    stats: [
      { label: '3.2x ROAS', color: 'green' },
      { label: 'First Page Rankings in 90 Days', color: 'blue' },
    ],
    slug: { current: 'landscaping-digital-presence' },
  },
  {
    _id: '3',
    industry: 'Excavation',
    title: 'Building a digital foundation for a growing excavation company.',
    excerpt: 'An excavation contractor relying entirely on referrals with no digital presence. We built their brand online — site, local SEO, and Google Ads — opening up a new inbound lead channel.',
    stats: [
      { label: 'New Inbound Channel', color: 'gold' },
      { label: '68% Lower CPL vs. Industry Avg', color: 'green' },
    ],
    slug: { current: 'excavation-digital-foundation' },
  },
  {
    _id: '4',
    industry: 'Home Security',
    title: 'Scaling a home security brand beyond door-to-door.',
    excerpt: 'A regional home security company over-reliant on door-to-door sales. We built their digital acquisition engine — paid search, local SEO, and a converting website — to create a scalable inbound channel.',
    stats: [
      { label: '2.8x Lead Volume', color: 'green' },
      { label: '47% Lower CPL', color: 'blue' },
    ],
    slug: { current: 'home-security-digital-acquisition' },
  },
];
---

<BaseLayout title="Work — Railshop" description="Case studies from Railshop. See how we've helped service businesses build their digital presence and drive real growth.">
  <!-- Header -->
  <section class="page-hero">
    <div class="container">
      <SectionTag label="Case Studies" />
      <h1 class="page-title">Our work</h1>
      <p class="page-desc">
        A selection of client engagements. Details are anonymised where requested.
        We're happy to share more specifics on a call.
      </p>
    </div>
  </section>

  <!-- Case Study Grid -->
  <section class="section">
    <div class="container">
      <div class="cases-grid stagger">
        {displayCases.map((cs) => (
          <Card href={`/work/${cs.slug.current}`} animate class="case-card">
            <!-- Featured image -->
            <div class="case-image">
              {cs._id === '1' ? (
                <img
                  src="/images/F&I Scaled 1500.jpg"
                  alt="HVAC business owner reviewing campaign results with a client"
                  class="case-img"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <>
                  <div class="case-image-glow" aria-hidden="true"></div>
                  <span class="case-image-label">Client Photo</span>
                </>
              )}
            </div>
            <!-- Content -->
            <div class="case-content">
              <div class="case-meta">
                <span class="tag">{cs.industry}</span>
              </div>
              <h2 class="case-title">{cs.title}</h2>
              <p class="case-excerpt">{cs.excerpt}</p>
              <div class="case-stats">
                {(cs.stats ?? []).map((stat: { label: string; color: string }) => (
                  <span class={`case-stat case-stat--${stat.color}`}>{stat.label}</span>
                ))}
              </div>
              <span class="case-link">
                Read case study
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container cta-inner">
      <SectionTag label="Let's Talk" />
      <h2 class="cta-title">Want results like these?</h2>
      <p class="cta-desc">We take on a limited number of new clients each quarter. Book a call to see if we're the right fit.</p>
      <div class="cta-buttons">
        <Button href="/contact#hubspot-meetings" variant="primary">Book a Call</Button>
        <Button href="/contact" variant="secondary">Send a Message</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 80px 0 48px;
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    color: var(--text-2);
    margin-top: 16px;
    letter-spacing: -0.02em;
  }

  .page-desc {
    font-size: 17px;
    color: var(--text-3);
    max-width: 540px;
    line-height: 1.7;
    margin-top: 12px;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }


  :global(.case-card) {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    text-decoration: none;
    overflow: hidden;
  }

  /* Featured image placeholder */
  .case-image {
    position: relative;
    height: 200px;
    background: var(--surface-3);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }

  .case-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .case-image-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(56, 182, 255, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .case-image-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
    opacity: 0.5;
    position: relative;
    z-index: 1;
  }

  /* Card content area */
  .case-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 28px 32px 32px;
    flex: 1;
  }

  .case-meta { display: flex; gap: 8px; }
  .case-title { font-size: 20px; font-weight: 700; color: var(--text-2); line-height: 1.3; }
  .case-excerpt { font-size: 14px; color: var(--text-3); line-height: 1.8; flex: 1; }

  .case-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .case-stat {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    padding: 5px 10px;
    border-radius: 20px;
  }

  .case-stat--green {
    background: rgba(52, 211, 153, 0.08);
    color: var(--green);
  }

  .case-stat--blue {
    background: rgba(56, 182, 255, 0.08);
    color: var(--blue);
  }

  .case-stat--gold {
    background: rgba(251, 191, 36, 0.08);
    color: var(--gold);
  }

  .case-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--blue);
    font-weight: 600;
  }

  /* CTA Banner */
  .cta-banner {
    position: relative;
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 80px 0;
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    top: -80px;
    right: -80px;
    width: 500px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(56, 182, 255, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .cta-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .cta-desc {
    font-size: 16px;
    color: var(--text-3);
    max-width: 480px;
    line-height: 1.7;
  }

  .cta-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .cases-grid { grid-template-columns: 1fr; }
  }
</style>
