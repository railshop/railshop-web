---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTag from '../components/ui/SectionTag.astro';
import ContactForm from '../components/ContactForm';
---

<BaseLayout
  title="Contact — Railshop"
  description="Book a call with Railshop or send us a message. We respond within one business day."
>
  <!-- Header -->
  <section class="page-hero">
    <div class="container">
      <SectionTag label="Get in Touch" />
      <h1 class="page-title">Let's talk</h1>
      <p class="page-desc">
        Book a call to discuss your paid media program, or fill out the form and
        we'll be in touch within one business day.
      </p>
    </div>
  </section>

  <!-- Two-column layout -->
  <section class="section">
    <div class="container contact-grid">
      <!-- Left: Contact Form -->
      <div class="contact-form-col">
        <h2 class="col-heading">Send a message</h2>
        <p class="col-subhead">
          Tell us about your goals and we'll come prepared to the call.
        </p>
        <div style="margin-top: 28px;">
          <ContactForm client:load />
        </div>
      </div>

      <!-- Right: Meetings Embed -->
      <div class="contact-meetings-col">
        <h2 class="col-heading">Book a call</h2>
        <p class="col-subhead">
          Pick a time that works for you. Calls are 30 minutes — no sales
          pressure, just an honest conversation about your program.
        </p>

        <!-- What to expect -->
        <div class="expect-list">
          <p class="expect-heading">What to expect</p>
          {[
            'A quick audit of your current paid media setup',
            'Honest assessment of what\'s working and what isn\'t',
            'Initial thinking on where the biggest opportunities are',
            'No obligation — if we\'re not the right fit, we\'ll say so',
          ].map((item) => (
            <div class="expect-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{item}</span>
            </div>
          ))}
        </div>

        <!-- HubSpot Meetings embed placeholder -->
        <div id="hubspot-meetings" class="meetings-embed" aria-label="Book a meeting with Railshop">
          <div class="meetings-placeholder">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <p class="meetings-placeholder-title">HubSpot Meetings</p>
            <p class="meetings-placeholder-desc">
              Add your HubSpot Meetings embed script here. Replace this
              placeholder with your{' '}
              <code>&lt;div class="meetings-embed-container"&gt;</code>{' '}
              and script tag from HubSpot.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { padding: 80px 0 48px; border-bottom: 1px solid var(--border); }

  .page-title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    color: var(--text-2);
    margin-top: 16px;
    letter-spacing: -0.02em;
  }

  .page-desc {
    font-size: 17px;
    color: var(--text-3);
    max-width: 520px;
    line-height: 1.7;
    margin-top: 12px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .col-heading { font-size: 20px; font-weight: 700; color: var(--text-2); }
  .col-subhead { font-size: 14px; color: var(--text-3); line-height: 1.7; margin-top: 8px; }

  /* What to expect */
  .expect-list {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .expect-heading {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
    margin-bottom: 4px;
  }

  .expect-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.5;
  }

  .expect-item svg { flex-shrink: 0; margin-top: 2px; }

  /* Meetings embed */
  .meetings-embed {
    margin-top: 24px;
    min-height: 400px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .meetings-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    min-height: 400px;
    background: var(--surface);
    padding: 40px;
    text-align: center;
  }

  .meetings-placeholder-title {
    font-weight: 700;
    color: var(--text-2);
    font-size: 16px;
  }

  .meetings-placeholder-desc {
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.7;
    max-width: 320px;
  }

  .meetings-placeholder-desc code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    background: var(--surface-2);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--blue);
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
