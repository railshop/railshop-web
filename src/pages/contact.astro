---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import { getContactPage, getSiteSettings, getServices, urlForImage } from '../lib/sanity';

let contactPage: any = null;
let settings: any = null;
let services: any[] = [];
try {
  [contactPage, settings, services] = await Promise.all([
    getContactPage(), getSiteSettings(), getServices(),
  ]);
} catch (_) {}

// Open section
const openEyebrow = contactPage?.openSection?.eyebrow  ?? 'Free · 30 Min Discovery Call';
const openHeading = contactPage?.openSection?.headline ?? null;
const openSub     = contactPage?.openSection?.sub      ?? "No pitch, no pressure. Book a call and we'll walk through your current setup, what's working, and where to focus next.";

// Send a Message section
const msgHeading  = contactPage?.sendAMessage?.heading ?? 'Not ready to book? Send us a note.';
const msgSub      = contactPage?.sendAMessage?.sub     ?? 'Tell us about your business and what you\'re trying to achieve. We\'ll review it and follow up within one business day.';
const stat1Value  = contactPage?.sendAMessage?.responseStat1Value ?? '~4h';
const stat1Label  = contactPage?.sendAMessage?.responseStat1Label ?? 'Avg. response time';
const stat2Value  = contactPage?.sendAMessage?.responseStat2Value ?? '100%';
const stat2Label  = contactPage?.sendAMessage?.responseStat2Label ?? 'Responses sent';
const socialProof = contactPage?.sendAMessage?.socialProofText ?? 'Most of our best client relationships started with a single message.';

// Client logos for trust strip
const clientLogos: any[] = contactPage?.clientLogos ?? [
  { name: 'Window Nation', logo: null, _localSrc: '/images/logos/window nation logo_cropped.png' },
  { name: 'Vector Security', logo: null, _localSrc: '/images/logos/vector security logo.svg' },
  { name: 'Fire & Ice', logo: null, _localSrc: '/images/logos/fire and ice logo.png' },
  { name: 'JP Operations', logo: null, _localSrc: '/images/logos/jp operations logo.svg' },
];

// Service pills — from Sanity or fallback
const servicePills = services.length > 0
  ? services.map((s: any) => ({ label: s.title, value: s.slug.current }))
  : [
      { label: 'Web Design & Development', value: 'web-design' },
      { label: 'Paid Ads',                 value: 'paid-ads' },
      { label: 'SEO',                      value: 'seo' },
      { label: 'Content Creation',         value: 'content-creation' },
      { label: 'Strategy Consulting',      value: 'strategy' },
      { label: 'AI Integration',           value: 'ai-integration' },
    ];

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  'name': 'Contact Railshop',
  'url': 'https://railshop.co/contact',
  'isPartOf': { '@id': 'https://railshop.co/#website' },
};
---

<BaseLayout
  title={contactPage?.seo?.metaTitle ?? 'Contact — Railshop'}
  description={contactPage?.seo?.metaDescription ?? 'Book a free 30-minute discovery call with Railshop. No pitch. Honest perspective on what\'s holding your marketing back.'}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://static.hsappstatic.net" />
    <link rel="preconnect" href="https://launch.railshop.co" />
    <link rel="preconnect" href="https://app.hubspot.com" />
    <link rel="dns-prefetch" href="https://js.hubspot.com" />
    <link rel="dns-prefetch" href="https://forms.hubspot.com" />
    <link rel="preload" as="script" href="https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js" />
    <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />
  </Fragment>

  <!-- ============================================================
       1. OPEN — PageHero
       ============================================================ -->
  <PageHero
    headline={openHeading ?? "Let's talk about<br />what's next."}
    sub={openSub}
    eyebrow={openEyebrow}
    annoCode="SYS: CONTACT"
    annoExtra="PORT: OPEN"
    annoModule="MODULE: CTX-001"
    illustration="launch"
  />

  <!-- ============================================================
       2. TRUST STRIP — client logos
       ============================================================ -->
  {clientLogos.length > 0 && (
    <div class="trust-strip">
      <div class="container">
        <div class="trust-inner">
          <span class="trust-eyebrow">// We've worked with</span>
          <div class="trust-logos">
            {clientLogos.map((client: any) => (
              <div class="trust-logo-slot">
                {client.logo
                  ? <img src={urlForImage(client.logo).url()} alt={client.name} loading="lazy" />
                  : client._localSrc
                    ? <img src={client._localSrc} alt={client.name} loading="lazy" />
                    : <span class="trust-logo-name">{client.name}</span>
                }
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  )}

  <!-- ============================================================
       3. BOOK A CALL — HUBSPOT MEETINGS
       ============================================================ -->
  <section class="cal-section" id="book-a-call">
    <div class="container">
      <div class="meetings-iframe-container" data-src="https://launch.railshop.co/meetings/andrew-opalinski?embed=true"></div>
    </div>
  </section>
  <!-- ============================================================
       4. SEND A MESSAGE — secondary path
       ============================================================ -->
  <div class="section-rule" aria-hidden="true">
    <div class="section-rule-line"></div>
    <span class="section-rule-label">// SEND A MESSAGE · MSG-001</span>
    <div class="section-rule-line"></div>
  </div>

  <section class="message-section" id="send-a-message">
    <div class="container">
      <div class="message-header">
        <div class="message-header-left">
          <h2 class="message-heading">{msgHeading}</h2>
          <p class="message-sub">{msgSub}</p>
        </div>
        <div class="message-header-right" aria-hidden="true">
          <div class="response-stat">
            <span class="response-stat-num">{stat1Value}</span>
            <span class="response-stat-label">{stat1Label}</span>
          </div>
          <div class="response-divider"></div>
          <div class="response-stat">
            <span class="response-stat-num">{stat2Value}</span>
            <span class="response-stat-label">{stat2Label}</span>
          </div>
        </div>
      </div>

      <form
        name="contact"
        method="POST"
        netlify
        action="/thank-you"
        class="contact-form"
        id="contact-form"
      >
        <input type="hidden" name="form-name" value="contact" />

        <div class="form-grid form-grid--2">
          <div class="field-group">
            <label class="field-label" for="name">Name <span class="field-required">*</span></label>
            <input id="name" type="text" name="name" placeholder="Your name" required class="field-input" />
          </div>
          <div class="field-group">
            <label class="field-label" for="email">Email <span class="field-required">*</span></label>
            <input id="email" type="email" name="email" placeholder="Your email" required class="field-input" />
          </div>
        </div>

        <div class="form-grid form-grid--2">
          <div class="field-group">
            <label class="field-label" for="phone">Phone</label>
            <input id="phone" type="tel" name="phone" placeholder="Your phone number" class="field-input" />
          </div>
          <div class="field-group">
            <label class="field-label" for="source">How did you hear about us?</label>
            <select id="source" name="source" class="field-input field-select">
              <option value="" disabled selected>Select an option</option>
              <option value="google-search">Google Search</option>
              <option value="referral">Referral</option>
              <option value="linkedin">LinkedIn</option>
              <option value="instagram">Instagram</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>

        <fieldset class="field-group field-group--fieldset">
          <legend class="field-label">What are you interested in?</legend>
          <div class="pill-group" id="pill-group" role="group" aria-label="Services of interest">
            {servicePills.map((opt: { label: string; value: string }) => (
              <button type="button" class="pill" data-value={opt.value} aria-pressed="false">{opt.label}</button>
            ))}
          </div>
          <input type="hidden" name="interests" id="interests-input" />
        </fieldset>

        <div class="field-group">
          <label class="field-label" for="message">Message</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            placeholder="Tell us about your business, your goals, and anything that would help us prepare for a call."
            class="field-input field-textarea"
          ></textarea>
        </div>

        <div class="form-footer">
          <p class="social-proof">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            {socialProof}
          </p>
          <button type="submit" class="submit-btn">
            Send Message
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      </form>

    </div>
  </section>

  <Fragment slot="body-end">
    <script type="text/javascript" src="https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js"></script>
  </Fragment>
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('#pill-group .pill');
  const interestsInput = document.getElementById('interests-input') as HTMLInputElement;
  const selected = new Set<string>();

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const val = pill.dataset.value ?? '';
      if (selected.has(val)) {
        selected.delete(val);
        pill.classList.remove('pill--active');
        pill.setAttribute('aria-pressed', 'false');
      } else {
        selected.add(val);
        pill.classList.add('pill--active');
        pill.setAttribute('aria-pressed', 'true');
      }
      interestsInput.value = Array.from(selected).join(', ');
    });
  });
</script>

<style>
  /* ══════════════════════════════════════
     2. TRUST STRIP
  ══════════════════════════════════════ */
  .trust-strip {
    padding: 28px 0 4px;
  }

  .trust-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .trust-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
  }

  .trust-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 56px;
    flex-wrap: wrap;
  }

  .trust-logo-slot img {
    display: block;
    object-fit: contain;
    opacity: 0.5;
    filter: brightness(0) invert(1);
    transition: opacity 0.2s;
  }

  .trust-logo-slot img:hover { opacity: 0.75; }

  /* Per-logo sizing — order matches Sanity clientLogos array */
  .trust-logo-slot:nth-child(1) img { width: 150px; height: 38px; } /* Window Nation — very wide */
  .trust-logo-slot:nth-child(2) img { width: 160px; height: 44px; } /* Vector Security — compact */
  .trust-logo-slot:nth-child(3) img { width: 160px; height: 44px; } /* Fire & Ice */
  .trust-logo-slot:nth-child(4) img { width: 130px; height: 36px; } /* JP Operations */

  .trust-logo-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--text-3);
    opacity: 0.4;
    text-transform: uppercase;
  }

  /* ══════════════════════════════════════
     3. BOOK A CALL — CALENDLY
  ══════════════════════════════════════ */
  .cal-section {
    padding: 56px 0 64px;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 72px;
  }



  /* ══════════════════════════════════════
     SHARED: SECTION RULE DIVIDER
  ══════════════════════════════════════ */
  .section-rule {
    display: flex;
    align-items: center;
    height: 32px;
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    overflow: hidden;
  }

  .section-rule-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .section-rule-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.35;
    padding: 0 16px;
    white-space: nowrap;
  }

  /* ══════════════════════════════════════
     4. SEND A MESSAGE
  ══════════════════════════════════════ */
  .message-section {
    padding: 64px 0 96px;
    scroll-margin-top: 72px;
  }

  .message-header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: end;
    margin-bottom: 48px;
  }

  .message-header-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .message-heading {
    font-size: clamp(20px, 2.5vw, 30px);
    font-weight: 700;
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 10px;
  }

  .message-sub {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.7;
    max-width: 420px;
  }

  .message-header-right {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-shrink: 0;
    padding-bottom: 4px;
  }

  .response-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .response-stat-num {
    font-size: 22px;
    font-weight: 800;
    color: var(--blue);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .response-stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.5;
    text-align: center;
    white-space: nowrap;
  }

  .response-divider {
    width: 1px;
    height: 36px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* ── Contact Form ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 40px;
  }

  .form-grid { display: grid; gap: 20px; }
  .form-grid--2 { grid-template-columns: 1fr 1fr; }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .field-group--fieldset {
    border: none;
    padding: 0;
    margin: 0;
    min-width: 0;
  }

  .field-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
  }

  .field-required { color: var(--blue); opacity: 0.7; }

  .field-input {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 13px 16px;
    font-size: 14px;
    color: var(--text);
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  .field-input::placeholder { color: var(--text-3); opacity: 0.5; }

  .field-input:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(56, 182, 255, 0.08);
  }

  .field-select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%23666' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
    cursor: pointer;
  }

  .field-textarea {
    resize: vertical;
    min-height: 140px;
    line-height: 1.65;
  }

  .pill-group { display: flex; flex-wrap: wrap; gap: 8px; }

  .pill {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 8px 14px;
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.04em;
    color: var(--text-3);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    text-transform: none;
  }

  .pill:hover { border-color: var(--blue); color: var(--text-2); }

  .pill--active {
    background: rgba(56, 182, 255, 0.1);
    border-color: var(--blue);
    color: var(--blue);
  }

  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .social-proof {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-3);
    font-style: italic;
    opacity: 0.8;
  }

  .social-proof svg { flex-shrink: 0; }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--blue);
    color: #111315;
    font-weight: 700;
    font-size: 14px;
    font-family: inherit;
    border: none;
    border-radius: 6px;
    padding: 13px 28px;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

.submit-btn:hover { opacity: 0.88; transform: translateY(-1px); }
  .submit-btn:active { transform: translateY(0); }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .message-header { grid-template-columns: 1fr; gap: 24px; }
    .message-header-right { justify-content: flex-start; }
  }

  @media (max-width: 768px) {
    .trust-logos { gap: 28px; }
    .trust-logo-slot img { width: 160px; height: 46px; }
    .form-grid--2 { grid-template-columns: 1fr; }
    .contact-form { padding: 28px 20px; }
    .form-footer { flex-direction: column; align-items: flex-start; }
    .submit-btn { width: 100%; justify-content: center; }
  }

  @media (max-width: 640px) {
    .section-rule { display: none; }
  }
</style>
