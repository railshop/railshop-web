---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/ui/CtaBanner.astro';
import { getPosts } from '../../lib/sanity';

let posts: any[] = [];
try {
  posts = await getPosts(20);
} catch (_) {}

const displayPosts = posts.length > 0 ? posts : [
  {
    _id: '1',
    title: 'Why Most Service Businesses Fail Online (And What Actually Works)',
    excerpt: 'The common mistakes we see across every industry — and the framework we use to fix them.',
    publishedAt: '2026-02-12',
    category: 'Strategy',
    slug: { current: 'why-service-businesses-fail-online' },
    image: '/images/blog/service businesses fail.png',
  },
  {
    _id: '2',
    title: 'Why Most Google Ads Accounts Plateau After Month 3',
    excerpt: 'The structural patterns we see in stalled accounts, and the levers that consistently move them.',
    publishedAt: '2026-01-28',
    category: 'Paid Ads',
    slug: { current: 'google-ads-plateau' },
    image: '/images/blog/google ads plateau after month 3.png',
  },
  {
    _id: '3',
    title: "Local SEO in 2026: What's Changed and What Still Works",
    excerpt: 'The tactics that have faded and the fundamentals that keep driving rankings for service businesses.',
    publishedAt: '2026-01-14',
    category: 'SEO',
    slug: { current: 'local-seo-2026' },
    image: '/images/blog/local seo in 2026.png',
  },
  {
    _id: '4',
    title: 'What Makes a Service Business Website Actually Convert',
    excerpt: "Speed, structure, and trust signals — the three things that separate websites that generate leads from ones that don't.",
    publishedAt: '2025-12-18',
    category: 'Web',
    slug: { current: 'service-business-website-conversion' },
    image: '/images/blog/what makes a service website convert.png',
  },
  {
    _id: '5',
    title: "How We're Using AI in Client Engagements Right Now",
    excerpt: 'Practical applications, not hype. Where AI is actually saving time and improving output in our day-to-day work.',
    publishedAt: '2025-12-03',
    category: 'AI',
    slug: { current: 'ai-in-client-engagements' },
    image: '/images/blog/ai in client engagements.png',
  },
];

const featuredPost = displayPosts[0];
const gridPosts = displayPosts.slice(1);

const categoryColorMap: Record<string, string> = {
  'Strategy': 'blue',
  'Paid Ads': 'green',
  'SEO': 'gold',
  'Web': 'blue',
  'AI': 'green',
  'Content': 'gold',
};
---

<BaseLayout
  title="Blog — Railshop"
  description="Straight talk on digital marketing for service businesses. No noise — honest perspective from practitioners who live in the accounts."
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <svg class="hero-grid-svg" viewBox="0 0 1400 480" fill="none" preserveAspectRatio="xMidYMid slice">
        <line class="grid-line" x1="350" y1="0" x2="350" y2="480"/>
        <line class="grid-line" x1="700" y1="0" x2="700" y2="480"/>
        <line class="grid-line" x1="1050" y1="0" x2="1050" y2="480"/>
        <line class="grid-line" x1="0" y1="160" x2="1400" y2="160"/>
        <line class="grid-line" x1="0" y1="320" x2="1400" y2="320"/>
        <path class="corner-bracket" d="M 32 24 L 32 60 M 32 24 L 68 24"/>
        <path class="corner-bracket" d="M 1368 456 L 1368 420 M 1368 456 L 1332 456"/>
        <line class="tick-mark" x1="350" y1="468" x2="350" y2="480"/>
        <line class="tick-mark" x1="700" y1="468" x2="700" y2="480"/>
        <line class="tick-mark" x1="1050" y1="468" x2="1050" y2="480"/>
      </svg>
      <div class="hero-glow"></div>
    </div>

    <!-- Corner annotations -->
    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: BLOG</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">{displayPosts.length} POSTS ACTIVE</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">MODULE: BLG-001</span>
    </div>

    <div class="container">
      <div class="hero-inner">
        <div class="hero-left">
          <h1 class="hero-headline">
            Straight talk on<br />
            <span class="hero-accent">digital marketing.</span>
          </h1>
          <p class="hero-sub">
            No noise, no vanity metrics — just honest perspective on what's working for service businesses online.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Post -->
  <section class="featured-section">
    <div class="container">

      <div class="section-label" aria-hidden="true">
        <span class="section-label-text">FEATURED // POST-{String(1).padStart(3,'0')}</span>
      </div>

      <a href={`/blog/${featuredPost.slug.current}`} class="featured-card">

        <!-- Image -->
        <div class="featured-image">
          <img src={featuredPost.image} alt="" class="featured-image-img" loading="eager" decoding="async" />
          <!-- HUD overlay -->
          <div class="card-hud" aria-hidden="true">
            <span class="hud-id">POST-001</span>
            <span class="hud-cat">{featuredPost.category}</span>
          </div>
          <!-- Corner brackets -->
          <span class="img-corner img-corner--tl" aria-hidden="true"></span>
          <span class="img-corner img-corner--tr" aria-hidden="true"></span>
          <span class="img-corner img-corner--bl" aria-hidden="true"></span>
          <span class="img-corner img-corner--br" aria-hidden="true"></span>
        </div>

        <!-- Content -->
        <div class="featured-content">
          <span class="post-date">{new Date(featuredPost.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
          <h2 class="featured-title">{featuredPost.title}</h2>
          <p class="featured-excerpt">{featuredPost.excerpt}</p>
          <span class="card-cta">
            Read post
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>

      </a>
    </div>
  </section>

  <!-- Filter + Post Grid -->
  <section class="posts-section">
    <div class="container">

      <!-- Filter bar -->
      <div class="filter-bar">
        <span class="filter-label">FILTER</span>
        <div class="filter-tabs" id="filter-tabs">
          <button class="filter-tab filter-tab--active" data-filter="all">All</button>
          <button class="filter-tab" data-filter="web">Web</button>
          <button class="filter-tab" data-filter="seo">SEO</button>
          <button class="filter-tab" data-filter="paid-ads">Paid Ads</button>
          <button class="filter-tab" data-filter="content">Content</button>
          <button class="filter-tab" data-filter="strategy">Strategy</button>
          <button class="filter-tab" data-filter="ai">AI</button>
        </div>
        <span class="filter-count" id="filter-count">{gridPosts.length} articles</span>
      </div>

      <!-- Grid -->
      <div class="posts-grid" id="posts-grid">
        {gridPosts.map((post, i) => (
          <a
            href={`/blog/${post.slug.current}`}
            class="post-card"
            data-category={post.category.toLowerCase().replace(' ', '-')}
          >
            <!-- Image -->
            <div class="post-image">
              <img src={post.image} alt="" class="post-image-img" loading="lazy" decoding="async" />
              <!-- HUD overlay -->
              <div class="card-hud" aria-hidden="true">
                <span class="hud-id">POST-{String(i + 2).padStart(3, '0')}</span>
                <span class="hud-cat">{post.category}</span>
              </div>
              <!-- Corner brackets -->
              <span class="img-corner img-corner--tl" aria-hidden="true"></span>
              <span class="img-corner img-corner--tr" aria-hidden="true"></span>
              <span class="img-corner img-corner--bl" aria-hidden="true"></span>
              <span class="img-corner img-corner--br" aria-hidden="true"></span>
            </div>

            <!-- Content -->
            <div class="post-content">
              <span class="post-date">{new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
              <h2 class="post-title">{post.title}</h2>
              <p class="post-excerpt">{post.excerpt}</p>
              <span class="card-cta">
                Read post
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="newsletter-section">
    <div class="newsletter-glow" aria-hidden="true"></div>
    <div class="container newsletter-inner">
      <div class="newsletter-status" aria-hidden="true">
        <span class="newsletter-status-dot"></span>
        New posts weekly
      </div>
      <h2 class="newsletter-title">Get it in your inbox.</h2>
      <p class="newsletter-desc">New posts, no spam. Practical marketing perspective for service business owners and marketing leaders.</p>
      <form
        name="newsletter-signup"
        method="POST"
        netlify
        class="newsletter-form"
      >
        <input type="hidden" name="form-name" value="newsletter-signup" />
        <div class="newsletter-row">
          <input
            type="email"
            name="email"
            placeholder="Your email address"
            required
            class="newsletter-input"
          />
          <button type="submit" class="newsletter-btn">Subscribe</button>
        </div>
      </form>
    </div>
    <div class="container newsletter-rule-wrap">
      <div class="newsletter-rule" aria-hidden="true">
        <div class="newsletter-rule-line"></div>
        <span class="newsletter-rule-label">// No Spam. Unsubscribe Anytime.</span>
        <div class="newsletter-rule-line"></div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');
  const countEl = document.getElementById('filter-count');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const filter = tab.dataset.filter ?? 'all';

      tabs.forEach((t) => t.classList.remove('filter-tab--active'));
      tab.classList.add('filter-tab--active');

      let visible = 0;
      cards.forEach((card) => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      if (countEl) countEl.textContent = `${visible} article${visible !== 1 ? 's' : ''}`;
    });
  });
</script>

<style>
  /* ── Hero ─────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-grid-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .grid-line {
    stroke: var(--border);
    stroke-width: 1;
    opacity: 0.4;
  }

  .corner-bracket {
    stroke: var(--border);
    stroke-width: 1.5;
    opacity: 0.35;
  }

  .tick-mark {
    stroke: var(--border);
    stroke-width: 1;
    opacity: 0.5;
  }

  .hero-glow {
    position: absolute;
    top: -40px;
    left: -5%;
    width: 50%;
    height: 80%;
    background: radial-gradient(ellipse at 30% 40%, rgba(56, 182, 255, 0.045) 0%, transparent 65%);
  }

  .hero-annotation {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-annotation--tr { top: 20px; right: 32px; }
  .hero-annotation--bl { bottom: 20px; left: 32px; }

  .anno-code { color: var(--blue); opacity: 0.8; }
  .anno-sep  { opacity: 0.3; }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 56px 0 64px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-accent { color: var(--blue); }

  .hero-sub {
    font-size: 16px;
    color: var(--text-3);
    max-width: 540px;
    line-height: 1.75;
  }

  /* ── Section label ──────────────────────────── */
  .section-label {
    display: flex;
    align-items: center;
    height: 32px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
    overflow: hidden;
  }

  .section-label-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.35;
  }

  /* ── Featured Post ──────────────────────────── */
  .featured-section {
    padding: 48px 0 0;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .featured-card:hover {
    border-color: var(--border-2);
    transform: translateY(-2px);
  }

  .featured-image {
    position: relative;
    min-height: 280px;
    background: var(--surface-3);
    overflow: hidden;
  }

  .featured-image-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }

  .featured-card:hover .featured-image-img {
    transform: scale(1.03);
  }

  .featured-content {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 32px 36px;
    justify-content: center;
  }

  .featured-title {
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 700;
    color: var(--text-2);
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .featured-card:hover .featured-title { color: var(--blue); }

  .featured-excerpt {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.8;
  }

  /* ── Post Grid ──────────────────────────────── */
  .posts-section {
    padding: 48px 0 80px;
  }

  /* Filter bar */
  .filter-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-3);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .filter-tabs {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    flex: 1;
  }

  .filter-tab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 2px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-3);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .filter-tab:hover {
    border-color: var(--blue);
    color: var(--text-2);
  }

  .filter-tab--active {
    background: rgba(56, 182, 255, 0.1);
    border-color: rgba(56, 182, 255, 0.4);
    color: var(--blue);
  }

  .filter-tab--active:hover {
    color: var(--blue);
  }

  .filter-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    color: var(--text-3);
    opacity: 0.4;
    flex-shrink: 0;
    margin-left: auto;
  }

  /* Grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .post-card:hover {
    border-color: var(--border-2);
    transform: translateY(-2px);
  }

  .post-image {
    position: relative;
    height: 200px;
    background: var(--surface-3);
    overflow: hidden;
    flex-shrink: 0;
  }

  .post-image-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }

  .post-card:hover .post-image-img {
    transform: scale(1.03);
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 22px 24px 24px;
    flex: 1;
  }

  .post-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-2);
    line-height: 1.35;
    transition: color 0.15s ease;
  }

  .post-card:hover .post-title { color: var(--blue); }

  .post-excerpt {
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.8;
    flex: 1;
  }

  /* ── Shared card elements ───────────────────── */
  .post-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
    opacity: 0.6;
  }

  .card-cta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-3);
    margin-top: 4px;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .featured-card:hover .card-cta,
  .post-card:hover .card-cta {
    color: var(--blue);
    transform: translateX(3px);
  }

  /* HUD overlay */
  .card-hud {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 14px;
    background: linear-gradient(to top, rgba(17,19,21,0.85) 0%, transparent 100%);
  }

  .hud-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(248, 250, 252, 0.5);
  }

  .hud-cat {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-2);
    background: rgba(42, 47, 51, 0.8);
    border: 1px solid var(--border-2);
    border-radius: 2px;
    padding: 3px 8px;
    backdrop-filter: blur(4px);
  }

  /* Corner brackets on images */
  .img-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    pointer-events: none;
    opacity: 0.5;
  }

  .img-corner--tl { top: 10px; left: 10px; border-top: 1px solid var(--blue); border-left: 1px solid var(--blue); }
  .img-corner--tr { top: 10px; right: 10px; border-top: 1px solid var(--blue); border-right: 1px solid var(--blue); }
  .img-corner--bl { bottom: 36px; left: 10px; border-bottom: 1px solid var(--blue); border-left: 1px solid var(--blue); }
  .img-corner--br { bottom: 36px; right: 10px; border-bottom: 1px solid var(--blue); border-right: 1px solid var(--blue); }

  /* ── Newsletter ─────────────────────────────── */
  .newsletter-section {
    position: relative;
    background: var(--bg);
    border-top: 3px solid var(--blue);
    padding: 80px 0 40px;
    overflow: hidden;
  }

  :global([data-theme="light"]) .newsletter-section { background: var(--surface); }

  .newsletter-glow {
    position: absolute;
    top: -80px;
    right: -80px;
    width: 500px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(56, 182, 255, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .newsletter-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    margin-bottom: 24px;
  }

  .newsletter-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--blue);
  }

  .newsletter-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--blue);
    animation: ctapulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes ctapulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }

  .newsletter-title {
    font-size: clamp(32px, 4.5vw, 52px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .newsletter-desc {
    font-size: 17px;
    color: var(--text-3);
    line-height: 1.7;
    max-width: 420px;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    width: 100%;
  }

  .newsletter-row {
    display: flex;
    gap: 6px;
    width: 100%;
    max-width: 400px;
  }

  .newsletter-input {
    flex: 1;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 12px 16px;
    font-size: 14px;
    font-family: inherit;
    color: var(--text);
    outline: none;
    transition: border-color 0.15s;
    min-width: 0;
  }

  .newsletter-input::placeholder { color: var(--text-3); }
  .newsletter-input:focus { border-color: var(--blue); }

  .newsletter-btn {
    background: var(--blue);
    color: #111315;
    font-weight: 700;
    font-size: 14px;
    font-family: inherit;
    border: none;
    border-radius: 2px;
    padding: 12px 20px;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  :global([data-theme="light"]) .newsletter-btn { color: #FFFFFF; }
  .newsletter-btn:hover { opacity: 0.88; }

