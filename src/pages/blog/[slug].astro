---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PortableText from '../../components/ui/PortableText.astro';
import { getPostBySlug, getAllPostSlugs, getPosts, getSiteSettings, estimateReadTime, urlForImage } from '../../lib/sanity';

export async function getStaticPaths() {
  try {
    const slugs = await getAllPostSlugs();
    if (slugs.length > 0) {
      return slugs.map((s: { slug: string }) => ({ params: { slug: s.slug } }));
    }
  } catch (_) {}
  return [
    'why-service-businesses-fail-online',
    'google-ads-plateau',
    'local-seo-2026',
    'service-business-website-conversion',
    'ai-in-client-engagements',
  ].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

let post: any = null;
let relatedPosts: any[] = [];
let takingNewClients = true;

try {
  [post, relatedPosts] = await Promise.all([
    getPostBySlug(slug),
    getPosts(10),
  ]);
  const settings = await getSiteSettings();
  if (settings?.takingNewClients !== undefined) takingNewClients = settings.takingNewClients;
  relatedPosts = (relatedPosts ?? []).filter((p: any) => p.slug?.current !== slug).slice(0, 3);
} catch (_) {}

const slugCategoryMap: Record<string, string> = {
  'why-service-businesses-fail-online': 'Strategy',
  'google-ads-plateau': 'Paid Ads',
  'local-seo-2026': 'SEO',
  'service-business-website-conversion': 'Web',
  'ai-in-client-engagements': 'AI',
};

if (!post) {
  post = {
    title: slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
    excerpt: 'Full post content coming soon.',
    publishedAt: new Date().toISOString(),
    slug: { current: slug },
    categories: slugCategoryMap[slug] ? [{ title: slugCategoryMap[slug] }] : [],
  };
}

const formattedDate = new Date(post.publishedAt).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const readTime = post.body ? estimateReadTime(post.body) : null;
const postRef = (post._id ?? slug).slice(-6).toUpperCase();

const coverImageUrl = post.coverImage?.asset?._ref
  ? urlForImage(post.coverImage).width(1200).url()
  : 'https://railshop.co/og-default.png';

const blogPostSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      'headline': post.title,
      'description': post.excerpt ?? '',
      'datePublished': post.publishedAt,
      'dateModified': post.publishedAt,
      'url': `https://railshop.co/blog/${post.slug.current}`,
      'mainEntityOfPage': { '@type': 'WebPage', '@id': `https://railshop.co/blog/${post.slug.current}` },
      'image': { '@type': 'ImageObject', 'url': coverImageUrl },
      'author': { '@type': 'Organization', '@id': 'https://railshop.co/#organization' },
      'publisher': { '@id': 'https://railshop.co/#organization' },
      'isPartOf': { '@id': 'https://railshop.co/#website' },
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://railshop.co' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Blog', 'item': 'https://railshop.co/blog' },
        { '@type': 'ListItem', 'position': 3, 'name': post.title, 'item': `https://railshop.co/blog/${post.slug.current}` },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${post.title} — Railshop Blog`}
  description={post.seo?.metaDescription ?? post.excerpt}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogPostSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <svg class="hero-bg-svg" viewBox="0 0 1400 480" fill="none" preserveAspectRatio="xMidYMid slice">
        <path class="hero-arc-main"      d="M -80 520 Q 380 40 860 260 Q 1060 390 1480 180" stroke-width="1" fill="none"/>
        <path class="hero-arc-secondary" d="M -80 560 Q 360 60 830 290 Q 1030 420 1480 220" stroke-width="1" fill="none"/>
        <circle class="hero-bg-star" cx="885"  cy="44"  r="1.5"/>
        <circle class="hero-bg-star" cx="1102" cy="29"  r="1"/>
        <circle class="hero-bg-star" cx="1248" cy="74"  r="2"/>
        <circle class="hero-bg-star" cx="1342" cy="42"  r="1.5"/>
        <circle class="hero-bg-star" cx="1064" cy="142" r="1"/>
        <circle class="hero-bg-star" cx="1285" cy="184" r="1.5"/>
        <circle class="hero-bg-star" cx="950"  cy="244" r="1"/>
        <circle class="hero-bg-star" cx="1380" cy="260" r="2"/>
        <circle class="hero-bg-star" cx="822"  cy="352" r="1"/>
        <circle class="hero-bg-star" cx="1154" cy="384" r="1.5"/>
        <circle class="hero-bg-star" cx="684"  cy="80"  r="1"/>
        <path class="hero-bg-star-4pt" d="M 1022 56 L 1023.8 60.2 L 1028 62 L 1023.8 63.8 L 1022 68 L 1020.2 63.8 L 1016 62 L 1020.2 60.2 Z"/>
        <path class="hero-bg-star-4pt" d="M 1220 146 L 1221.5 149.5 L 1225 151 L 1221.5 152.5 L 1220 156 L 1218.5 152.5 L 1215 151 L 1218.5 149.5 Z"/>
        <path class="hero-bg-star-4pt" d="M 870 316 L 871.8 320.2 L 876 322 L 871.8 323.8 L 870 328 L 868.2 323.8 L 864 322 L 868.2 320.2 Z"/>
      </svg>
      <div class="hero-glow"></div>
    </div>

    <div class="hero-annotation hero-annotation--tr" aria-hidden="true">
      <span class="anno-code">SYS: BLOG</span>
      <span class="anno-sep">·</span>
      <span class="anno-coord">{postRef}</span>
    </div>
    <div class="hero-annotation hero-annotation--bl" aria-hidden="true">
      <span class="anno-code">// ARTICLE DETAIL</span>
    </div>

    <div class="container">
      <div class="breadcrumb">
        <a href="/blog" class="breadcrumb-link">Blog</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{post.title}</span>
      </div>

      <div class="hero-inner">
        <div class="hero-left">
          <div class="post-meta">
            {post.categories?.map((cat: any) => (
              <span class="tag">{cat.title}</span>
            ))}
            {post.categories?.length > 0 && <span class="post-meta-sep">·</span>}
            <span class="post-date">{formattedDate}</span>
            {readTime && <><span class="post-meta-sep">·</span><span class="post-date">{readTime}</span></>}
          </div>
          <h1 class="hero-headline">{post.title}</h1>
          <p class="post-byline">By the Railshop Team</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <div class="content-wrap">
    <div class="container content-grid">

      <!-- Article body -->
      <article class="main-col">
        {post.body ? (
          <div class="post-body">
            <PortableText value={post.body} />
          </div>
        ) : (
          <p class="no-content">Post content coming soon.</p>
        )}

        <!-- Inline subscribe -->
        <div class="inline-subscribe" id="newsletter-block">
          <div class="inline-subscribe-copy">
            <p class="inline-subscribe-prompt">Posts like this, weekly.</p>
            <span class="inline-subscribe-helper">No spam. Unsubscribe anytime.</span>
          </div>
          <form name="newsletter-signup" method="POST" data-netlify="true" class="inline-subscribe-form" id="newsletter-form">
            <input type="hidden" name="form-name" value="newsletter-signup" />
            <input type="email" name="email" placeholder="your@email.com" required class="inline-subscribe-input" id="newsletter-email" />
            <button type="submit" class="inline-subscribe-btn" id="newsletter-btn">Subscribe</button>
          </form>
          <div class="inline-subscribe-success" id="newsletter-success" aria-live="polite">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>You're in. Talk soon.</span>
          </div>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="sidebar">

        <div class="sidebar-card">
          <p class="sidebar-eyebrow">// ABOUT RAILSHOP</p>
          <div class="sidebar-body-wrap">
            <p class="sidebar-body">Railshop is a performance marketing agency for service businesses. Our team spent years leading digital programs at national brands. This is what we learned.</p>
            <a href="/about" class="sidebar-text-link">
              Meet the team
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          {takingNewClients && (
            <div class="sidebar-cta-status">
              <span class="sidebar-cta-dot"></span>
              <span class="sidebar-cta-label">Taking new clients</span>
            </div>
          )}
          <p class="sidebar-cta-heading">Work with us</p>
          <p class="sidebar-body">Book a no-commitment call to discuss your digital program and see what's possible.</p>
          <a href="/contact#book-a-call" class="sidebar-cta-btn">
            Book a Call
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <a href="/blog" class="sidebar-back-link">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          All posts
        </a>

      </aside>

    </div>
  </div>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="related-section">
      <div class="container">
        <div class="related-header">
          <span class="related-label">// RELATED READING</span>
          <div class="related-rule"></div>
        </div>
        <div class="related-grid">
          {relatedPosts.map((rp: any) => {
            const imgSrc = rp.coverImage ? urlForImage(rp.coverImage).width(640).url() : null;
            const rpDate = rp.publishedAt ? new Date(rp.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : '';
            const rpCat = rp.categories?.[0]?.title ?? '';
            return (
              <a href={`/blog/${rp.slug?.current}`} class="related-card">
                <div class="related-image">
                  {imgSrc ? (
                    <img src={imgSrc} alt="" class="related-image-img" loading="lazy" decoding="async" />
                  ) : (
                    <div class="related-image-placeholder"></div>
                  )}
                  {rpCat && (
                    <div class="card-hud" aria-hidden="true">
                      <span class="hud-id">{rp._id?.slice(-6).toUpperCase()}</span>
                      <span class="hud-cat">{rpCat}</span>
                    </div>
                  )}
                  <span class="img-corner img-corner--tl" aria-hidden="true"></span>
                  <span class="img-corner img-corner--tr" aria-hidden="true"></span>
                  <span class="img-corner img-corner--bl" aria-hidden="true"></span>
                  <span class="img-corner img-corner--br" aria-hidden="true"></span>
                </div>
                <div class="related-content">
                  {rpDate && <span class="related-date">{rpDate}</span>}
                  <h3 class="related-title">{rp.title}</h3>
                  {rp.excerpt && <p class="related-excerpt">{rp.excerpt}</p>}
                  <span class="related-cta">
                    Read post
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const success = document.getElementById('newsletter-success') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('newsletter-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      const data = new FormData(form);
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as any).toString(),
      });
      form.style.display = 'none';
      if (success) success.style.display = 'flex';
    } catch {
      btn.disabled = false;
      btn.textContent = 'Subscribe';
    }
  });
</script>

</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-bg-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-arc-main      { stroke: rgba(56, 182, 255, 0.10); }
  .hero-arc-secondary { stroke: rgba(56, 182, 255, 0.05); }
  .hero-bg-star       { fill:   rgba(56, 182, 255, 0.18); }
  .hero-bg-star-4pt   { fill:   rgba(56, 182, 255, 0.14); }

  [data-theme="light"] .hero-arc-main      { stroke: rgba(3, 105, 161, 0.14); }
  [data-theme="light"] .hero-arc-secondary { stroke: rgba(3, 105, 161, 0.07); }
  [data-theme="light"] .hero-bg-star       { fill:   rgba(3, 105, 161, 0.20); }
  [data-theme="light"] .hero-bg-star-4pt   { fill:   rgba(3, 105, 161, 0.15); }

  .hero-glow {
    position: absolute;
    top: -40px;
    left: -5%;
    width: 50%;
    height: 80%;
    background: radial-gradient(ellipse at 30% 40%, rgba(56, 182, 255, 0.045) 0%, transparent 65%);
  }

  .hero-annotation {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    pointer-events: none;
    z-index: 2;
  }

  .hero-annotation--tr { top: 20px; right: 32px; }
  .hero-annotation--bl { bottom: 20px; left: 32px; }
  .anno-code { color: var(--blue); opacity: 0.8; }
  .anno-sep  { opacity: 0.3; }

  /* Breadcrumb inside hero */
  .breadcrumb {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 20px 0;
    font-size: 12px;
    border-bottom: 1px solid var(--border);
  }

  .breadcrumb-link { color: var(--text-3); transition: color 0.15s; text-decoration: none; }
  .breadcrumb-link:hover { color: var(--blue); }
  .breadcrumb-sep { color: var(--border-2); }
  .breadcrumb-current {
    color: var(--text-3);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 480px;
  }

  /* Hero inner */
  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 48px 0 60px;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  /* Post meta row */
  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }


  .post-meta-sep {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--border-2);
  }

  .post-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-3);
    opacity: 0.6;
  }

  .hero-headline {
    font-size: clamp(28px, 4vw, 50px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 20px;
    max-width: 760px;
  }

  .post-byline {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
    opacity: 0.45;
  }

  /* ── Content ──────────────────────────────────── */
  .content-wrap { padding: 64px 0 80px; }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 64px;
    align-items: start;
  }

  .main-col {
    display: flex;
    flex-direction: column;
    gap: 48px;
    min-width: 0;
  }

  /* Post body from PortableText */
  .post-body {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.85;
  }

  .no-content { color: var(--text-3); font-style: italic; }

  /* ── Sidebar ──────────────────────────────────── */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 88px;
  }

  .sidebar-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .sidebar-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.65;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    display: block;
  }

  .sidebar-body-wrap {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sidebar-body {
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.7;
  }

  .sidebar-text-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--blue);
    text-decoration: none;
    transition: gap 0.15s;
  }

  .sidebar-text-link:hover { gap: 9px; }

  /* CTA card */
  .sidebar-card--cta {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: var(--surface-2);
  }

  .sidebar-cta-status {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .sidebar-cta-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--green);
    animation: ctapulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes ctapulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }

  .sidebar-cta-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green);
    opacity: 0.8;
  }

  .sidebar-cta-heading {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-2);
  }

  .sidebar-cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: var(--blue);
    color: #111315;
    font-weight: 700;
    font-size: 13px;
    border-radius: 2px;
    padding: 10px 16px;
    text-decoration: none;
    margin-top: 4px;
    transition: opacity 0.2s;
  }

  :global([data-theme="light"]) .sidebar-cta-btn { color: #FFFFFF; }
  .sidebar-cta-btn:hover { opacity: 0.88; }

  /* Back link */
  .sidebar-back-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.45;
    text-decoration: none;
    padding: 4px 0;
    transition: opacity 0.15s, color 0.15s;
  }

  .sidebar-back-link:hover { opacity: 1; color: var(--text-2); }

  /* ── Inline subscribe ─────────────────────────── */
  .inline-subscribe {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .inline-subscribe-copy {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex-shrink: 0;
  }

  .inline-subscribe-prompt {
    font-size: 14px;
    color: var(--text-3);
  }

  .inline-subscribe-helper {
    font-size: 12px;
    color: var(--text-3);
    opacity: 0.5;
  }

  .inline-subscribe-form {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .inline-subscribe-input {
    width: 200px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 9px 12px;
    font-size: 13px;
    font-family: inherit;
    color: var(--text);
    outline: none;
    transition: border-color 0.15s;
  }

  .inline-subscribe-input::placeholder { color: var(--text-3); }
  .inline-subscribe-input:focus { border-color: var(--blue); }

  .inline-subscribe-btn {
    background: var(--blue);
    color: #111315;
    font-weight: 700;
    font-size: 13px;
    font-family: inherit;
    border: none;
    border-radius: 2px;
    padding: 9px 16px;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  :global([data-theme="light"]) .inline-subscribe-btn { color: #FFFFFF; }
  .inline-subscribe-btn:hover { opacity: 0.88; }

  .inline-subscribe-success {
    display: none;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green);
  }

  /* ── Related Posts ────────────────────────────── */
  .related-section {
    border-top: 1px solid var(--border);
    padding: 56px 0 72px;
  }

  .related-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .related-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.65;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .related-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

