---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTag from '../../components/ui/SectionTag.astro';
import Button from '../../components/ui/Button.astro';
import PortableText from '../../components/ui/PortableText.astro';
import { getPostBySlug, getAllPostSlugs, estimateReadTime } from '../../lib/sanity';

export async function getStaticPaths() {
  try {
    const slugs = await getAllPostSlugs();
    if (slugs.length > 0) {
      return slugs.map((s: { slug: string }) => ({ params: { slug: s.slug } }));
    }
  } catch (_) {}
  return [
    'why-service-businesses-fail-online',
    'google-ads-plateau',
    'local-seo-2026',
    'service-business-website-conversion',
    'ai-in-client-engagements',
  ].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

let post: any = null;
try {
  post = await getPostBySlug(slug);
} catch (_) {}

const slugCategoryMap: Record<string, string> = {
  'why-service-businesses-fail-online': 'Strategy',
  'google-ads-plateau': 'Paid Ads',
  'local-seo-2026': 'SEO',
  'service-business-website-conversion': 'Web',
  'ai-in-client-engagements': 'AI',
};

if (!post) {
  post = {
    title: slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
    excerpt: 'Full post content coming soon.',
    publishedAt: new Date().toISOString(),
    slug: { current: slug },
    categories: slugCategoryMap[slug] ? [{ title: slugCategoryMap[slug] }] : [],
  };
}

const formattedDate = new Date(post.publishedAt).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const readTime = post.body ? estimateReadTime(post.body) : null;
---

<BaseLayout
  title={`${post.title} — Railshop Blog`}
  description={post.seo?.metaDescription ?? post.excerpt}
>
  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <div class="container breadcrumb-inner">
      <a href="/blog" class="breadcrumb-link">Blog</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{post.title}</span>
    </div>
  </div>

  <!-- Hero -->
  <section class="post-hero">
    <div class="container">
      <div class="post-hero-meta">
        {post.categories?.map((cat: any) => (
          <span class="post-cat-tag">{cat.title}</span>
        ))}
        <span class="post-date">{formattedDate}</span>
        {readTime && <span class="post-date">{readTime}</span>}
      </div>
      <h1 class="post-title">{post.title}</h1>
      <p class="post-byline">By the Railshop Team</p>
    </div>
  </section>

  <!-- Body -->
  <div class="content-wrap">
    <div class="container content-grid">

      <!-- Main -->
      <article class="post-body">
        {post.body ? (
          <PortableText value={post.body} />
        ) : (
          <p class="no-content">Post content coming soon.</p>
        )}
      </article>

      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-card">
          <p class="sidebar-eyebrow">// About the Authors</p>
          <p class="sidebar-body">Drew and Sean co-founded Railshop after years leading digital marketing and product at national service brands. This is the stuff they wish someone had told them sooner.</p>
          <a href="/about" class="sidebar-link">Meet the team →</a>
        </div>

        <div class="sidebar-card">
          <p class="sidebar-eyebrow">// Work With Us</p>
          <p class="sidebar-body">If this post resonated, we should talk. Railshop helps service businesses grow through web, paid ads, and SEO.</p>
          <a href="/contact#hubspot-meetings" class="sidebar-btn-link">Book a Call</a>
        </div>
      </aside>

    </div>
  </div>

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container cta-inner">
      <SectionTag label="Enjoyed This Post?" />
      <h2 class="cta-title">See how we put this into practice.</h2>
      <p class="cta-desc">Book a call and we'll walk you through how we'd apply this to your business specifically.</p>
      <div class="cta-buttons">
        <Button href="/contact#hubspot-meetings" variant="primary">Book a Call</Button>
        <Button href="/blog" variant="secondary">Read More Posts</Button>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Breadcrumb ── */
  .breadcrumb { border-bottom: 1px solid var(--border); background: var(--surface); }
  .breadcrumb-inner { display: flex; align-items: center; gap: 8px; padding: 14px 24px; font-size: 13px; }
  .breadcrumb-link { color: var(--text-3); transition: color 0.15s; }
  .breadcrumb-link:hover { color: var(--text); }
  .breadcrumb-sep { color: var(--border-2); }
  .breadcrumb-current { color: var(--text-3); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 360px; }

  /* ── Hero ── */
  .post-hero {
    padding: 64px 0 56px;
    border-bottom: 1px solid var(--border);
  }

  .post-hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .post-cat-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--blue);
    background: var(--blue-glow);
    border: 1px solid var(--blue-border);
    border-radius: 999px;
    padding: 4px 10px;
    display: inline-flex;
    align-items: center;
  }

  .post-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-3);
  }

  .post-title {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.15;
    max-width: 720px;
    margin-bottom: 16px;
  }

  .post-byline {
    font-size: 14px;
    color: var(--text-3);
  }

  /* ── Layout ── */
  .content-wrap { padding: 64px 0 80px; }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 64px;
    align-items: start;
  }

  /* ── Post body ── */
  .post-body {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.85;
    min-width: 0;
  }

  .no-content {
    color: var(--text-3);
    font-style: italic;
  }

  .post-body :global(h2) {
    font-size: 22px;
    font-weight: 700;
    color: var(--text-2);
    margin-top: 24px;
    letter-spacing: -0.01em;
  }

  .post-body :global(p) {
    font-size: 16px;
    color: var(--text-3);
    line-height: 1.85;
  }

  .post-body :global(a) {
    color: var(--blue);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 24px 0;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5em;
    color: var(--text-3);
    line-height: 1.85;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--blue);
    padding-left: 1.25em;
    margin: 0;
    color: var(--text-3);
    font-style: italic;
  }

  /* ── Sidebar ── */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 88px;
  }

  .sidebar-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sidebar-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.65;
  }

  .sidebar-body {
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.7;
  }

  .sidebar-link {
    font-size: 12px;
    font-weight: 600;
    color: var(--blue);
    text-decoration: none;
  }

  .sidebar-link:hover { text-decoration: underline; }

  .sidebar-btn-link {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--blue);
    color: #111315;
    font-weight: 700;
    font-size: 14px;
    border-radius: 8px;
    padding: 10px 18px;
    transition: opacity 0.2s;
    text-decoration: none;
    margin-top: 4px;
  }

  :global([data-theme="light"]) .sidebar-btn-link { color: #FFFFFF; }

  .sidebar-btn-link:hover { opacity: 0.88; }

  /* ── CTA Banner ── */
  .cta-banner {
    position: relative;
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 80px 0;
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    top: -80px;
    right: -80px;
    width: 500px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(56, 182, 255, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .cta-title {
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 800;
    color: var(--text-2);
    letter-spacing: -0.02em;
    line-height: 1.2;
    max-width: 560px;
  }

  .cta-desc {
    font-size: 16px;
    color: var(--text-3);
    max-width: 440px;
    line-height: 1.7;
  }

  .cta-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .content-grid { grid-template-columns: 1fr; }
    .sidebar { position: static; }
  }
</style>
