---
interface Props {
  eyebrow?: string;
  heading: string;
  subhead?: string;
  align?: 'left' | 'center';
  headingLevel?: 'h2' | 'h3';
}

const {
  eyebrow,
  heading,
  subhead,
  align = 'left',
  headingLevel = 'h2',
} = Astro.props;

const Tag = headingLevel;
---

<div class:list={['section-header', align === 'center' && 'section-header--center']}>
  {eyebrow && <p class="eyebrow section-header-eyebrow">{eyebrow}</p>}
  <Tag class="section-header-heading" set:html={heading} />
  {subhead && <p class="section-header-sub">{subhead}</p>}
</div>

<style>
  .section-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .section-header--center {
    align-items: center;
    text-align: center;
  }

  .section-header-eyebrow {
    margin: 0;
  }

  .section-header-heading {
    font-size: var(--fs-h2);
    font-weight: var(--fw-black);
    line-height: var(--lh-heading);
    letter-spacing: var(--ls-heading);
    color: var(--text-2);
    max-width: 680px;
    margin: 0;
  }

  .section-header--center .section-header-heading {
    max-width: 720px;
  }

  .section-header-sub {
    font-size: var(--fs-body);
    color: var(--text-3);
    line-height: var(--lh-body);
    max-width: 540px;
    margin: 0;
  }

  .section-header--center .section-header-sub {
    max-width: 600px;
  }
</style>
