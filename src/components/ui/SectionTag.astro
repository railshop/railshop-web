---
interface Props {
  label: string;
  class?: string;
}

const { label, class: className = '' } = Astro.props;
---

<span class={`section-tag ${className}`}>// {label}</span>

<style>
  .section-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blue);
    opacity: 0.65;
  }
</style>
