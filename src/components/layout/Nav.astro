---
import ThemeToggle from '../ThemeToggle';
import { getSiteSettings } from '../../lib/sanity';

const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Work', href: '/work' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;

let settings: any = null;
try { settings = await getSiteSettings(); } catch (_) {}

const clientLoginUrl = settings?.clientLoginUrl ?? 'https://launchpad.railshop.co';
const takingNewClients = settings?.takingNewClients ?? true;
---

<header class="nav-header">
  <div class="nav-accent-bar" aria-hidden="true"></div>
  <div class="container nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Railshop home">
      <img src="/logo-white.svg" alt="Railshop" class="logo-for-dark"  width="120" height="42" />
      <img src="/logo-dark.svg"  alt="Railshop" class="logo-for-light" width="120" height="42" style="display:none" />
    </a>

    <!-- Center links (desktop) -->
    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'nav-link--active' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right: theme toggle + client login + CTA -->
    <div class="nav-right">
      <ThemeToggle client:load />
      <a
        href={clientLoginUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="nav-client-login"
        aria-label="Client Login"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
      </a>
      <a href="/contact#book-a-call" class="btn-primary nav-cta">
        Book a Call
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile overlay -->
<div class="nav-mobile-overlay" id="nav-mobile-overlay" aria-hidden="true" aria-modal="true" role="dialog">
  <div class="nav-mobile-topbar">
    <a href="/" class="nav-logo" aria-label="Railshop home">
      <img src="/logo-white.svg" alt="Railshop" class="logo-for-dark"  width="120" height="42" />
      <img src="/logo-dark.svg"  alt="Railshop" class="logo-for-light" width="120" height="42" style="display:none" />
    </a>
    <button class="nav-close" id="nav-close" aria-label="Close menu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <nav class="nav-mobile-links" aria-label="Mobile navigation">
    {navLinks.map((link, i) => (
      <a href={link.href} class="nav-mobile-link">
        <span class="nav-mobile-idx">0{i + 1}</span>
        {link.label}
      </a>
    ))}
    <a
      href={clientLoginUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="nav-mobile-link nav-mobile-link--secondary"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
      Client Login
    </a>
  </nav>

  <div class="nav-mobile-footer">
    <a href="/contact#book-a-call" class="btn-primary nav-mobile-cta">
      Book a Call
    </a>
    {takingNewClients && (
      <p class="nav-mobile-status">
        <span class="status-dot"></span>
        Taking new clients
      </p>
    )}
  </div>
</div>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const closeBtn  = document.getElementById('nav-close');
  const overlay   = document.getElementById('nav-mobile-overlay');

  function openMenu() {
    overlay?.classList.add('is-open');
    hamburger?.setAttribute('aria-expanded', 'true');
    overlay?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    overlay?.classList.remove('is-open');
    hamburger?.setAttribute('aria-expanded', 'false');
    overlay?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  overlay?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('is-open')) closeMenu();
  });
</script>

<style>
  /* Thin accent line at very top */
  .nav-accent-bar {
    height: 2px;
    background: linear-gradient(90deg, var(--blue) 0%, transparent 60%);
    opacity: 0.6;
  }

  .nav-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(17, 19, 21, 0.92);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  [data-theme="light"] .nav-mobile-link {
    color: var(--text-2);
  }

  [data-theme="light"] .nav-mobile-link:hover {
    color: var(--text);
    background: var(--surface-2);
  }

  [data-theme="light"] .nav-mobile-idx { opacity: 0.5; }

  [data-theme="light"] .nav-mobile-link--secondary {
    color: var(--text-3);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 24px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav-logo img {
    height: 36px;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .nav-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-3);
    padding: 6px 12px;
    border-radius: 4px;
    transition: color 0.15s ease, background 0.15s ease;
    position: relative;
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--surface);
  }

  .nav-link--active {
    color: var(--text) !important;
  }

  .nav-link--active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 12px;
    right: 12px;
    height: 1px;
    background: var(--blue);
    opacity: 0.6;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .nav-cta {
    font-size: 13px;
    padding: 7px 14px;
  }

  .nav-client-login {
    display: inline-flex;
    align-items: center;
    width: 32px;
    height: 32px;
    justify-content: center;
    color: var(--text-3);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: color 0.15s, border-color 0.15s;
  }

  .nav-client-login:hover {
    color: var(--text);
    border-color: var(--border-2);
  }

  /* ── Hamburger ── */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    padding: 8px;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
  }

  .nav-hamburger span {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--text);
    border-radius: 1px;
    transition: opacity 0.15s;
  }

  .nav-hamburger:hover span {
    background: var(--blue);
  }

  /* ── Mobile overlay ── */
  .nav-mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background-color: var(--bg);
    flex-direction: column;
  }

  .nav-mobile-overlay.is-open {
    display: flex;
  }

  .nav-mobile-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    padding: 0 24px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .nav-close {
    background: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 7px;
    cursor: pointer;
    color: var(--text-3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s, color 0.15s;
  }

  .nav-close:hover {
    border-color: var(--blue-border);
    color: var(--text);
  }

  .nav-mobile-links {
    display: flex;
    flex-direction: column;
    padding: 8px 0;
    flex: 1;
    overflow-y: auto;
  }

  .nav-mobile-link {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 20px;
    font-weight: 700;
    color: var(--text-3);
    padding: 18px 24px;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s, background 0.15s;
    letter-spacing: -0.02em;
  }

  .nav-mobile-link:hover {
    color: var(--text);
    background: var(--surface);
  }

  .nav-mobile-idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--text-3);
    opacity: 0.35;
    flex-shrink: 0;
    width: 24px;
  }

  .nav-mobile-link--secondary {
    font-size: 14px;
    font-weight: 500;
    gap: 10px;
    letter-spacing: 0;
    border-bottom: none;
    opacity: 0.6;
  }

  .nav-mobile-link--secondary .nav-mobile-idx {
    display: none;
  }

  .nav-mobile-footer {
    padding: 20px 24px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .nav-mobile-cta {
    width: 100%;
    justify-content: center;
  }

  .nav-mobile-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--green);
    justify-content: center;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .nav-links,
    .nav-right {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }
  }
</style>
