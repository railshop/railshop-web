---
import ThemeToggle from '../ThemeToggle';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Work', href: '/work' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav-header">
  <div class="container nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Railshop home">
      <img src="/logo-white.svg" alt="Railshop" class="logo-for-dark"  width="120" height="42" />
      <img src="/logo-dark.svg"  alt="Railshop" class="logo-for-light" width="120" height="42" style="display:none" />
    </a>

    <!-- Center links (desktop) -->
    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'nav-link--active' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right: theme toggle + CTA -->
    <div class="nav-right">
      <ThemeToggle client:load />
      <a href="/contact#hubspot-meetings" class="btn-primary nav-cta">
        Book a Call
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<!-- Mobile overlay — outside <header> so z-index is independent -->
<div class="nav-mobile-overlay" id="nav-mobile-overlay" aria-hidden="true" aria-modal="true" role="dialog">
  <!-- Overlay top bar: logo + close -->
  <div class="nav-mobile-topbar">
    <a href="/" class="nav-logo" aria-label="Railshop home">
      <img src="/logo-white.svg" alt="Railshop" class="logo-for-dark"  width="120" height="42" />
      <img src="/logo-dark.svg"  alt="Railshop" class="logo-for-light" width="120" height="42" style="display:none" />
    </a>
    <button class="nav-close" id="nav-close" aria-label="Close menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Links -->
  <nav class="nav-mobile-links" aria-label="Mobile navigation">
    {navLinks.map((link) => (
      <a href={link.href} class="nav-mobile-link">
        {link.label}
      </a>
    ))}
  </nav>

  <!-- Pinned CTA -->
  <div class="nav-mobile-footer">
    <a href="/contact#hubspot-meetings" class="btn-primary nav-mobile-cta">
      Book a Call
    </a>
  </div>
</div>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const closeBtn  = document.getElementById('nav-close');
  const overlay   = document.getElementById('nav-mobile-overlay');

  function openMenu() {
    overlay?.classList.add('is-open');
    hamburger?.setAttribute('aria-expanded', 'true');
    overlay?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    overlay?.classList.remove('is-open');
    hamburger?.setAttribute('aria-expanded', 'false');
    overlay?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Close on any nav link click
  overlay?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('is-open')) closeMenu();
  });
</script>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 24px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav-logo img {
    height: 36px;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-link--active {
    color: var(--text) !important;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .nav-cta {
    font-size: 13px;
    padding: 8px 14px;
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
  }

  /* ── Mobile overlay ─────────────────────────────── */
  .nav-mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;           /* above the sticky header (100) */
    background-color: var(--bg);
    flex-direction: column;
  }

  .nav-mobile-overlay.is-open {
    display: flex;
  }

  /* Top bar inside overlay — mirrors the real nav bar */
  .nav-mobile-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 24px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  /* Close button */
  .nav-close {
    background: none;
    border: 1px solid var(--border-2);
    border-radius: 8px;
    padding: 8px;
    cursor: pointer;
    color: var(--text-3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s, color 0.15s;
  }

  .nav-close:hover {
    border-color: var(--blue-border);
    color: var(--text);
  }

  /* Links */
  .nav-mobile-links {
    display: flex;
    flex-direction: column;
    padding: 16px 24px;
    flex: 1;
    overflow-y: auto;
  }

  .nav-mobile-link {
    font-size: 22px;
    font-weight: 600;
    color: var(--text-3);
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s;
    display: block;
  }

  .nav-mobile-link:hover {
    color: var(--text);
  }

  /* Pinned CTA */
  .nav-mobile-footer {
    padding: 24px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }

  .nav-mobile-cta {
    width: 100%;
    justify-content: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav-links,
    .nav-right {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }
  }
</style>
