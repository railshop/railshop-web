---
import { getSiteSettings } from '../../lib/sanity';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Work', href: '/work' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const year = new Date().getFullYear();

let settings: any = null;
try { settings = await getSiteSettings(); } catch (_) {}

const tagline = settings?.footerTagline ?? 'Digital growth for service businesses.\nBuilt on strategy. Delivered by people who\'ve done it at scale.';
const address = settings?.address ?? '33 East Pittsburgh Street\nGreensburg, PA 15601';
const linkedIn = settings?.linkedIn ?? 'https://linkedin.com/company/railshop';
const instagramUrl = settings?.instagramUrl ?? 'https://instagram.com/railshop';
const ctaHeading = settings?.footerCtaHeading ?? 'Get Started';
const ctaCopy = settings?.footerCtaCopy ?? 'Ready to see what the right digital partner can do for your business?';
---

<footer class="footer">
  <!-- Top accent line -->
  <div class="footer-accent" aria-hidden="true">
    <div class="footer-accent-line"></div>
    <span class="footer-accent-label">RAILSHOP DIGITAL SYSTEMS</span>
    <div class="footer-accent-line footer-accent-line--right"></div>
  </div>

  <div class="container footer-inner">
    <div class="footer-top">
      <!-- Brand col -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="/logo-white.svg" alt="Railshop" class="logo-for-dark"  width="120" height="42" />
          <img src="/logo-dark.svg"  alt="Railshop" class="logo-for-light" width="120" height="42" style="display:none" />
        </a>
        <p class="footer-tagline" set:html={tagline.replace(/\n/g, '<br />')} />
        <address class="footer-address" set:html={address.replace(/\n/g, '<br />')} />
        <div class="footer-socials">
          <a
            href={linkedIn}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-icon"
            aria-label="Follow Railshop on LinkedIn"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a
            href={instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-icon"
            aria-label="Follow Railshop on Instagram"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav col -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <p class="footer-col-heading">Navigate</p>
        {navLinks.map((link) => (
          <a href={link.href} class="footer-nav-link">{link.label}</a>
        ))}
      </nav>

      <!-- CTA col -->
      <div class="footer-cta-col">
        <p class="footer-col-heading">{ctaHeading}</p>
        <p class="footer-cta-copy">{ctaCopy}</p>
        <a href="/contact#book-a-call" class="btn-primary footer-cta-btn">
          Book a Call
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; {year} Railshop LLC. All rights reserved.</p>
      <div class="footer-bottom-right">
        <a href="/privacy" class="footer-privacy">Privacy Policy</a>
        <span class="footer-coord">GRG · 40.29°N · 79.55°W</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  /* Accent header bar */
  .footer-accent {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 24px;
    height: 36px;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .footer-accent-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-2));
  }

  .footer-accent-line--right {
    background: linear-gradient(90deg, var(--border-2), transparent);
  }

  .footer-accent-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-3);
    opacity: 0.4;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .footer-inner {
    padding: 56px 24px 28px;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 56px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--border);
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: center;
    margin-bottom: 18px;
  }

  .footer-logo img {
    height: 32px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.65;
    margin-bottom: 20px;
    max-width: 260px;
  }

  .footer-address {
    font-size: 12px;
    color: var(--text-3);
    line-height: 1.7;
    font-style: normal;
    opacity: 0.7;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.02em;
  }

  .footer-socials {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-top: 20px;
  }

  .footer-social-icon {
    width: 32px;
    height: 32px;
    border: 1px solid var(--border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-3);
    transition: color 0.15s, border-color 0.15s;
  }

  .footer-social-icon:hover {
    color: var(--blue);
    border-color: var(--blue-border);
  }

  /* Nav col */
  .footer-col-heading {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-3);
    margin-bottom: 20px;
    opacity: 0.6;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer-nav-link {
    font-size: 14px;
    color: var(--text-3);
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s ease, padding-left 0.15s ease;
    display: block;
  }

  .footer-nav-link:first-of-type {
    border-top: 1px solid var(--border);
  }

  .footer-nav-link:hover {
    color: var(--text);
    padding-left: 6px;
  }

  /* CTA col */
  .footer-cta-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-cta-copy {
    font-size: 14px;
    color: var(--text-3);
    line-height: 1.65;
  }

  .footer-cta-btn {
    display: inline-flex;
    align-self: flex-start;
  }

  /* Bottom bar */
  .footer-bottom {
    padding-top: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 12px;
    color: var(--text-3);
    opacity: 0.55;
  }

  .footer-bottom-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .footer-privacy {
    font-size: 12px;
    color: var(--text-3);
    opacity: 0.55;
    transition: color 0.15s, opacity 0.15s;
  }

  .footer-privacy:hover {
    color: var(--text);
    opacity: 1;
  }

  .footer-coord {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    color: var(--text-3);
    opacity: 0.3;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .footer-accent {
      padding: 0 16px;
    }

    .footer-coord {
      display: none;
    }
  }

</style>
