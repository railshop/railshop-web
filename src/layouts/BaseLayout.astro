---
import '../styles/global.css';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import { getSiteSettings, urlForImage } from '../lib/sanity';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Railshop — Performance Marketing for Modern Brands',
  description = 'We build and run paid media programs that compound. From strategy to creative to analytics, Railshop drives measurable growth.',
  ogImage = '/og-default.png',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

let faviconUrl = '/favicon.svg';
let orgName = 'Railshop';
let orgDescription = 'Boutique digital growth agency for home and consumer service businesses.';
let orgLogoUrl = '';
const orgSameAs: string[] = [];

try {
  const settings = await getSiteSettings();
  if (settings?.favicon?.asset?._ref) faviconUrl = urlForImage(settings.favicon).url();
  if (settings?.siteTitle) orgName = settings.siteTitle;
  if (settings?.siteDescription) orgDescription = settings.siteDescription;
  if (settings?.logo?.asset?._ref) orgLogoUrl = urlForImage(settings.logo).url();
  if (settings?.linkedIn) orgSameAs.push(settings.linkedIn);
  if (settings?.instagramUrl) orgSameAs.push(settings.instagramUrl);
} catch (_) {}

const orgNode: Record<string, unknown> = {
  '@type': ['Organization', 'ProfessionalService'],
  '@id': 'https://railshop.co/#organization',
  'name': orgName,
  'url': 'https://railshop.co',
  'description': orgDescription,
  'address': {
    '@type': 'PostalAddress',
    'addressLocality': 'Pittsburgh',
    'addressRegion': 'PA',
    'addressCountry': 'US',
  },
};
if (orgLogoUrl) orgNode.logo = { '@type': 'ImageObject', 'url': orgLogoUrl };
if (orgSameAs.length > 0) orgNode.sameAs = orgSameAs;

const globalSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    orgNode,
    {
      '@type': 'WebSite',
      '@id': 'https://railshop.co/#website',
      'name': orgName,
      'url': 'https://railshop.co',
      'publisher': { '@id': 'https://railshop.co/#organization' },
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href={faviconUrl} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>

    <!-- Global structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(globalSchema)} />

    <slot name="head" />

    <!-- Theme init: read localStorage before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          if (stored === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
